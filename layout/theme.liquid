  {%- liquid
    assign resolved_canonical_url = canonical_url
    assign product_redirect_path = blank
    assign patches_path_prefix = request.path | slice: 0, 9
    assign custom_canonical_metafield = blank
    assign robots_meta_content = 'index, follow'
    assign custom_robots_metafield = blank
    assign meta_description_content = page_description

    if patches_path_prefix == '/patches/'
      assign product_redirect_path = request.path | replace_first: '/patches/', '/products/'
      assign resolved_canonical_url = shop.url | append: product_redirect_path
    endif

    if request.page_type == 'product'
      assign custom_canonical_metafield = product.metafields.custom.canonical_url
      assign custom_robots_metafield = product.metafields.custom.seo_robots | default: product.metafields.custom.seo_keywords
      assign product_meta_description = product.metafields.global.description_tag.value | default: product.metafields.global.description_tag
      assign meta_description_content = product_meta_description | default: meta_description_content | default: product.description
    elsif request.page_type == 'collection'
      assign custom_canonical_metafield = collection.metafields.custom.canonical_url
      assign custom_robots_metafield = collection.metafields.custom.seo_robots | default: collection.metafields.custom.seo_keywords
      assign collection_meta_description = collection.metafields.global.description_tag.value | default: collection.metafields.global.description_tag
      assign meta_description_content = collection_meta_description | default: meta_description_content | default: collection.description
    elsif request.page_type == 'blog'
      assign custom_canonical_metafield = blog.metafields.custom.canonical_url
      assign custom_robots_metafield = blog.metafields.custom.seo_robots | default: blog.metafields.custom.seo_keywords
    elsif request.page_type == 'article'
      assign custom_canonical_metafield = article.metafields.custom.canonical_url
      assign custom_robots_metafield = article.metafields.custom.seo_robots | default: article.metafields.custom.seo_keywords
    elsif request.page_type == 'page'
      assign custom_canonical_metafield = page.metafields.custom.canonical_url
      assign custom_robots_metafield = page.metafields.custom.seo_robots | default: page.metafields.custom.seo_keywords
    endif

    assign custom_canonical_url = custom_canonical_metafield.value | default: custom_canonical_metafield
    assign custom_robots_meta_content = custom_robots_metafield.value | default: custom_robots_metafield

    if custom_canonical_url != blank
      assign resolved_canonical_url = custom_canonical_url
    endif

    if custom_robots_meta_content != blank
      assign robots_meta_content = custom_robots_meta_content
    endif

    assign meta_description_content = meta_description_content | strip_html | strip
  -%}
  <link rel="canonical" href="{{ resolved_canonical_url }}">
  {%- if product_redirect_path != blank -%}
    <meta http-equiv="refresh" content="0;url={{ product_redirect_path }}">
  {%- endif -%}
  <meta name="robots" content="{{ robots_meta_content | escape }}">
  {%- if meta_description_content != blank -%}
    <meta name="description" content="{{ meta_description_content | escape }}">
  {%- endif -%}
  {%- if settings.favicon != blank -%}
    <link rel="icon" type="image/png" href="{{ settings.favicon | image_url: width: 32, height: 32 }}">
    <link rel="shortcut icon" href="{{ settings.favicon | image_url: width: 32, height: 32 }}">
    <link rel="apple-touch-icon" href="{{ settings.favicon | image_url: width: 180, height: 180 }}">
  {%- else -%}
    <link rel="icon" href="{{ 'favicon.ico' | asset_url }}" sizes="any">
    <link rel="shortcut icon" href="{{ 'favicon.ico' | asset_url }}">
  {%- endif -%}
  {%- if request.page_type == 'index' -%}
    <link rel="preload" as="image" href="{{ 'home-page-hero.webp' | asset_url }}" fetchpriority="high">
  {%- endif -%}
  <title>{{ page_title }} - {{ shop.name }}</title>
    {% comment %}
      Schema snippets are created but not currently applied.
      Re-enable these renders when the schema is ready to publish.
    {% endcomment %}
    {%- if request.page_type == 'product' -%}
      {% render 'product-schema' %}
    {%- elsif request.page_type == 'collection' -%}
      {% render 'collection-schema' %}
    {%- elsif request.page_type == 'index' -%}
      {% render 'home-schema' %}
    {%- endif -%}
  {{ content_for_header }}
