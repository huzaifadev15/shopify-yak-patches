<script>
  window.FineystShopifyAnalytics = {
    page_type: {{ request.page_type | json }},
    currency: {{ cart.currency.iso_code | default: shop.currency | default: 'USD' | json }}
    {%- if request.page_type == 'product' and product -%}
    ,
    product: {
      id: {{ product.id | json }},
      variant_id: {{ product.selected_or_first_available_variant.id | json }},
      title: {{ product.title | json }},
      type: {{ product.type | default: 'Patches' | json }},
      variant_title: {{ product.selected_or_first_available_variant.title | json }},
      price: {{ product.selected_or_first_available_variant.price | divided_by: 100.0 | json }}
    }
    {%- endif -%}
    {%- if request.page_type == 'cart' and cart.item_count > 0 -%}
    ,
    cart: {
      currency: {{ cart.currency.iso_code | default: shop.currency | default: 'USD' | json }},
      value: {{ cart.total_price | divided_by: 100.0 | json }},
      items: [
        {%- for item in cart.items -%}
          {%- assign analytics_price = item.final_price | divided_by: 100.0 -%}
          {%- if item.properties['custom_price'] != blank -%}
            {%- assign analytics_price = item.properties['custom_price'] | remove: '$' | strip -%}
          {%- elsif item.properties['Calculated Unit Price'] != blank -%}
            {%- assign analytics_price = item.properties['Calculated Unit Price'] | remove: '$' | strip -%}
          {%- endif -%}
          {
            id: {{ item.variant_id | json }},
            name: {{ item.product.title | json }},
            category: {{ item.product.type | default: 'Patches' | json }},
            variant: {{ item.variant.title | json }},
            price: {{ analytics_price | json }},
            quantity: {{ item.quantity | json }}
          }{% unless forloop.last %},{% endunless %}
        {%- endfor -%}
      ]
    }
    {%- endif -%}
    {%- if first_time_accessed and checkout -%}
    ,
    purchase: {
      transaction_id: {{ checkout.order_id | default: checkout.order_number | default: checkout.id | json }},
      value: {{ checkout.total_price | divided_by: 100.0 | json }},
      currency: {{ checkout.currency | default: shop.currency | default: 'USD' | json }},
      items: [
        {%- for item in checkout.line_items -%}
          {
            id: {{ item.variant_id | default: item.product_id | json }},
            name: {{ item.title | json }},
            category: {{ item.product.type | default: 'Patches' | json }},
            variant: {{ item.variant.title | json }},
            price: {{ item.final_price | divided_by: 100.0 | json }},
            quantity: {{ item.quantity | json }}
          }{% unless forloop.last %},{% endunless %}
        {%- endfor -%}
      ]
    }
    {%- endif -%}
  };
</script>
