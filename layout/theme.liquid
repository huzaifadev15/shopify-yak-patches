  <style>
    html { overflow-x: clip; }
    body { overflow-x: clip; max-width: 100%; overscroll-behavior-x: none; }
    /* Search overlay */
    .search-overlay { position:fixed; inset:0; z-index:9999; background:rgba(10,14,35,0.96); display:flex; flex-direction:column; opacity:0; pointer-events:none; transition:opacity 0.2s; font-family:"Averta","Segoe UI",Arial,sans-serif; }
    .search-overlay.open { opacity:1; pointer-events:all; }
    .search-overlay-header { display:flex; align-items:center; justify-content:space-between; padding:20px 40px; border-bottom:1px solid rgba(255,255,255,0.08); flex-shrink:0; }
    .search-overlay-logo { height:36px; }
    .search-close-btn { background:none; border:none; color:#fff; cursor:pointer; padding:6px; display:flex; align-items:center; justify-content:center; opacity:0.7; transition:opacity 0.2s; }
    .search-close-btn:hover { opacity:1; }
    .search-overlay-body { flex:1; overflow:hidden; display:flex; flex-direction:column; align-items:center; padding:40px 24px 0; }
    .search-input-wrap { display:flex; align-items:center; background:rgba(255,255,255,0.08); border:1px solid rgba(255,255,255,0.15); border-radius:9999px; padding:0 8px 0 20px; width:100%; max-width:600px; }
    .search-icon-inside { flex-shrink:0; color:#9ca3af; }
    .search-input { flex:1; border:none; outline:none; font-size:17px; padding:14px 12px; background:transparent; color:#fff; font-family:inherit; }
    .search-input::placeholder { color:#6b7280; }
    .search-submit-btn { flex-shrink:0; width:38px; height:38px; border-radius:50%; background:#C4520A; border:none; color:#fff; display:flex; align-items:center; justify-content:center; cursor:pointer; transition:background 0.2s; }
    .search-submit-btn:hover { background:#e64a19; }
    .search-tabs { display:flex; gap:8px; margin-top:20px; width:100%; max-width:600px; }
    .search-tab { padding:6px 16px; border-radius:9999px; font-size:13px; font-weight:600; cursor:pointer; border:1px solid rgba(255,255,255,0.2); color:#9ca3af; background:none; transition:all 0.15s; }
    .search-tab.active { background:#C4520A; border-color:#C4520A; color:#fff; }
    .search-results { width:100%; max-width:600px; margin-top:16px; background:rgba(255,255,255,0.05); border-radius:12px; overflow-y:auto; max-height:calc(100vh - 320px); border:1px solid rgba(255,255,255,0.08); }
    .search-result-item { display:flex; align-items:center; gap:14px; padding:14px 16px; border-bottom:1px solid rgba(255,255,255,0.06); text-decoration:none; transition:background 0.15s; }
    .search-result-item:last-child { border-bottom:none; }
    .search-result-item:hover { background:rgba(255,255,255,0.07); }
    .search-result-icon { width:40px; height:40px; border-radius:8px; background:rgba(255,87,34,0.15); display:flex; align-items:center; justify-content:center; flex-shrink:0; overflow:hidden; }
    .search-result-icon img { width:100%; height:100%; object-fit:cover; border-radius:8px; }
    .search-result-icon svg { color:#C4520A; }
    .search-result-info { flex:1; min-width:0; }
    .search-result-title { font-size:14px; font-weight:600; color:#fff; white-space:nowrap; overflow:hidden; text-overflow:ellipsis; }
    .search-result-desc { font-size:12px; color:#9ca3af; margin-top:2px; white-space:nowrap; overflow:hidden; text-overflow:ellipsis; }
    .search-result-type { font-size:11px; color:#6b7280; margin-top:3px; }
    .search-empty { padding:32px; text-align:center; color:#6b7280; font-size:14px; }
    .search-overlay-footer { display:flex; align-items:center; justify-content:space-between; padding:16px 40px; border-top:1px solid rgba(255,255,255,0.08); flex-shrink:0; }
    .search-esc-hint { font-size:12px; color:#6b7280; }
    .search-browse-all { font-size:13px; font-weight:600; color:#C4520A; text-decoration:none; }
    .search-browse-all:hover { color:#D4A820; }
    @media(max-width:640px){ .search-overlay-header,.search-overlay-footer{ padding:16px 20px; } .search-overlay-body{ padding:24px 16px 0; } }
  </style>
  <script>
    (function() {
      var FIRST_TOUCH_KEY = 'aid_first_touch';
      var LAST_TOUCH_KEY  = 'aid_last_touch';

      function getCookie(name) {
        var v = document.cookie.split('; ').find(function(c){ return c.startsWith(name + '='); });
        return v ? decodeURIComponent(v.split('=')[1]) : null;
      }

      function setCookie(name, value, days) {
        var expires = new Date();
        expires.setTime(expires.getTime() + days * 24 * 60 * 60 * 1000);
        document.cookie = name + '=' + encodeURIComponent(value) + ';expires=' + expires.toUTCString() + ';path=/';
      }

      var params = new URLSearchParams(window.location.search);
      var hasGoogle = !!(params.get('gclid') || params.get('gad_source') || params.get('gad_campaignid'));

      var source   = params.get('utm_source')   || (hasGoogle ? 'google' : null);
      var medium   = params.get('utm_medium')   || (hasGoogle ? 'paid'   : null);
      var campaign = params.get('utm_campaign') || null;

      var hasData = source || medium || campaign;

      if (hasData) {
        var touch = JSON.stringify({ source: source, medium: medium, campaign: campaign });
        // Last touch: always overwrite
        setCookie(LAST_TOUCH_KEY, touch, 30);
        // First touch: only set once, never overwrite
        if (!getCookie(FIRST_TOUCH_KEY)) {
          setCookie(FIRST_TOUCH_KEY, touch, 365);
        }
      }

      // Expose helper so forms can read attribution at submit time
      window.FineystAttribution = {
        get: function() {
          var firstRaw = getCookie(FIRST_TOUCH_KEY);
          var lastRaw  = getCookie(LAST_TOUCH_KEY);
          var first = firstRaw ? JSON.parse(firstRaw) : {};
          var last  = lastRaw  ? JSON.parse(lastRaw)  : {};
          return {
            firstSource:   first.source   || null,
            firstMedium:   first.medium   || null,
            firstCampaign: first.campaign || null,
            lastSource:    last.source    || null,
            lastMedium:    last.medium    || null,
            lastCampaign:  last.campaign  || null,
            isFine:        true
          };
        }
      };
    })();
    </script>
