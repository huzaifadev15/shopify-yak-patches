  // Configurator preview for files the browser can't render (PDF/AI/EPS/PSD/HEIC)
  function showFilePlaceholder(fileName){
    var name = fileName || 'Design file';
    if (name.length > 30) name = name.slice(0, 14) + 'â€¦' + name.slice(-13);
    var safe = name.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;').replace(/'/g,'&apos;');
    var svg = '<svg xmlns="http://www.w3.org/2000/svg" width="400" height="300" viewBox="0 0 400 300">'
      + '<rect width="400" height="300" fill="#fff8f3"/>'
      + '<g transform="translate(200,112)">'
      + '<path d="M-26,-44 h34 l18,18 v70 h-52 z" fill="#fff" stroke="#C4520A" stroke-width="3" stroke-linejoin="round"/>'
      + '<path d="M8,-44 v18 h18" fill="none" stroke="#C4520A" stroke-width="3" stroke-linejoin="round"/>'
      + '<path d="M-13,-8 h26 M-13,6 h26 M-13,20 h17" stroke="#fdba74" stroke-width="3" stroke-linecap="round"/>'
      + '</g>'
      + '<text x="200" y="220" text-anchor="middle" font-family="-apple-system,BlinkMacSystemFont,Segoe UI,Arial,sans-serif" font-size="14" font-weight="600" fill="#374151">' + safe + '</text>'
      + '<text x="200" y="243" text-anchor="middle" font-family="-apple-system,BlinkMacSystemFont,Segoe UI,Arial,sans-serif" font-size="11" fill="#9ca3af">File attached â€” preview not available</text>'
      + '</svg>';
    cfgImg.src = 'data:image/svg+xml,' + encodeURIComponent(svg);
