.pp-stars { display: flex; align-items: center; gap: 2px; }
.pp-stars svg { width: 16px; height: 16px; fill: #facc15; color: #facc15; }
.pp-review-count { margin-left: 8px; font-size: 14px; color: #6b7280; }
.pp-price-row { margin: 12px 0; font-size: 18px; color: #111; }
.pp-price-row strong { font-size: 24px; font-weight: 800; }
.pp-price-row span { font-weight: 600; }
.pp-desc { font-size: 15px; font-weight: 600; color: #6b7280; line-height: 1.6; margin: 0px 0; display: -webkit-box; -webkit-line-clamp: 3; -webkit-box-orient: vertical; overflow: hidden; }
.pp-trust { display: flex; flex-wrap: wrap; gap: 12px; font-size: 13px; font-weight: 700; color: #111; padding: 12px 0; border-top: 1px solid #e5e7eb; border-bottom: 1px solid #e5e7eb; margin: 16px 0; }
.pp-trust-item { display: inline-flex; align-items: center; }
.pp-trust-note { margin-left: 4px; font-weight: 600; }
.pp-trust-sep { color: #d1d5db; }
.pp-trustpilot-wrap { margin: 8px 0 16px 0; display: flex; justify-content: flex-start; }
.pp-trustpilot-widget { width: fit-content; max-width: 120px; }
.pp-upload-box { position: relative; height: 240px; border-radius: 12px; background: linear-gradient(135deg, #fff8f3, #F0D8C2); padding: 16px; display: flex; flex-direction: column; align-items: center; justify-content: center; border: 2px dashed #C4520A; box-shadow: 0 0 15px rgba(20,26,50,0.3), inset 0 0 20px rgba(255,165,100,0.15); margin-bottom: 16px; }
.pp-upload-btn { background: #C4520A; color: #fff; border: none; border-radius: 9999px; padding: 10px 24px; font-size: 15px; font-weight: 700; cursor: pointer; display: flex; align-items: center; gap: 8px; margin-bottom: 8px; transition: box-shadow 0.2s; }
