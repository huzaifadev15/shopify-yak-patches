  /* â”€â”€ Crop Modal â”€â”€ */
  (function() {
    var modal    = document.getElementById('cropModal');
    var img      = document.getElementById('crpmImg');
    var box      = document.getElementById('crpmBox');
    var subtitle = document.getElementById('crpmSubtitle');
    var wrap     = document.getElementById('crpmCanvasWrap');

    function openCropModal() {
      var w = parseFloat(document.getElementById('cfgWidth').value)  || 1;
      var h = parseFloat(document.getElementById('cfgHeight').value) || 1;
      subtitle.textContent = 'Adjust framing to match ' + w.toFixed(2) + '" Ã— ' + h.toFixed(2) + '" proportions.';

      img.src = window.uploadedImageUrl;
      modal.classList.add('open');
      modal.setAttribute('aria-hidden', 'false');
      document.body.style.overflow = 'hidden';

      img.onload = function() { initCropBox(w / h); };
      if (img.complete && img.naturalWidth) initCropBox(w / h);
    }
    window.openCropModal = openCropModal;

    /* â”€â”€ Initialise crop box to fill ~80% of image, locked to patch aspect ratio â”€â”€ */
    function initCropBox(aspect) {
      var iw = wrap.clientWidth;
      var ih = img.clientHeight;
      var boxW = iw * 0.80;
      var boxH = boxW / aspect;
      if (boxH > ih * 0.80) { boxH = ih * 0.80; boxW = boxH * aspect; }
      var x = (iw - boxW) / 2;
      var y = (ih - boxH) / 2;
      setBox(x, y, boxW, boxH);
    }

    function setBox(x, y, w, h) {
      var iw = wrap.clientWidth;
      var ih = img.clientHeight;
      x = Math.max(0, Math.min(x, iw - w));
      y = Math.max(0, Math.min(y, ih - h));
      w = Math.max(40, Math.min(w, iw - x));
      h = Math.max(40, Math.min(h, ih - y));
      box.style.left   = x + 'px';
      box.style.top    = y + 'px';
      box.style.width  = w + 'px';
      box.style.height = h + 'px';
    }

    /* â”€â”€ Drag & resize â”€â”€ */
    var drag = null; // { type:'move'|dir, startX, startY, ox, oy, ow, oh }

    function onPointerDown(e) {
      e.preventDefault();
      var dir = e.target.dataset.dir;
      var cx  = e.clientX || (e.touches && e.touches[0].clientX);
      var cy  = e.clientY || (e.touches && e.touches[0].clientY);
      drag = {
        type:  dir || 'move',
        startX: cx, startY: cy,
        ox: parseInt(box.style.left),  oy: parseInt(box.style.top),
        ow: parseInt(box.style.width), oh: parseInt(box.style.height)
      };
    }

    function onPointerMove(e) {
      if (!drag) return;
      var cx  = e.clientX || (e.touches && e.touches[0].clientX);
      var cy  = e.clientY || (e.touches && e.touches[0].clientY);
      var dx  = cx - drag.startX;
      var dy  = cy - drag.startY;
      var aspect = (parseFloat(document.getElementById('cfgWidth').value)  || 1) /
                   (parseFloat(document.getElementById('cfgHeight').value) || 1);
      var x = drag.ox, y = drag.oy, w = drag.ow, h = drag.oh;
      var iw = wrap.clientWidth, ih = img.clientHeight;

      if (drag.type === 'move') {
        x = drag.ox + dx; y = drag.oy + dy;
      } else {
        var t = drag.type;
        // resize keeping aspect ratio
        if (t === 'se' || t === 's' || t === 'e') {
          w = drag.ow + dx; h = w / aspect;
        } else if (t === 'sw' || t === 'w') {
          w = drag.ow - dx; h = w / aspect; x = drag.ox + drag.ow - w;
        } else if (t === 'ne' || t === 'n') {
          w = drag.ow + dx; h = w / aspect; y = drag.oy + drag.oh - h;
        } else if (t === 'nw') {
          w = drag.ow - dx; h = w / aspect; x = drag.ox + drag.ow - w; y = drag.oy + drag.oh - h;
        }
      }
      setBox(x, y, w, h);
    }

    function onPointerUp() { drag = null; }

    box.addEventListener('mousedown',  onPointerDown);
    box.addEventListener('touchstart', onPointerDown, { passive: false });
    document.addEventListener('mousemove',  onPointerMove);
    document.addEventListener('touchmove',  onPointerMove, { passive: false });
    document.addEventListener('mouseup',  onPointerUp);
    document.addEventListener('touchend',  onPointerUp);

    /* â”€â”€ Apply crop â”€â”€ */
    document.getElementById('crpmApply').onclick = function() {
      var scaleX = img.naturalWidth  / img.clientWidth;
      var scaleY = img.naturalHeight / img.clientHeight;
      var bx = parseInt(box.style.left)   * scaleX;
      var by = parseInt(box.style.top)    * scaleY;
      var bw = parseInt(box.style.width)  * scaleX;
      var bh = parseInt(box.style.height) * scaleY;

      var canvas = document.createElement('canvas');
      canvas.width  = bw;
      canvas.height = bh;
      var ctx = canvas.getContext('2d');
      var source = new Image();
      source.crossOrigin = 'anonymous';
      source.onload = function() {
        ctx.drawImage(source, bx, by, bw, bh, 0, 0, bw, bh);
        var cropped = canvas.toDataURL('image/png');
        window.uploadedImageUrl = cropped;
        var cfgImg = document.getElementById('cfgPreviewImg');
        if (cfgImg) cfgImg.src = cropped;
        cropSwitch.setAttribute('aria-checked', 'true');
        closeModal();
      };
      source.onerror = function() {
        // fallback: use canvas drawn from img element
        ctx.drawImage(img, bx, by, bw, bh, 0, 0, bw, bh);
        var cropped = canvas.toDataURL('image/png');
        window.uploadedImageUrl = cropped;
        var cfgImg = document.getElementById('cfgPreviewImg');
        if (cfgImg) cfgImg.src = cropped;
        cropSwitch.setAttribute('aria-checked', 'true');
        closeModal();
      };
      source.src = window.uploadedImageUrl;
    };

    /* â”€â”€ Close helpers â”€â”€ */
    function closeModal() {
      modal.classList.remove('open');
      modal.setAttribute('aria-hidden', 'true');
      document.body.style.overflow = '';
    }

    function cancelCrop() {
      restoreOriginalImage();
      cropSwitch.setAttribute('aria-checked', 'false');
      closeModal();
    }
    document.getElementById('crpmClose').onclick    = cancelCrop;
    document.getElementById('crpmCancel').onclick   = cancelCrop;
    document.getElementById('crpmBackdrop').onclick = cancelCrop;
    document.addEventListener('keydown', function(e) { if (e.key === 'Escape' && modal.classList.contains('open')) cancelCrop(); });
  })();
  
