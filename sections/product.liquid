.pp-gallery-grid { display:grid; grid-template-columns:repeat(4,1fr); gap:24px; }
.pp-gcard { height:100%; }
.pp-gcard-inner { position:relative; border-radius:16px; overflow:hidden; border:1px solid #EDD9A0; background:#fff; box-shadow:0 1px 4px rgba(0,0,0,0.06); }
.pp-gcard-img-wrap { position:relative; width:100%; padding-bottom:100%; }
