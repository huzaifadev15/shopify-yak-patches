<style>
.pp-wrap, .pp-wrap * { box-sizing: border-box; font-family: "Averta", "Segoe UI", Arial, sans-serif !important; }
.pp-wrap { background: #fff; padding: 100px 0 48px; overflow-x: hidden; max-width: 100%; }
@media (max-width: 991px) { .pp-wrap { margin-top: 20px; padding-top: 116px; } }
.pp-inner { max-width: 1280px; margin: 0 auto; margin-top : 28px; padding: 0 24px; display: grid; grid-template-columns: minmax(0,1fr) minmax(0,2fr); gap: 48px; align-items: start; }
.pp-gallery { position: sticky; }
.pp-main-img-box { position: relative; width: 100%; height: 0; padding-bottom: 100%; overflow: hidden; border-radius: 12px; border: 1px solid #e5e7eb; background: #f9fafb; }
