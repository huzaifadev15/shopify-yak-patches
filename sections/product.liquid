.pp-product-desc-body p { margin-bottom:16px; }
.pp-product-desc-body h1,.pp-product-desc-body h2,.pp-product-desc-body h3 { font-weight:700; color:#1C0800; margin:24px 0 12px; }
.pp-product-desc-body ul,
.pp-product-desc-body ol {
