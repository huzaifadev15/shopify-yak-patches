.pp-ai-btn { display: inline-flex; align-items: center; gap: 8px; border-radius: 9999px; padding: 8px 24px; font-size: 15px; font-weight: 700; color: #fff; border: none; cursor: pointer; background: linear-gradient(135deg, #C4520A, #ec4899, #a855f7); transition: opacity 0.2s; }
.pp-ai-btn:hover { opacity: 0.9; }
.pp-hr { border: none; border-top: 1px solid #e5e7eb; margin-top: 40px; margin-right: 10px; margin-bottom: 10px; margin-left: 0; }
/* Gallery Section */
.pp-gallery-section { margin: 0 0 64px; padding: 48px 24px; background: linear-gradient(135deg, #FDF8ED, #fff, #FDF8ED); max-width: 1280px; margin: 0 auto 64px; }
.pp-gallery-header { text-align:center; margin-bottom:48px; }
.pp-gallery-title-wrap { display:inline-block; }
.pp-gallery-title { font-size:clamp(28px,4vw,44px); font-weight:800; background:linear-gradient(135deg,#A33A06,#C4520A); -webkit-background-clip:text; -webkit-text-fill-color:transparent; margin-bottom:12px; }
.pp-gallery-underline { height:4px; width:128px; background:linear-gradient(135deg,#A33A06,#D4A820); border-radius:9999px; margin:0 auto; }
