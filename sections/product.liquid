.ai-underline-tag-dark { font-size:8px; font-weight:700; text-transform:uppercase; letter-spacing:0.1em; color:#1C0800; }
.ai-prompts-used { margin-top:8px; font-size:11px; color:#9ca3af; }
.ai-preview-area { padding:12px 24px 12px; flex:1; overflow:hidden; }
.ai-preview-box { border-radius:12px; border:1px solid #e5e7eb; background:#f9fafb; overflow:hidden; height:100%; display:flex; align-items:center; justify-content:center; position:relative; }
