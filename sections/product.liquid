.ai-history-img { width:100%; height:128px; object-fit:cover; display:block; cursor:pointer; }
.ai-prompt-area { flex-shrink:0; padding:16px 24px 0; }
.ai-prompt-label { display:flex; align-items:center; justify-content:space-between; margin-bottom:8px; }
.ai-new-chat { margin-left:auto; display:flex; align-items:center; gap:6px; padding:6px 10px; border-radius:9999px; font-size:11px; font-weight:600; background:#C4520A; color:#fff; border:1px solid rgba(255,87,34,0.25); cursor:pointer; transition:background 0.2s; }
.ai-new-chat:hover { background:#E64A19; }
.ai-textarea-wrap { margin-top:10px; border-radius:12px; padding:1px; background:linear-gradient(135deg,rgba(249,115,22,0.55),rgba(236,72,153,0.45),rgba(168,85,247,0.55)); }
.ai-textarea { width:100%; border-radius:11px; border:1px solid transparent; font-size:14px; padding:12px 16px; resize:none; outline:none; color:#1C0800; background:#fff; line-height:1.6; box-sizing:border-box; }
.ai-textarea::placeholder { color:#6b7280; font-weight:700; }
.ai-hint { margin-top:8px; font-size:13px; }
