          });
      } else {
        // Use URL directly
        fetch('https://shopify-backend-app-omega.vercel.app/api/ai/edit', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ action: 'remove_background', imageUrl: window.uploadedImageUrl })
        })
        .then(function(r) { return r.json(); })
        .then(function(data) {
          var reqId = data.requestId || data.generation_id || data.id;
          if (reqId) {
            pollRemoveBgStatus(reqId, 0, Date.now(), bgSwitch, originalText);
          } else {
            bgSwitch.disabled = false;
            bgSwitch.parentElement.querySelector('.cfg-toggle-text').innerHTML = originalText;
          }
