  function validateConfiguratorRequiredFields(w, h, bgColor, border) {
    // Clear previous errors
    ['cfgWidth','cfgHeight','cfgBgColor','cfgBorder'].forEach(function(id){
      document.getElementById(id).classList.remove('cfg-input-err');
    });
    ['cfgWidthErr','cfgHeightErr','cfgBgColorErr','cfgBorderErr'].forEach(function(id){
      var el = document.getElementById(id); el.textContent=''; el.classList.remove('visible');
    });

    var hasError = false;
    if (!parseFloat(w) || parseFloat(w) <= 0) {
      var ew = document.getElementById('cfgWidthErr');
      ew.textContent = 'Mandatory field!'; ew.classList.add('visible');
      document.getElementById('cfgWidth').classList.add('cfg-input-err');
      hasError = true;
    }
    if (!parseFloat(h) || parseFloat(h) <= 0) {
      var eh = document.getElementById('cfgHeightErr');
      eh.textContent = 'Mandatory field!'; eh.classList.add('visible');
      document.getElementById('cfgHeight').classList.add('cfg-input-err');
      hasError = true;
    }
    if (!bgColor) {
      var e = document.getElementById('cfgBgColorErr');
      e.textContent = 'Mandatory field!'; e.classList.add('visible');
      document.getElementById('cfgBgColor').classList.add('cfg-input-err');
      hasError = true;
    }
    if (!border) {
      var e2 = document.getElementById('cfgBorderErr');
      e2.textContent = 'Mandatory field!'; e2.classList.add('visible');
      document.getElementById('cfgBorder').classList.add('cfg-input-err');
      hasError = true;
    }
    if (hasError) {
      if (!parseFloat(w) || parseFloat(w) <= 0) document.getElementById('cfgWidth').focus();
      else if (!parseFloat(h) || parseFloat(h) <= 0) document.getElementById('cfgHeight').focus();
      else if (!bgColor) document.getElementById('cfgBgColor').focus();
      else document.getElementById('cfgBorder').focus();
      return false;
    }

    return true;
  }

  function toShopifyCartPayload() {
    var qty = parseInt(document.getElementById('cfgQty').value, 10);
    var w   = document.getElementById('cfgWidth').value;
    var h   = document.getElementById('cfgHeight').value;
    var shape   = document.getElementById('cfgShapeLabel').textContent;
    var backing = document.getElementById('cfgBackingLabel').textContent;
    var bgColor = document.getElementById('cfgBgColor').value.trim();
    var border  = document.getElementById('cfgBorder').value.trim();
    var notes   = document.getElementById('cfgNotes').value;

    if (!validateQtyMinimum()) return null;
    if (!validateConfiguratorRequiredFields(w, h, bgColor, border)) return null;

    var pricingData = window._fineyst && window._fineyst.pricingData;
    if (!pricingData || !Array.isArray(pricingData) || pricingData.length === 0) {
      alert('Pricing information is still loading. Please wait a moment and try again.');
      return null;
    }

    var size = Math.max(parseFloat(w), parseFloat(h));
    var sizeData = currentSizeData || findSizeData(size);
    var unitPrice = sizeData ? getPriceForQuantity(sizeData, qty) : 0;
    var backingFee = backing === 'No Backing' ? 0 : 0.50;

    if (!unitPrice || unitPrice <= 0) {
      alert('Pricing information is still loading. Please wait a moment and try again.');
      return null;
    }

    var effectiveUnitPrice = (unitPrice + backingFee).toFixed(2);
    var totalPrice = ((unitPrice + backingFee) * qty).toFixed(2);
    var props = {
      'Width': w + '"',
      'Height': h + '"',
      'Patch Quantity': String(qty),
      'Shape': shape,
      'Backing': backing,
      'Background Color': bgColor,
      'Border': border,
      'custom_price': effectiveUnitPrice,
      'customPrice': effectiveUnitPrice,
      'Calculated Unit Price': effectiveUnitPrice,
      'Calculated Total': totalPrice
    };

    if (notes) props['Design Notes'] = notes;
    if (QUOTE_API_URL) props['Quote API URL'] = QUOTE_API_URL;

    (window.uploadedFiles || []).forEach(function(file, i) {
      var url = file.fileUrl || file.url || '';
      if (url) props['Artwork File ' + (i + 1)] = url;
    });

    if (document.getElementById('aiPropImageUrl').value) {
      props['_AI Provider']   = document.getElementById('aiPropProvider').value;
      props['_AI Model']      = document.getElementById('aiPropModel').value;
      props['_AI Prompt']     = document.getElementById('aiPropPrompt').value;
      props['_AI Request ID'] = document.getElementById('aiPropRequestId').value;
      props['_AI Image URL']  = document.getElementById('aiPropImageUrl').value;
    }

    return {
      id: CART_VARIANT_ID,
      quantity: qty,
      configuredQuantity: qty,
      configuredTotal: totalPrice,
      properties: props
    };
  }

