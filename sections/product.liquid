.ai-preview-img { width:100%; height:100%; object-fit:contain; display:none; position:relative; z-index:1; }
.ai-modal-footer { padding:12px 24px; border-top:1px solid #f3f4f6; background:#fff; display:flex; flex-direction:column; gap:8px; flex-shrink:0; }
.ai-footer-row { display:flex; align-items:center; justify-content:space-between; gap:8px; }
.ai-edit-row { display:none; align-items:center; gap:8px; padding:8px 12px; background:#f9fafb; border-radius:12px; border:1px solid #e5e7eb; }
.ai-edit-row.visible { display:flex; }
.ai-edit-input { flex:1; border:none; background:transparent; font-size:13px; color:#1C0800; outline:none; }
.ai-edit-input::placeholder { color:#9ca3af; }
.ai-edit-btn { flex-shrink:0; padding:6px 14px; border-radius:9999px; font-size:13px; font-weight:700; color:#fff; border:none; cursor:pointer; display:flex; align-items:center; gap:6px; background:linear-gradient(135deg,#C4520A,#ec4899,#a855f7); transition:opacity 0.2s; white-space:nowrap; }
.ai-edit-btn:hover:not(:disabled) { opacity:0.9; }
.ai-edit-btn:disabled { opacity:0.35; cursor:not-allowed; }
.ai-use-btn { padding:8px 20px; border-radius:12px; font-size:14px; font-weight:700; color:#fff; border:none; cursor:pointer; display:none; align-items:center; gap:8px; background:#22c55e; transition:opacity 0.2s; }
.ai-use-btn:hover:not(:disabled) { opacity:0.9; }
.ai-use-btn:disabled { opacity:0.35; cursor:not-allowed; }
.ai-discard-btn { padding:8px 16px; border-radius:12px; font-size:14px; color:#9ca3af; background:#fff; border:1px solid #e5e7eb; cursor:pointer; transition:all 0.2s; }
.ai-discard-btn:hover:not(:disabled) { color:#374151; background:#f3f4f6; }
.ai-discard-btn:disabled { opacity:0.3; cursor:not-allowed; }
.ai-generate-btn { padding:8px 20px; border-radius:12px; font-size:14px; font-weight:700; color:#fff; border:none; cursor:pointer; display:flex; align-items:center; gap:8px; background:linear-gradient(135deg,#C4520A,#ec4899,#a855f7); box-shadow:0 4px 16px rgba(168,85,247,0.25); transition:opacity 0.2s; }
.ai-generate-btn:hover:not(:disabled) { opacity:0.9; }
.ai-generate-btn:disabled { opacity:0.35; cursor:not-allowed; box-shadow:none; }
