  }
  window._fineyst.syncRemoveButtonVisibility = syncRemoveButtonVisibility;
  var cfgWidthLabel= document.getElementById('cfgWidthLabel');
  var cfgRulerV    = document.getElementById('cfgRulerV');
  var cfgImgFrame  = document.getElementById('cfgImgFrame');

  var pricingData = null; // loaded from API (array of size objects)
  var currentSizeData = null; // current size pricing object
  // Expose to window so other IIFEs (e.g. quote modal) can access them
  window._fineyst = window._fineyst || {};
  Object.defineProperty(window._fineyst, 'pricingData', {
    get: function() { return pricingData; },
    set: function(v) { pricingData = v; }
  });
  Object.defineProperty(window._fineyst, 'currentSizeData', {
