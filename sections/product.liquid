  margin: 8px 0 12px;
  padding-left: 18px;
  list-style: disc;
}
.pp-feat-answer-inner li {
  margin-bottom: 6px;
}
@media (max-width:768px) { .pp-product-desc-section { padding:20px 16px; margin-bottom:0 !important; } .pp-product-desc-inner { grid-template-columns:1fr; gap:32px; padding:24px 20px; margin-top:0 !important; } }
/* FAQ Section */
.pp-faq-section { max-width:1280px; margin:0 auto 64px; padding:0 24px; }
.pp-faq-title { font-size:clamp(22px,2.5vw,32px); font-weight:800; color:#1C0800; margin-bottom:24px; }
.pp-faq-list { display:flex; flex-direction:column; }
.pp-faq-item { position:relative; display:block; border-top:1px solid #e5e7eb; }
.pp-faq-item:last-child { border-bottom:1px solid #e5e7eb; }
.pp-faq-toggle { position:absolute; opacity:0; pointer-events:none; }
.pp-faq-question { width:100%; display:flex; align-items:center; gap:16px; padding:18px 0; background:none; border:none; cursor:pointer; text-align:left; font-size:17px; font-weight:700; color:#1C0800; transition:color 0.15s; }
.pp-faq-icon { flex-shrink:0; font-size:20px; font-weight:300; color:#1C0800; width:20px; line-height:1; }
.pp-faq-icon--open { display:none; }
.pp-faq-toggle:checked + .pp-faq-question .pp-faq-icon--closed { display:none; }
.pp-faq-toggle:checked + .pp-faq-question .pp-faq-icon--open { display:inline; }
.pp-faq-answer { max-height:0; overflow:hidden; transition:max-height 0.3s ease; }
.pp-faq-toggle:checked ~ .pp-faq-answer { max-height:600px; }
.pp-faq-answer-inner { padding:0 0 16px 36px; font-size:15px; font-weight:400; color:#1C0800; line-height:1.75; white-space:pre-line; }
@media(max-width:640px) { .pp-faq-question { padding:14px 0; font-size:14px; } .pp-faq-answer-inner { padding:0 0 14px 32px; } }
/* Reviews Section */
.pp-rev-section { max-width:1280px; margin:0 auto 64px; padding:0 24px; }
.pp-rev-title { font-size:clamp(22px,2.5vw,32px); font-weight:800; color:#1C0800; margin-bottom:32px; text-align:center; }
/* Summary */
.pp-rev-summary { display:grid; grid-template-columns:1fr 1fr; gap:32px; align-items:center; margin-bottom:32px; padding-bottom:32px; border-bottom:1px solid #e5e7eb; }
.pp-rev-avg-col { display:flex; align-items:center; gap:20px; justify-content:flex-end; border-right:1px solid #dedede; padding-right:40px; }
.pp-rev-avg-num { font-size:64px; font-weight:700; color:#1C0800; line-height:1; flex-shrink:0; }
.pp-rev-avg-right { display:flex; flex-direction:column; gap:6px; }
.pp-rev-avg-stars { display:flex; gap:3px; }
.pp-rev-avg-star { font-size:26px; color:#f6be00; }
.pp-rev-avg-star.empty { color:#e5e7eb; }
.pp-rev-avg-sub { font-size:14px; color:#374151; font-weight:700; }
.pp-rev-breakdown { display:flex; flex-direction:column; gap:10px; padding-left:24px; }
.pp-rev-bar-row { display:flex; align-items:center; gap:10px; font-size:14px; color:#374151; }
.pp-rev-bar-label { width:10px; text-align:right; }
.pp-rev-bar-star { color:#f6be00; font-size:14px; line-height:1; }
.pp-rev-bar-track { flex:1; height:6px; background:#e9e9e9; border-radius:9999px; overflow:hidden; min-width:120px; }
.pp-rev-bar-fill { height:100%; background:#1C0800; border-radius:9999px; }
.pp-rev-bar-count { width:28px; text-align:right; color:#374151; }
@media(max-width:768px) { .pp-rev-summary { grid-template-columns:1fr; } .pp-rev-avg-col { justify-content:flex-start; border-right:none; padding-right:0; border-bottom:1px solid #dedede; padding-bottom:24px; } .pp-rev-breakdown { padding-left:0; padding-top:24px; } }
/* Media strip */
.pp-rev-media-wrap { margin-bottom:28px; padding-bottom:28px; border-bottom:1px solid #e5e7eb; }
.pp-rev-media-header { display:flex; align-items:center; justify-content:space-between; margin-bottom:14px; }
.pp-rev-media-title { font-size:16px; font-weight:700; color:#1C0800; }
.pp-rev-media-nav { display:flex; gap:8px; }
.pp-rev-media-btn { width:36px; height:36px; border-radius:50%; border:1px solid #e5e7eb; background:#fff; display:flex; align-items:center; justify-content:center; cursor:pointer; color:#374151; transition:background 0.15s; }
.pp-rev-media-btn:hover { background:#f3f4f6; }
.pp-rev-media-strip { display:flex; gap:10px; overflow-x:auto; scrollbar-width:none; scroll-behavior:smooth; }
.pp-rev-media-strip::-webkit-scrollbar { display:none; }
.pp-rev-media-thumb { width:140px; height:140px; flex-shrink:0; border-radius:8px; overflow:hidden; cursor:pointer; }
.pp-rev-media-thumb img { width:100%; height:100%; object-fit:cover; }
/* Filters */
.pp-rev-filters { display:flex; flex-wrap:wrap; align-items:center; gap:10px; margin-bottom:16px; padding-bottom:16px; }
.pp-rev-search-wrap { position:relative; flex:1; min-width:200px; max-width:280px; }
.pp-rev-search { width:100%; padding:8px 36px 8px 14px; border:1px solid #d1d5db; border-radius:9999px; font-size:14px; outline:none; font-family:inherit; }
.pp-rev-search:focus { border-color:#1C0800; }
.pp-rev-search-icon { position:absolute; right:12px; top:50%; transform:translateY(-50%); color:#9ca3af; pointer-events:none; }
.pp-rev-filter-btn { padding:8px 18px; border:1.5px solid #d1d5db; border-radius:9999px; background:#fff; font-size:14px; font-weight:600; color:#374151; cursor:pointer; font-family:inherit; transition:all 0.15s; }
.pp-rev-filter-btn:hover,.pp-rev-filter-btn.active { border-color:#1C0800; background:#1C0800; color:#fff; }
.pp-rev-media-toggle { display:flex; align-items:center; gap:8px; font-size:14px; font-weight:600; color:#374151; cursor:pointer; }
.pp-rev-toggle-switch { position:relative; width:44px; height:24px; border-radius:9999px; background:#d1d5db; border:none; cursor:pointer; transition:background 0.2s; flex-shrink:0; }
.pp-rev-toggle-switch.on { background:#1C0800; }
.pp-rev-toggle-thumb { position:absolute; top:4px; left:4px; width:16px; height:16px; border-radius:50%; background:#fff; transition:transform 0.2s; }
.pp-rev-toggle-switch.on .pp-rev-toggle-thumb { transform:translateX(20px); }
.pp-rev-topics { display:flex; flex-wrap:wrap; gap:8px; margin-bottom:16px; align-items:center; }
.pp-rev-topics-label { font-size:13px; font-weight:600; color:#6b7280; }
.pp-rev-topic-btn { padding:5px 14px; border:1px solid #d1d5db; border-radius:9999px; background:#fff; font-size:13px; color:#374151; cursor:pointer; font-family:inherit; transition:all 0.15s; }
.pp-rev-topic-btn:hover,.pp-rev-topic-btn.active { border-color:#1C0800; background:#1C0800; color:#fff; }
.pp-rev-sort-row { display:flex; justify-content:flex-end; align-items:center; gap:8px; font-size:14px; color:#374151; margin-bottom:8px; }
.pp-rev-sort-select { border:none; font-size:14px; font-weight:700; color:#1C0800; cursor:pointer; outline:none; background:none; font-family:inherit; }
/* Review list */
.pp-rev-list { display:flex; flex-direction:column; }
.pp-rev-item { display:grid; grid-template-columns:56px 1fr auto; gap:12px 18px; padding:20px 0; border-top:1px solid #e5e7eb; align-items:start; }
.pp-rev-item:last-child { border-bottom:1px solid #e5e7eb; }
.pp-rev-item.hidden { display:none; }
.pp-rev-avatar { width:44px; height:44px; border-radius:50%; background:#e5e7eb; display:flex; align-items:center; justify-content:center; font-size:14px; font-weight:700; color:#374151; flex-shrink:0; overflow:hidden; }
.pp-rev-avatar img { width:100%; height:100%; object-fit:cover; }
.pp-rev-left { display:flex; flex-direction:column; gap:3px; }
.pp-rev-name { font-size:14px; font-weight:700; color:#1C0800; }
.pp-rev-location { font-size:12px; color:#6b7280; }
