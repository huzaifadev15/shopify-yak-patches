          bgSwitch.disabled = false;
          bgSwitch.parentElement.querySelector('.cfg-toggle-text').innerHTML = originalText;
        });
      }
    } else {
      // Toggle off â€” restore original image
      restoreOriginalImage();
      bgSwitch.setAttribute('aria-checked', 'false');
    }
  };
  
  function pollRemoveBgStatus(requestId, attempt, startTime, switchEl, originalText) {
    var elapsed = Date.now() - startTime;
    if (elapsed > 90000) {
      switchEl.disabled = false;
      switchEl.parentElement.querySelector('.cfg-toggle-text').innerHTML = originalText;
      return;
    }
    
    fetch('https://shopify-backend-app-omega.vercel.app/api/ai/edit/' + requestId)
      .then(function(r) { return r.json(); })
      .then(function(data) {
        if (data.status === 'completed') {
          var imageUrl = null;
          if (data.images && data.images.length > 0 && data.images[0].url) imageUrl = data.images[0].url;
          else if (data.image && data.image.url) imageUrl = data.image.url;
          else if (data.output && typeof data.output === 'string') imageUrl = data.output;
          else if (data.output && data.output.images && data.output.images.length > 0 && data.output.images[0].url) imageUrl = data.output.images[0].url;
          
          if (imageUrl) {
            fetch(imageUrl)
              .then(function(r) { return r.blob(); })
              .then(function(blob) {
                var reader = new FileReader();
                reader.onload = function(e) {
                  cfgImg.src = e.target.result;
                  window.uploadedImageUrl  = e.target.result;
                  window.removedBgImageUrl = e.target.result; // cache for re-use
                  switchEl.setAttribute('aria-checked', 'true');
                  switchEl.disabled = false;
                  switchEl.parentElement.querySelector('.cfg-toggle-text').innerHTML = originalText;
                };
                reader.readAsDataURL(blob);
              })
              .catch(function() {
                switchEl.disabled = false;
                switchEl.parentElement.querySelector('.cfg-toggle-text').innerHTML = originalText;
              });
          } else {
            switchEl.disabled = false;
            switchEl.parentElement.querySelector('.cfg-toggle-text').innerHTML = originalText;
          }
        } else if (data.status === 'failed') {
          switchEl.disabled = false;
          switchEl.parentElement.querySelector('.cfg-toggle-text').innerHTML = originalText;
        } else {
          setTimeout(function() { pollRemoveBgStatus(requestId, attempt + 1, startTime, switchEl, originalText); }, 2500);
        }
      })
      .catch(function() {
        setTimeout(function() { pollRemoveBgStatus(requestId, attempt + 1, startTime, switchEl, originalText); }, 2500);
      });
  }

