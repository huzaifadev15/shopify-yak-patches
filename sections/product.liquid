.pp-rev-helpful { display:flex; align-items:center; gap:12px; margin-top:8px; font-size:13px; color:#6b7280; }
.pp-rev-helpful-btn { display:inline-flex; align-items:center; gap:5px; background:none; border:none; cursor:pointer; font-size:13px; color:#6b7280; padding:0; font-family:inherit; }
.pp-rev-helpful-btn:hover { color:#1C0800; }
.pp-rev-date { font-size:13px; color:#6b7280; white-space:nowrap; }
.pp-rev-empty { text-align:center; padding:40px; color:#9ca3af; font-size:14px; }
@media(max-width:768px) { .pp-rev-avg-col { padding-right:0; border-right:none; border-bottom:1px solid #dedede; padding-bottom:24px; } }
@media(max-width:640px) { .pp-rev-item { grid-template-columns:44px 1fr; } .pp-rev-date { grid-column:1/-1; } }
/* Before/After Section */
.pp-ba-wrap { max-width:1280px; margin:0 auto 64px; padding:0 24px; }
.pp-ba-inner { background:#f7f7f5; border-radius:24px; padding:32px; display:grid; grid-template-columns:1fr minmax(480px,640px); gap:48px; align-items:center; }
.pp-ba-title { font-size:clamp(22px,2.5vw,40px); font-weight:600; color:#111; line-height:1.15; max-width:28ch; margin-bottom:16px; }
