.pp-upload-sub { font-size: 11px; font-weight: 600; color: #374151; text-align: center; }
.pp-upload-later { position: absolute; bottom: 16px; left: 16px; display: flex; align-items: center; gap: 6px; font-size: 13px; font-weight: 600; color: #374151; }
.pp-ai-box { border-radius: 12px; padding: 2px; background: linear-gradient(135deg, #D4A820, #f43f5e, #a855f7); margin-bottom: 16px; }
.pp-ai-inner { border-radius: 10px; background: linear-gradient(135deg, #fff7f5, #fdf4ff); padding: 16px 20px; display: flex; flex-direction: column; align-items: center; gap: 10px; text-align: center; }
.pp-ai-title { font-size: 16px; font-weight: 800; color: #111; }
