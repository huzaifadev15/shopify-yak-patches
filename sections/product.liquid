.pp-rev-verified-dot { width:8px; height:8px; border-radius:50%; background:#1C0800; flex-shrink:0; }
.pp-rev-body { display:flex; flex-direction:column; gap:6px; grid-column:2/-1; }
.pp-rev-top { display:flex; align-items:center; gap:10px; flex-wrap:wrap; }
.pp-rev-stars { display:flex; gap:1px; }
.pp-rev-star { font-size:16px; color:#f59e0b; }
.pp-rev-star.empty { color:#d1d5db; }
.pp-rev-review-title { font-size:15px; font-weight:700; color:#1C0800; }
.pp-rev-text { font-size:14px; color:#374151; line-height:1.7; }
