.crpm-backdrop { position:fixed; inset:0; background:rgba(17,17,17,0.6); backdrop-filter:blur(2px); }
.crpm-panel { position:relative; z-index:1; background:#fff; border-radius:16px; box-shadow:0 20px 60px rgba(0,0,0,0.25); width:92vw; max-width:760px; overflow:hidden; animation:crpmIn .2s ease; }
@keyframes crpmIn { from{opacity:0;transform:translateY(12px) scale(.97)} to{opacity:1;transform:none} }
.crpm-header { padding:20px 24px 14px; border-bottom:1px solid #f3f4f6; }
.crpm-title { font-size:17px; font-weight:800; color:#1C0800; margin:0 0 2px; }
.crpm-subtitle { font-size:13px; color:#6b7280; font-weight:500; }
.crpm-close { position:absolute; top:14px; right:14px; width:30px; height:30px; border-radius:8px; background:#f3f4f6; border:none; color:#374151; display:flex; align-items:center; justify-content:center; cursor:pointer; }
.crpm-close:hover { background:#e5e7eb; }
.crpm-canvas-wrap { position:relative; background:#4b5563; overflow:hidden; user-select:none; touch-action:none; }
.crpm-canvas-wrap img { display:block; width:100%; height:auto; pointer-events:none; }
.crpm-overlay-top,.crpm-overlay-bottom,.crpm-overlay-left,.crpm-overlay-right { position:absolute; background:rgba(55,65,81,0.65); pointer-events:none; }
.crpm-box { position:absolute; border:2px solid #fff; box-shadow:0 0 0 9999px rgba(55,65,81,0.65); cursor:move; }
.crpm-corner { position:absolute; width:16px; height:16px; border:3px solid #fff; }
.crpm-corner-tl { top:-2px; left:-2px; border-right:none; border-bottom:none; cursor:nw-resize; }
.crpm-corner-tr { top:-2px; right:-2px; border-left:none; border-bottom:none; cursor:ne-resize; }
.crpm-corner-bl { bottom:-2px; left:-2px; border-right:none; border-top:none; cursor:sw-resize; }
.crpm-corner-br { bottom:-2px; right:-2px; border-left:none; border-top:none; cursor:se-resize; }
.crpm-edge { position:absolute; }
.crpm-edge-t,.crpm-edge-b { left:8px; right:8px; height:12px; cursor:n-resize; }
.crpm-edge-l,.crpm-edge-r { top:8px; bottom:8px; width:12px; cursor:e-resize; }
.crpm-edge-t { top:-6px; }
.crpm-edge-b { bottom:-6px; }
.crpm-edge-l { left:-6px; }
.crpm-edge-r { right:-6px; }
.crpm-footer { display:flex; align-items:center; justify-content:flex-end; gap:12px; padding:16px 24px; border-top:1px solid #f3f4f6; }
.crpm-btn-cancel { height:40px; padding:0 20px; border-radius:9999px; background:#f3f4f6; border:none; font-size:14px; font-weight:700; color:#374151; cursor:pointer; font-family:inherit; }
.crpm-btn-cancel:hover { background:#e5e7eb; }
.crpm-btn-apply { height:40px; padding:0 24px; border-radius:9999px; background:#C4520A; border:none; font-size:14px; font-weight:700; color:#fff; cursor:pointer; font-family:inherit; }
.crpm-btn-apply:hover { background:#E64A19; }

/* AI Modal */
#aiModal { display:none; position:fixed; inset:0; z-index:9999; background:rgba(0,0,0,0.45); align-items:center; justify-content:center; }
#aiModal.open { display:flex; }
.ai-modal-panel { background:#fff; border:1px solid #e5e7eb; box-shadow:0 8px 40px rgba(0,0,0,0.12); width:92vw; max-width:1100px; border-radius:16px; height:72vh; display:grid; grid-template-rows:auto 1fr; grid-template-columns:1fr 28px; overflow:hidden; transition:grid-template-columns 0.22s; }
.ai-modal-panel.history-open { grid-template-columns:1fr 220px; }
.ai-modal-header { grid-column:1/-1; display:flex; align-items:center; justify-content:space-between; padding:14px 20px; border-bottom:1px solid #f3f4f6; background:#fff; }
.ai-modal-logo { width:32px; height:32px; border-radius:8px; display:flex; align-items:center; justify-content:center; background:linear-gradient(135deg,#C4520A,#c2410c); flex-shrink:0; }
.ai-modal-body { grid-area:2/1; display:flex; flex-direction:column; overflow:hidden; position:relative; min-width:0; }
.ai-modal-sidebar { grid-area:2/2; display:flex; flex-direction:column; border-left:1px solid #e5e7eb; background:#f8f9fa; overflow:visible; width:28px; min-width:0; transition:width 0.22s; position:relative; }
.ai-modal-panel.history-open .ai-modal-sidebar { width:220px; }
.ai-sidebar-toggle { position:absolute; top:12%; left:-13px; width:26px; height:26px; border-radius:6px 0 0 6px; background:#C4520A; border:1px solid #E64A19; border-right:none; display:flex; align-items:center; justify-content:center; cursor:pointer; z-index:20; transition:background 0.2s; }
.ai-sidebar-toggle:hover { background:#E64A19; }
.ai-sidebar-header { padding:12px 16px; border-bottom:1px solid #f3f4f6; display:flex; align-items:center; gap:8px; opacity:0; transition:opacity 0.15s; overflow:hidden; white-space:nowrap; }
.ai-modal-panel.history-open .ai-sidebar-header { opacity:1; }
.ai-sidebar-list { flex:1; overflow-y:auto; padding:8px; opacity:0; transition:opacity 0.15s; }
.ai-modal-panel.history-open .ai-sidebar-list { opacity:1; }
.ai-history-item { position:relative; border-radius:12px; overflow:hidden; border:1px solid #e5e7eb; background:#fff; margin-bottom:8px; }
.ai-history-item:hover { border-color:rgba(255,87,34,0.4); }
.ai-history-del { position:absolute; top:6px; right:6px; z-index:10; opacity:0; width:24px; height:24px; border-radius:6px; background:#ef4444; border:none; display:flex; align-items:center; justify-content:center; cursor:pointer; transition:opacity 0.15s; }
.ai-history-item:hover .ai-history-del { opacity:1; }
