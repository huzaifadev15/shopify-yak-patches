    syncRemoveButtonVisibility();
    preUpload.style.display = 'none';
    configurator.style.display = 'block';
    document.getElementById('cfgToggles').style.display = 'none';
    updatePriceDisplay();
  }

  function hasUsablePricingRows(rows) {
    if (!rows || !Array.isArray(rows) || !rows.length) return false;
    return rows.some(function(row) {
      return Object.keys(row).some(function(key) {
        if (key.indexOf('qty') !== 0 && key !== 'price') return false;
        var price = parseFloat(row[key]);
        return !isNaN(price) && price > 0;
      });
    });
  }

  function loadPricingRowsFromAPI(title) {
    return fetch(PRICING_API_URL + '?title=' + encodeURIComponent(title))
      .then(function(r) {
        if (!r.ok) return [];
        return r.json().catch(function() { return []; });
      })
      .then(function(data) { return hasUsablePricingRows(data) ? data : []; })
      .catch(function() { return []; });
  }

  function groupFlatPricingRows(rows) {
    var sizeMap = {};
    rows.forEach(function(item) {
      var s = String(item.size);
      if (!sizeMap[s]) sizeMap[s] = { size: item.size };
      sizeMap[s]['qty' + item.quantity] = item.price;
    });
    return Object.keys(sizeMap).map(function(k) { return sizeMap[k]; });
  }

  function loadPricingRowsFromAsset() {
    return fetch('{{ "pricing-updt.json" | asset_url }}')
      .then(function(r) { return r.ok ? r.json() : []; })
      .then(function(data) {
        if (!data || !Array.isArray(data) || !data.length) return [];
        return groupFlatPricingRows(data.filter(function(item) { return item.name === PRODUCT_NAME; }));
      })
      .catch(function() { return []; });
  }

  function applyLoadedPricingData(data, sourceLabel) {
    if (!hasUsablePricingRows(data)) {
      var initialPriceRow = document.getElementById('ppInitialPriceRow');
      if (initialPriceRow) initialPriceRow.style.display = 'none';
      document.getElementById('ppInitialPrice').textContent = 'Price unavailable';
      return;
    }

    pricingData = data;
    console.log('Pricing data loaded from ' + sourceLabel + ':', data);

    var initialSizeData = findSizeData(2.25);
    if (initialSizeData) {
      var priceAt100 = getPriceForQuantity(initialSizeData, 100);
      if (priceAt100 > 0) {
        var initialPriceEl = document.getElementById('ppInitialPrice');
        var initialPriceRow = document.getElementById('ppInitialPriceRow');
        if (initialPriceEl) initialPriceEl.textContent = '$' + priceAt100.toFixed(2);
        if (initialPriceRow) initialPriceRow.style.display = '';
        if (window.FineystSetProductSchemaPrice) window.FineystSetProductSchemaPrice(priceAt100);
      }
      var defaultQty = parseInt((document.getElementById('cfgQty') || {}).value) || 10;
      renderPricingTableFromAPI(initialSizeData, defaultQty);
    }

    if (configurator.style.display !== 'none') updatePriceDisplay();
  }

  // Fetch pricing data from API on page load; use embroidered pricing only if product and JSON fallbacks are missing.
  loadPricingRowsFromAPI(PRODUCT_NAME)
    .then(function(data) {
      if (hasUsablePricingRows(data)) return { rows: data, source: 'product API' };
      return loadPricingRowsFromAsset().then(function(assetData) {
        if (hasUsablePricingRows(assetData)) return { rows: assetData, source: 'pricing-updt.json fallback' };
        return loadPricingRowsFromAPI('Embroidered Patches').then(function(defaultData) {
          return { rows: defaultData, source: 'Embroidered Patches API fallback' };
        });
      });
    })
    .then(function(result) {
      applyLoadedPricingData(result.rows, result.source);
    });

  function showUploadError(msg){
    var box = document.getElementById('cfgUploadErr');
    var txt = document.getElementById('cfgUploadErrMsg');
    if(!box) return;
    if(txt) txt.textContent = msg || 'Your design could not be uploaded. Please check your connection and retry.';
    box.style.display = 'flex';
  }
  function hideUploadError(){
    var box = document.getElementById('cfgUploadErr');
    if(box) box.style.display = 'none';
  }
  window._fineyst = window._fineyst || {};
  window._fineyst.showUploadError = showUploadError;

  // The ERP upload is the one that ends up on the order ("Artwork File 1"),
  // so its outcome gates checkout/quote submission via _uploadPending/_uploadFailed.
  function startErpUpload(file){
    window.uploadedFiles = [];
    window.erpUploadedFile = null;
    window._uploadPending = true;
    window._uploadFailed = false;
    hideUploadError();
    var fd = new FormData();
    fd.append('file', file);
    window._uploadPromise = fetch('https://shopify-backend-app-omega.vercel.app/api/dashboardimage-upload', {
      method: 'POST',
      body: fd
    })
    .then(function(r){
      return r.json().catch(function(){ return null; }).then(function(data){ return { ok: r.ok, data: data }; });
    })
    .then(function(res){
      if(res.ok && res.data && res.data.success){
        var data = res.data;
        window.erpUploadedFile = data;
        window.uploadedFiles = [{
          originalName: file.name,
          fileName:     data.name,
          fileUrl:      data.fileUrl || data.url,
          fileSize:     data.size,
          fileType:     data.type
        }];
      } else {
        console.error('Dashboard upload rejected:', res.data);
        window._uploadFailed = true;
        showUploadError(res.data && res.data.error ? 'Upload failed: ' + res.data.error : null);
      }
    })
    .catch(function(err){
      console.error('Dashboard upload error:', err);
      window._uploadFailed = true;
      showUploadError(null);
    })
    .finally(function(){ window._uploadPending = false; });
    return window._uploadPromise;
  }

  document.getElementById('cfgUploadRetry').onclick = function(){
    if(!window._lastUploadFile) return;
    var b = this;
    b.disabled = true;
    b.textContent = 'Uploadingâ€¦';
    startErpUpload(window._lastUploadFile).finally(function(){
      b.disabled = false;
      b.textContent = 'Retry upload';
    });
  };

  function handleFile(file){
    if(!file) return;

    window._lastUploadFile = file;
    var formData = new FormData();
    formData.append('file', file);
    fetch('https://shopify-backend-app-omega.vercel.app/api/upload', {
      method: 'POST',
      body: formData
    })
    .catch(function(err){ console.error('Upload API error:', err); });
    startErpUpload(file);

    var isImage = file.type.startsWith('image/');
    if(isImage){
      var reader = new FileReader();
      reader.onload = function(e){
        // Probe first: formats like HEIC pass the MIME check but can't render in <img>
        var probe = new Image();
        probe.onload  = function(){ showConfigurator(e.target.result); };
        probe.onerror = function(){ showFilePlaceholder(file.name); };
        probe.src = e.target.result;
      };
      reader.readAsDataURL(file);
    } else {
      // Non-image (PDF/AI/EPS/PSD): show configurator with a file placeholder
      showFilePlaceholder(file.name);
    }
  }

  function triggerFileInput() {
    fileInput.click();
    // iOS/Android file picker can cause horizontal scroll shift â€” reset it
    var savedX = window.scrollX || window.pageXOffset || 0;
    var savedY = window.scrollY || window.pageYOffset || 0;
    setTimeout(function() { window.scrollTo(0, savedY); }, 50);
    setTimeout(function() { window.scrollTo(0, savedY); }, 200);
  }
  uploadBtn.onclick = triggerFileInput;
  cfgImgBtn.onclick = triggerFileInput;

  // Clear inline errors on input
  document.getElementById('cfgWidth').addEventListener('input', function(){
