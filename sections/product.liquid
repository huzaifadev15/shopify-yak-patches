.pp-ba-label-r { right:16px; }
.pp-ba-before { position:absolute; inset:0; overflow:hidden; }
.pp-ba-before img { width:100%; height:100%; object-fit:cover; padding:0; opacity:1; filter:none; }
.pp-ba-after { position:absolute; inset:0; overflow:hidden; }
.pp-ba-after img { width:100%; height:100%; object-fit:cover; padding:0; filter:none; }
.pp-ba-line { position:absolute; top:0; bottom:0; width:2px; background:#fff; box-shadow:0 0 0 1px rgba(17,17,17,0.08); z-index:10; pointer-events:none; }
.pp-ba-handle { position:absolute; top:50%; z-index:20; transform:translate(-50%,-50%); width:36px; height:36px; border-radius:50%; background:rgba(111,114,111,0.9); border:2px solid #fff; display:flex; align-items:center; justify-content:center; color:#fff; box-shadow:0 10px 24px rgba(17,17,17,0.18); pointer-events:none; }
@media (max-width:1024px) { .pp-ba-inner { grid-template-columns:1fr; } }
@media (max-width:640px) { .pp-ba-inner { padding:20px; border-radius:16px; } .pp-ba-img-wrap { aspect-ratio:1/1; } }
