@media (max-width: 640px) { .pp-gallery-grid { grid-template-columns:repeat(2,1fr); gap:12px; } }
/* Product Description Section */
.pp-product-desc-section { max-width:100%; margin:0 auto 64px; padding:24px; background:linear-gradient(135deg, #FDF8ED, #fff, #FDF8ED); }
.pp-product-desc-inner { background:#fffdfb; border-radius:20px; box-shadow:0 1px 4px rgba(0,0,0,0.04); display:grid; grid-template-columns:1fr 1fr; gap:48px; align-items:start; max-width:1280px; margin:0 auto; padding:32px; border:1px solid #F0D8C2; }
