  function validate() {
    var ok = true;
    var name = document.getElementById('qrmName').value.trim();
    var phone = document.getElementById('qrmPhone').value.trim();
    var email = document.getElementById('qrmEmail').value.trim();
    clearErrors();
    if (!name) {
      document.getElementById('qrmNameErr').classList.add('visible');
      document.getElementById('qrmName').classList.add('qrm-invalid');
      ok = false;
    }
    if (!phone) {
      document.getElementById('qrmPhoneErr').classList.add('visible');
      document.getElementById('qrmPhone').classList.add('qrm-invalid');
      ok = false;
    }
    if (!email || !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email)) {
      document.getElementById('qrmEmailErr').classList.add('visible');
      document.getElementById('qrmEmail').classList.add('qrm-invalid');
      ok = false;
    }
    return ok;
  }

  openBtn.addEventListener('click', function(){
    var wVal    = document.getElementById('cfgWidth').value.trim();
    var hVal    = document.getElementById('cfgHeight').value.trim();
    var bgColor = document.getElementById('cfgBgColor').value.trim();
    var border  = document.getElementById('cfgBorder').value.trim();

    if (!(window._fineyst && typeof window._fineyst.validateQtyMinimum === 'function' && window._fineyst.validateQtyMinimum())) {
      return;
    }

    // Clear previous errors
    ['cfgWidth','cfgHeight','cfgBgColor','cfgBorder'].forEach(function(id){
      document.getElementById(id).classList.remove('cfg-input-err');
    });
    ['cfgWidthErr','cfgHeightErr','cfgBgColorErr','cfgBorderErr'].forEach(function(id){
      var el = document.getElementById(id); el.textContent=''; el.classList.remove('visible');
    });

    var hasError = false;
    if (!parseFloat(wVal) || parseFloat(wVal) <= 0) {
      var ew = document.getElementById('cfgWidthErr');
      ew.textContent = 'Mandatory field!'; ew.classList.add('visible');
      document.getElementById('cfgWidth').classList.add('cfg-input-err');
      hasError = true;
    }
    if (!parseFloat(hVal) || parseFloat(hVal) <= 0) {
      var eh = document.getElementById('cfgHeightErr');
      eh.textContent = 'Mandatory field!'; eh.classList.add('visible');
      document.getElementById('cfgHeight').classList.add('cfg-input-err');
      hasError = true;
    }
    if (!bgColor) {
      var e = document.getElementById('cfgBgColorErr');
      e.textContent = 'Mandatory field!'; e.classList.add('visible');
      document.getElementById('cfgBgColor').classList.add('cfg-input-err');
      hasError = true;
    }
    if (!border) {
      var e2 = document.getElementById('cfgBorderErr');
      e2.textContent = 'Mandatory field!'; e2.classList.add('visible');
      document.getElementById('cfgBorder').classList.add('cfg-input-err');
      hasError = true;
    }
    if (hasError) {
      if (!parseFloat(wVal) || parseFloat(wVal) <= 0) document.getElementById('cfgWidth').focus();
      else if (!parseFloat(hVal) || parseFloat(hVal) <= 0) document.getElementById('cfgHeight').focus();
      else if (!bgColor) document.getElementById('cfgBgColor').focus();
      else document.getElementById('cfgBorder').focus();
      return;
    }

    openModal();
  });
  qClose.addEventListener('click', closeModal);
  qCancel.addEventListener('click', closeModal);
  qBackdrop.addEventListener('click', closeModal);

  document.getElementById('qrmName').addEventListener('input', function(){
    this.classList.remove('qrm-invalid');
    document.getElementById('qrmNameErr').classList.remove('visible');
  });
  document.getElementById('qrmPhone').addEventListener('input', function(){
    this.classList.remove('qrm-invalid');
    document.getElementById('qrmPhoneErr').classList.remove('visible');
  });
  document.getElementById('qrmEmail').addEventListener('input', function(){
    this.classList.remove('qrm-invalid');
    document.getElementById('qrmEmailErr').classList.remove('visible');
  });
  var cfgQtyInput = document.getElementById('cfgQty');
  if (cfgQtyInput) {
    cfgQtyInput.addEventListener('input', function(){
      qErrBanner.classList.remove('visible');
    });
  }
  document.addEventListener('keydown', function(e) {
    if (e.key === 'Escape' && qModal.classList.contains('qrm-open')) closeModal();
  });

  qForm.addEventListener('submit', function(e) {
    e.preventDefault();

    if(window._uploadPending){
      qErrBanner.textContent = 'Please wait â€” your file is still uploading.';
      qErrBanner.classList.add('visible');
      return;
    }

    if(window._uploadFailed){
      qErrBanner.textContent = 'Your design file could not be uploaded. Please close this form and retry the upload, or remove the file and choose "Upload by email later".';
      qErrBanner.classList.add('visible');
      if (window._fineyst && window._fineyst.showUploadError) window._fineyst.showUploadError();
      return;
    }

    // CRITICAL: Validate that pricing data has loaded before allowing submission
    var pricingData = window._fineyst && window._fineyst.pricingData;
    if (!pricingData || !Array.isArray(pricingData) || pricingData.length === 0) {
      qErrBanner.textContent = 'Pricing information is still loading. Please wait a moment and try again.';
      qErrBanner.classList.add('visible');
      console.warn('Form submitted before pricing data loaded. pricingData:', pricingData);
      return; // Block submission
    }

    if (!(window._fineyst && typeof window._fineyst.validateQtyMinimum === 'function' && window._fineyst.validateQtyMinimum())) {
      qErrBanner.textContent = 'Qty min 10.';
      qErrBanner.classList.add('visible');
      return;
    }

    if (!validate()) return;

    // Gather configurator values
    var qty      = parseInt((document.getElementById('cfgQty') || {}).value) || 1;
    var w        = parseFloat((document.getElementById('cfgWidth') || {}).value) || 0;
    var h        = parseFloat((document.getElementById('cfgHeight') || {}).value) || 0;
    var shape    = ((document.getElementById('cfgShapeLabel') || {}).textContent || '').trim();
    var backing  = ((document.getElementById('cfgBackingLabel') || {}).textContent || '').trim();
    var border   = ((document.getElementById('cfgBorder') || {}).value || '').trim();
    var bgColor  = ((document.getElementById('cfgBgColor') || {}).value || '').trim();
    var sizeStr  = w + '" x ' + h + '"';

    // Calculate unit price via shared helpers exposed on window._fineyst
    var unitPrice = 0;
    var size = Math.max(w, h);
    var currentSizeData = window._fineyst && window._fineyst.currentSizeData;
    var findSizeData = window._fineyst && window._fineyst.findSizeData;
    var getPriceForQuantity = window._fineyst && window._fineyst.getPriceForQuantity;
    var sizeData = currentSizeData || (findSizeData && findSizeData(size));

    if (sizeData && typeof getPriceForQuantity === 'function') {
      unitPrice = getPriceForQuantity(sizeData, qty);
    }

    // SAFETY CHECK: Validate that pricing calculation succeeded and we have a valid price
    if (!unitPrice || unitPrice === 0 || isNaN(unitPrice)) {
      qErrBanner.textContent = 'Cannot calculate pricing. Please verify dimensions and try again.';
      qErrBanner.classList.add('visible');
      console.error('Pricing calculation failed', { unitPrice, sizeData, qty, size });
      return; // Block submission
    }

    // Format pricing strings to match checkout flow
    var backingFee = backing === 'No Backing' ? 0 : 0.50 * qty;
    var unitPriceStr = unitPrice.toFixed(2);
    var subTotal = parseFloat((unitPrice * qty + backingFee).toFixed(2));

    // Debug logging for monitoring
    console.log('âœ“ Pricing calculated successfully:', { unitPrice, unitPriceStr, subTotal, qty, size });
    console.log('âœ“ Size data found:', sizeData);

    var attribution = (window.FineystAttribution && window.FineystAttribution.get()) || {};

    var payload = {
      status:      'pending',
      customerName: document.getElementById('qrmName').value.trim(),
      email:       document.getElementById('qrmEmail').value.trim(),
      phoneNumber: document.getElementById('qrmPhone').value.trim(),
      queryFrom:   window.location.href,
      patchType:   {{ product.title | json }},
      shape:       shape,
      backing:     backing,
      border:      border,
      thread:      '',
      colors:      bgColor,
      size:        sizeStr,
      quantity:    qty,
      unitPrice:   parseFloat((unitPrice + (backing === 'No Backing' ? 0 : 0.50)).toFixed(2)),
      subTotal:    subTotal,
      schedule:    '',
      notes:       '',
      uploadedFiles: window.uploadedFiles || [],
      firstSource:   attribution.firstSource   || null,
      firstMedium:   attribution.firstMedium   || null,
      firstCampaign: attribution.firstCampaign || null,
      lastSource:    attribution.lastSource    || null,
      lastMedium:    attribution.lastMedium    || null,
      lastCampaign:  attribution.lastCampaign  || null,
      isFine:        true
    };

    // Keep schedule and notes in dedicated fields for dashboard storage
    var schedule = document.getElementById('qrmSchedule').value;
    if (schedule) payload.schedule = schedule;

    var notes = (document.getElementById('cfgNotes').value || '').trim();
    if (notes) {
      payload.notes = notes;
    }

    qSubmit.disabled = true;
    qSubmit.textContent = 'Submittingâ€¦';
    qErrBanner.classList.remove('visible');

    function showSuccess() {
      qSuccess.classList.add('visible');
      qForm.querySelector('.qrm-footer').style.display = 'none';
      setTimeout(function() {
        closeModal();
        qForm.querySelector('.qrm-footer').style.display = '';
      }, 3000);
    }

    function resetBtn() {
      qSubmit.disabled = false;
      qSubmit.textContent = 'Submit Quote';
    }

    // Shopify contact form â€” offscreen so Turnstile initializes, submits into hidden iframe
    var sqpForm = document.querySelector('form[action*="/contact"]');
    console.log('[SQP] form found:', sqpForm ? sqpForm.action : 'NOT FOUND');
    if (sqpForm) {
      document.getElementById('sqpCustomerName').value  = payload.customerName;
      document.getElementById('sqpEmail').value          = payload.email;
      document.getElementById('sqpPhone').value          = payload.phoneNumber;
      document.getElementById('sqpPatchType').value      = payload.patchType;
      document.getElementById('sqpShape').value          = payload.shape;
      document.getElementById('sqpBacking').value        = payload.backing;
      document.getElementById('sqpBorder').value         = payload.border;
      document.getElementById('sqpColors').value         = payload.colors;
      document.getElementById('sqpSize').value           = payload.size;
      document.getElementById('sqpQty').value            = payload.quantity;
      document.getElementById('sqpUnitPrice').value      = '$' + parseFloat(payload.unitPrice).toFixed(2);
      document.getElementById('sqpSubtotal').value       = '$' + parseFloat(payload.subTotal).toFixed(2);
      document.getElementById('sqpNotes').value          = payload.notes || payload.schedule || '';
      document.getElementById('sqpFiles').value          = (payload.uploadedFiles || []).map(function(f) { return f.fileUrl || f.url || ''; }).filter(Boolean).join(', ');
      document.getElementById('sqpFirstSource').value    = payload.firstSource   || '';
      document.getElementById('sqpFirstMedium').value    = payload.firstMedium   || '';
      document.getElementById('sqpFirstCampaign').value  = payload.firstCampaign || '';
      document.getElementById('sqpLastSource').value     = payload.lastSource    || '';
      document.getElementById('sqpLastMedium').value     = payload.lastMedium    || '';
      document.getElementById('sqpLastCampaign').value   = payload.lastCampaign  || '';
      document.getElementById('sqpIsFine').value         = 'true';

      sqpForm.setAttribute('target', 'sqp_sink');

      // One-time submit listener to see if event fires and whether anything blocks it
      sqpForm.addEventListener('submit', function handler(e) {
        sqpForm.removeEventListener('submit', handler);
        console.log('[SQP] submit event fired â€” defaultPrevented:', e.defaultPrevented);
        console.log('[SQP] form fields:', Array.from(new FormData(sqpForm).entries()).map(function(p){ return p[0]; }));
      });

      // Track iframe response
      var sqpIframe = document.querySelector('iframe[name="sqp_sink"]');
      if (sqpIframe) {
        sqpIframe.onload = function() {
          console.log('[SQP] iframe loaded â€” contact form went through');
        };
      }

      // Small delay to allow Turnstile to inject its token before submit
      setTimeout(function() {
        console.log('[SQP] form fields before submit:', Array.from(new FormData(sqpForm).entries()).map(function(p){ return p[0]; }));
        console.log('[SQP] attempting submit via requestSubmit...');
        try {
          sqpForm.requestSubmit();
          console.log('[SQP] requestSubmit called on:', sqpForm.action);
        } catch(e) {
          console.warn('[SQP] requestSubmit failed, falling back to submit():', e);
          sqpForm.submit();
        }
      }, 500);
    }

    fetch('https://shopify-backend-app-omega.vercel.app/api/shopify/draft-orders/from-form', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(payload)
    })
    .then(function(r) {
      if (!r.ok) throw new Error('API returned ' + r.status);
      if (window.FineystAnalytics && typeof window.FineystAnalytics.trackQuoteRequestSubmitted === 'function') {
        window.FineystAnalytics.trackQuoteRequestSubmitted({
          form_name: 'category_quote_form',
          email: payload.email,
          phone: payload.phoneNumber,
          name: payload.customerName || null,
          product_id: {{ product.handle | json }},
          product_name: {{ product.title | json }},
          patch_type: {{ product.handle | remove: 'custom-' | remove: '-patches' | json }},
          quantity: payload.quantity,
          currency: {{ cart.currency.iso_code | default: shop.currency | default: 'USD' | json }},
          value: payload.subTotal,
          page_path: window.location.pathname,
          size: payload.size,
          shape: payload.shape,
          backing: payload.backing,
          border: payload.border,
          colors: payload.colors,
          schedule: payload.schedule || ''
        });
      }
      showSuccess();
    })
    .catch(function(err) {
      console.error('[QuoteModal] Submission error:', err);
      qErrBanner.textContent = 'Something went wrong. Please try again.';
      qErrBanner.classList.add('visible');
    })
    .finally(resetBtn);
  });
})();

(function(){
  var img    = document.getElementById('cfgPreviewImg');
  var frame  = document.getElementById('cfgImgFrame');
  var lens   = document.getElementById('cfgZoomLens');
  var result = document.getElementById('cfgZoomResult');
  if (!img || !frame || !lens || !result) return;

  var RESULT_W = 380, RESULT_H = 380;
  var lensW = 140, lensH = 140;

  function isRealImage() {
    return !!(window.uploadedImageUrl);
  }

  function hideZoom() {
    lens.style.display   = 'none';
    result.style.display = 'none';
  }

  frame.addEventListener('mouseenter', function() {
    if (!isRealImage()) return;

    var frameRect = frame.getBoundingClientRect();
    var zoom = RESULT_W / lensW;

    // pin result flush to the left of the frame, top-aligned â€” never moves again
    var resultLeft = frameRect.left - RESULT_W - 12;
    var resultTop  = frameRect.top;
    // fallback: below the frame when there is no space on the left
    if (resultLeft < 8) {
      resultLeft = frameRect.left;
      resultTop  = frameRect.bottom + 10;
    }

    result.style.left   = resultLeft + 'px';
    result.style.top    = resultTop  + 'px';
    result.style.width  = RESULT_W   + 'px';
    result.style.height = RESULT_H   + 'px';
    result.style.backgroundImage = 'url("' + img.src + '")';
    result.style.display = 'block';
    lens.style.display   = 'block';
  });

  frame.addEventListener('mouseleave', hideZoom);

  frame.addEventListener('mousemove', function(e) {
    if (!isRealImage()) { hideZoom(); return; }

    var frameRect = frame.getBoundingClientRect();
    var imgRect   = img.getBoundingClientRect();
    var zoom      = RESULT_W / lensW;

    // cursor relative to the rendered image area
    var cx = e.clientX - imgRect.left;
    var cy = e.clientY - imgRect.top;

    // clamp lens within image bounds
    var lx = Math.max(0, Math.min(cx - lensW / 2, imgRect.width  - lensW));
    var ly = Math.max(0, Math.min(cy - lensH / 2, imgRect.height - lensH));

    // move lens (positioned relative to cfgImgFrame)
    lens.style.left = ((imgRect.left - frameRect.left) + lx) + 'px';
    lens.style.top  = ((imgRect.top  - frameRect.top)  + ly) + 'px';

    // update only the zoomed region inside the fixed result box
    var bgW = imgRect.width  * zoom;
    var bgH = imgRect.height * zoom;
    result.style.backgroundSize     = bgW + 'px ' + bgH + 'px';
    result.style.backgroundPosition = (-lx * zoom) + 'px ' + (-ly * zoom) + 'px';
  });
})();

// Price Calculator Modal
(function(){
  var modal = document.getElementById('pcModal');
  var openBtn = document.getElementById('ppPriceCalcBtn');
  var closeBtn = document.getElementById('pcmClose');
  var backdrop = document.getElementById('pcmBackdrop');
  if (!modal || !openBtn) return;

  var tiers = [
    { min:10,  max:24,   label:'10-24 pcs',  key:'qty10' },
    { min:25,  max:49,   label:'25-49',       key:'qty25' },
    { min:50,  max:99,   label:'50-99',       key:'qty50' },
    { min:100, max:199,  label:'100-199',     key:'qty100' },
    { min:200, max:499,  label:'200-499',     key:'qty250' },
    { min:500, max:999,  label:'500-999',     key:'qty500' },
    { min:1000,max:null, label:'1000+',       key:'qty1000' }
  ];

  function openModal(e) {
    e.preventDefault();
    modal.classList.add('open');
    modal.setAttribute('aria-hidden', 'false');
    document.body.style.overflow = 'hidden';
    renderTable();
  }
  function closeModal() {
    modal.classList.remove('open');
    modal.setAttribute('aria-hidden', 'true');
    document.body.style.overflow = '';
  }

  openBtn.addEventListener('click', openModal);
  closeBtn.addEventListener('click', closeModal);
  backdrop.addEventListener('click', closeModal);
  document.addEventListener('keydown', function(e){ if (e.key === 'Escape') closeModal(); });

  function makeStep(minusId, plusId, inputId, step, min, max) {
    var minus = document.getElementById(minusId);
    var plus  = document.getElementById(plusId);
    var input = document.getElementById(inputId);
    minus.addEventListener('click', function(){
      var v = parseFloat(input.value) || min;
      input.value = Math.max(min, parseFloat((v - step).toFixed(2)));
      renderTable();
    });
    plus.addEventListener('click', function(){
      var v = parseFloat(input.value) || min;
      input.value = Math.min(max, parseFloat((v + step).toFixed(2)));
      renderTable();
    });
    input.addEventListener('change', renderTable);
    var isQty = inputId === 'pcmQty';
    input.addEventListener('input', function(){
      if (isQty) {
        input.value = input.value.replace(/[^0-9]/g, '').slice(0, 10);
      } else {
        input.value = input.value.replace(/[^0-9.]/g, '').replace(/(\..*)\./g, '$1');
        var parts = input.value.split('.');
        if (parts[0].length > 3) { parts[0] = parts[0].slice(0, 3); input.value = parts.join('.'); }
      }
      renderTable();
    });
  }

  makeStep('pcmWMinus','pcmWPlus','pcmWidth',0.25,0.5,20);
  makeStep('pcmHMinus','pcmHPlus','pcmHeight',0.25,0.5,20);
  makeStep('pcmQtyMinus','pcmQtyPlus','pcmQty',10,10,10000);

  function renderTable() {
    var findSizeData = window._fineyst && window._fineyst.findSizeData;
    var getPriceForQuantity = window._fineyst && window._fineyst.getPriceForQuantity;
    var tbody = document.getElementById('pcmTableBody');
    if (!findSizeData || !getPriceForQuantity) {
      tbody.innerHTML = '<tr><td colspan="3" class="pcm-loading">Prices still loadingâ€¦</td></tr>';
      return;
    }
    var w = parseFloat(document.getElementById('pcmWidth').value) || 0;
    var h = parseFloat(document.getElementById('pcmHeight').value) || 0;
    var qty = parseInt(document.getElementById('pcmQty').value) || 100;
    var size = Math.max(w, h);
    var sizeData = findSizeData(size);
    if (!sizeData) {
      tbody.innerHTML = '<tr><td colspan="3" class="pcm-loading">No pricing found for this size.</td></tr>';
      return;
    }
    var basePrice = getPriceForQuantity(sizeData, 10);
    if (!basePrice) {
      tbody.innerHTML = '<tr><td colspan="3" class="pcm-loading">Pricing unavailable.</td></tr>';
      return;
    }
    var html = '';
    tiers.forEach(function(tier) {
      var price = getPriceForQuantity(sizeData, tier.min);
      if (!price) return;
      var disc = Math.round(((basePrice - price) / basePrice) * 100);
      var active = qty >= tier.min && (tier.max === null || qty <= tier.max);
      html += '<tr' + (active ? ' class="pcm-row-active"' : '') + '>' +
        '<td>' + tier.label + '</td>' +
        '<td>$' + price.toFixed(2) + ' ea</td>' +
        '<td class="pcm-discount">' + (disc > 0 ? disc + '% off' : 'â€”') + '</td>' +
        '</tr>';
    });
    tbody.innerHTML = html || '<tr><td colspan="3" class="pcm-loading">No pricing available.</td></tr>';
  }

  document.getElementById('pcmGetQuote').addEventListener('click', function(){
    closeModal();
    var btn = document.getElementById('qrmOpen') || document.querySelector('[data-qrm-open]');
    if (btn) btn.click();
  });
})();
</script>

