                        {%- endif -%}
                      {%- endfor -%}
                    </li>
                  {%- else -%}
                    {%- if feature_answer_in_list -%}</ul>{%- assign feature_answer_in_list = false -%}{%- endif -%}
                    {%- assign feature_answer_chunks = feature_answer_line | split: '{' -%}
                    <p>
                      {%- for feature_answer_chunk in feature_answer_chunks -%}
                        {%- if forloop.first -%}
                          {{- feature_answer_chunk | escape -}}
                        {%- else -%}
                          {%- assign feature_answer_parts = feature_answer_chunk | split: '}' -%}
                          <strong>{{ feature_answer_parts[0] | escape }}</strong>{% if feature_answer_parts.size > 1 %}{{ feature_answer_parts[1] | escape }}{% endif %}
                        {%- endif -%}
                      {%- endfor -%}
                    </p>
                  {%- endif -%}
                {%- endfor -%}
                {%- if feature_answer_in_list -%}</ul>{%- endif -%}
