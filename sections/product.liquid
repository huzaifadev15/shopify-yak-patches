.pp-price-calc-link:hover { color:#e04a1c; }
.pp-feat-item { position:relative; display:block; border-top:1px solid #e5e7eb; }
.pp-feat-item:last-child { border-bottom:1px solid #e5e7eb; }
.pp-feat-toggle { position:absolute; opacity:0; pointer-events:none; }
.pp-feat-question { width:100%; display:flex; align-items:center; justify-content:space-between; background:none; border:none; cursor:pointer; padding:18px 0; font-size:16px; font-weight:700; color:#1C0800; text-align:left; font-family:inherit; gap:12px; }
.pp-feat-icon { font-size:20px; color:#1C0800; flex-shrink:0; line-height:1; }
.pp-feat-icon--open { display:none; }
.pp-feat-toggle:checked + .pp-feat-question .pp-feat-icon--closed { display:none; }
