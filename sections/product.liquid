.ai-hint-patch { font-weight:800; background:linear-gradient(135deg,#C4520A,#ec4899,#a855f7); -webkit-background-clip:text; -webkit-text-fill-color:transparent; }
.ai-hint-subject { font-weight:800; color:#1C0800; }
.ai-underline-wrap { position:relative; display:inline-block; padding-bottom:18px; }
