    fetch('/cart/add.js', {
      method: 'POST',
      headers: {
        'Content-Type': 'application/json',
        'Accept': 'application/json'
      },
      body: JSON.stringify(payload)
    })
    .then(function(r) {
      return r.json().then(function(data) {
        return { ok: r.ok, status: r.status, data: data };
      });
    })
    .then(function(result) {
      if (!result.ok) {
        throw new Error((result.data && (result.data.description || result.data.message)) || 'Could not add this product to cart. Please try again.');
      }
      window.location.href = '/cart';
    })
    .catch(function(err) {
      console.error('Cart add error:', err);
      alert(err.message || 'Could not add this product to cart. Please try again.');
