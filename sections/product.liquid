  var PRICING_API_URL = 'https://shopify-backend-app-omega.vercel.app/api/pricing/by-page-title';

  // Find pricing data for specific size
  function findSizeData(sizeInches) {
    if (!pricingData || !Array.isArray(pricingData)) return null;

    var nearest = null;
    var nearestDiff = Infinity;

    pricingData.forEach(function(sizeObj) {
      var size = parseFloat(sizeObj.size);
      if (isNaN(size)) return;
      var diff = Math.abs(size - sizeInches);
      if (diff < nearestDiff) {
        nearestDiff = diff;
        nearest = sizeObj;
      }
    });

    return nearest;
  }
  
  // Get price for specific quantity from size data
  function getPriceForQuantity(sizeData, qty) {
    if (!sizeData) return 0;
    
    // Define quantity breakpoints in order
    var qtyKeys = [
      { min: 10000, key: 'qty10000' },
      { min: 5000, key: 'qty5000' },
      { min: 2500, key: 'qty2500' },
      { min: 2000, key: 'qty2000' },
      { min: 1500, key: 'qty1500' },
      { min: 1000, key: 'qty1000' },
      { min: 750, key: 'qty750' },
      { min: 700, key: 'qty700' },
      { min: 500, key: 'qty500' },
      { min: 300, key: 'qty300' },
      { min: 250, key: 'qty250' },
      { min: 200, key: 'qty200' },
      { min: 100, key: 'qty100' },
      { min: 75, key: 'qty75' },
      { min: 50, key: 'qty50' },
      { min: 25, key: 'qty25' },
      { min: 20, key: 'qty20' },
      { min: 10, key: 'qty10' },
      { min: 5, key: 'qty5' }
    ];
    
    // Cap at 1000 â€” quantities above 1000 use the 1000-tier price
    var effectiveQty = Math.min(qty, 1000);

    // Find the appropriate price tier
    for (var i = 0; i < qtyKeys.length; i++) {
      if (effectiveQty >= qtyKeys[i].min) {
        var price = parseFloat(sizeData[qtyKeys[i].key]);
        if (!isNaN(price) && price > 0) {
          return price;
        }
      }
    }
    
    // Fallback: use the highest-priced available tier (lowest quantity tier with a value)
    for (var j = qtyKeys.length - 1; j >= 0; j--) {
      var fbPrice = parseFloat(sizeData[qtyKeys[j].key]);
      if (!isNaN(fbPrice) && fbPrice > 0) {
        return fbPrice;
      }
    }
    return 0;
  }

  // Expose pricing helpers globally for other IIFEs
  window._fineyst.findSizeData = findSizeData;
  window._fineyst.getPriceForQuantity = getPriceForQuantity;
  window._fineyst.productId = PRODUCT_ID;
  window._fineyst.variantId = CART_VARIANT_ID;

  // Render pricing table from API data
  function renderPricingTableFromAPI(sizeData, qty) {
    if (!sizeData) return false;
    
    var tbody = document.getElementById('cfgPriceTableBody');
    var html = '';
    
    // Define tier structure for display with their actual API keys
    var tiers = [
      { min: 10, max: 24, label: '10-24 pcs', qtyKey: 'qty10' },
      { min: 25, max: 49, label: '25-49', qtyKey: 'qty25' },
      { min: 50, max: 99, label: '50-99', qtyKey: 'qty50' },
      { min: 100, max: 199, label: '100-199', qtyKey: 'qty100' },
      { min: 200, max: 499, label: '200-499', qtyKey: 'qty250' },
      { min: 500, max: 999, label: '500-999', qtyKey: 'qty500' },
      { min: 1000, max: null, label: '1000+', qtyKey: 'qty1000' }
    ];
    
    var basePrice = getPriceForQuantity(sizeData, 10);
    if (!basePrice || basePrice === 0) return false;
    
    tiers.forEach(function(tier) {
      // Get the actual price for this tier using the quantity-based lookup
      var price = getPriceForQuantity(sizeData, tier.min);
      
      var discountPercent = Math.round(((basePrice - price) / basePrice) * 100);
      var active = qty >= tier.min && (tier.max === null || qty <= tier.max);
      
      html += '<tr' + (active ? ' class="cfg-row-active"' : '') + ' data-cfg-tier-qty="' + tier.min + '" tabindex="0" role="button">' +
        '<td>' + tier.label + '</td>' +
        '<td>$' + price.toFixed(2) + ' ea</td>' +
        '<td class="cfg-discount">' + (discountPercent > 0 ? discountPercent + '% off' : '') + '</td>' +
        '</tr>';
    });
    
    tbody.innerHTML = html;
    return true;
  }



  var BACKING_SURCHARGE = 0.50;

  /*
    var patchSize = 0;
  if (false) {
    if (w > 0 && h > 0) {
      patchSize = Math.ceil((((w + h) / 2) * 2)) / 2;
    }
  function getBackingSurcharge(){
  }
    var backing = (document.getElementById('cfgBackingLabel') || {}).textContent || '';
  if (false) {
    if (cfgPatchSizeValue) {
      cfgPatchSizeValue.textContent = patchSize > 0 ? patchSize.toFixed(1).replace(/\.0$/, '') + '"' : '?';
  }
    }
  */
  function getBackingSurcharge(){
    var backing = (document.getElementById('cfgBackingLabel') || {}).textContent || '';
    return backing === 'No Backing' ? 0 : BACKING_SURCHARGE;
  }

  /*
    return backing === 'No Backing' ? 0 : BACKING_SURCHARGE;
  }

  */
  function updatePriceDisplay(){
    var w = parseFloat(document.getElementById('cfgWidth').value) || 0;
    var h = parseFloat(document.getElementById('cfgHeight').value) || 0;
    var patchSize = 0;
    if (w > 0 && h > 0) {
      patchSize = Math.ceil((((w + h) / 2) * 2)) / 2;
    }
    var q = parseInt(document.getElementById('cfgQty').value) || 10;
    if(q < 10) q = 10;
    var size = Math.max(w, h);

    // Update labels immediately
    if (cfgPatchSizeValue) {
      cfgPatchSizeValue.textContent = patchSize > 0 ? patchSize.toFixed(1).replace(/\.0$/, '') + '"' : '-';
    }
    cfgWidthLabel.textContent = w.toFixed(2) + '"';
    cfgRulerV.textContent = h.toFixed(2) + '"';
    document.getElementById('cfgPriceSub').textContent = '{{ product.title }} â€¢ ' + w.toFixed(2) + 'Ã—' + h.toFixed(2) + '" â€¢ ' + q + ' pcs';

    // Find size data and update pricing
    if (pricingData) {
      currentSizeData = findSizeData(size);
      if (currentSizeData) {
        var basePrice = getPriceForQuantity(currentSizeData, q);
        var backingTotal = getBackingSurcharge() * q;
        var total = (basePrice * q + backingTotal).toFixed(2);

        document.getElementById('cfgPricePerPatch').textContent = basePrice > 0 ? '$' + basePrice.toFixed(2) + ' per patch' : 'â€”';
        document.getElementById('cfgPriceTotal').textContent = basePrice > 0 ? 'Total: $' + total : 'â€”';

        // Update pricing table
        renderPricingTableFromAPI(currentSizeData, q);
      } else {
        document.getElementById('cfgPricePerPatch').textContent = 'Size not available';
        document.getElementById('cfgPriceTotal').textContent = '';
      }
    } else {
      document.getElementById('cfgPricePerPatch').textContent = 'Loading...';
      document.getElementById('cfgPriceTotal').textContent = '';
    }
  }

  var uploadedImageUrl = null; // Track uploaded image

  function showConfigurator(dataUrl){
    cfgImg.src = dataUrl;
    window.uploadedImageUrl = dataUrl; // Store globally
    window.originalImageUrl = dataUrl; // Preserve original for toggle restore
    window.removedBgImageUrl = null;   // Clear bg-removal cache for new image
    syncRemoveButtonVisibility();
