.pp-thumb img { width: 100%; height: 100%; object-fit: cover; }
.pp-breadcrumb { display: flex; align-items: center; gap: 4px; font-size: 13px; color: #6b7280; margin-bottom: 16px; flex-wrap: wrap; }
.pp-breadcrumb a { color: #6b7280; text-decoration: none; }
.pp-breadcrumb a:hover { color: #111; }
