  // Steppers
  function makeStep(minusId, plusId, inputId, step, min, max, isInt){
    document.getElementById(minusId).onclick = function(){
      var v = parseFloat(document.getElementById(inputId).value) || min;
      v = Math.max(min, parseFloat((v - step).toFixed(2)));
      document.getElementById(inputId).value = isInt ? Math.round(v) : v.toFixed(2);
      if (inputId === 'cfgQty') clearQtyValidation();
      updatePriceDisplay();
    };
    document.getElementById(plusId).onclick = function(){
      var v = parseFloat(document.getElementById(inputId).value) || min;
      v = Math.min(max, parseFloat((v + step).toFixed(2)));
      document.getElementById(inputId).value = isInt ? Math.round(v) : v.toFixed(2);
      if (inputId === 'cfgQty') clearQtyValidation();
      updatePriceDisplay();
    };
    document.getElementById(inputId).oninput = function(){
      var el = this;
      if (isInt) {
        el.value = el.value.replace(/[^0-9]/g, '').slice(0, 10);
      } else {
        el.value = el.value.replace(/[^0-9.]/g, '').replace(/(\..*)\./g, '$1');
        var parts = el.value.split('.');
        if (parts[0].length > 3) { parts[0] = parts[0].slice(0, 3); el.value = parts.join('.'); }
      }
      if (inputId === 'cfgQty') clearQtyValidation();
      updatePriceDisplay();
    };
  }
