      </button>
      <img src="" alt="" class="pp-gallery-modal-img" id="ppGalleryModalImg">
    </div>
  </div>

  {%- if has_selected_patch_type -%}
  <!-- Reviews Section -->
  {%- assign product_reviews = product.metafields.custom.reviews.value -%}
  {%- if product_reviews != blank -%}
  {%- assign total_reviews = product_reviews.size -%}
  {%- assign sum_ratings = 0 -%}
  {%- assign count_5 = 0 -%}{%- assign count_4 = 0 -%}{%- assign count_3 = 0 -%}{%- assign count_2 = 0 -%}{%- assign count_1 = 0 -%}
  {%- for review in product_reviews -%}
    {%- assign r = review.rating.value | plus: 0 -%}
    {%- assign sum_ratings = sum_ratings | plus: r -%}
    {%- if r == 5 -%}{%- assign count_5 = count_5 | plus: 1 -%}{%- endif -%}
    {%- if r == 4 -%}{%- assign count_4 = count_4 | plus: 1 -%}{%- endif -%}
    {%- if r == 3 -%}{%- assign count_3 = count_3 | plus: 1 -%}{%- endif -%}
    {%- if r == 2 -%}{%- assign count_2 = count_2 | plus: 1 -%}{%- endif -%}
    {%- if r == 1 -%}{%- assign count_1 = count_1 | plus: 1 -%}{%- endif -%}
  {%- endfor -%}
  {%- assign avg_whole = sum_ratings | divided_by: total_reviews -%}
  {%- assign avg_dec = sum_ratings | modulo: total_reviews | times: 10 | divided_by: total_reviews -%}
  {%- assign pct_5 = count_5 | times: 100 | divided_by: total_reviews -%}
  {%- assign pct_4 = count_4 | times: 100 | divided_by: total_reviews -%}
  {%- assign pct_3 = count_3 | times: 100 | divided_by: total_reviews -%}
  {%- assign pct_2 = count_2 | times: 100 | divided_by: total_reviews -%}
  {%- assign pct_1 = count_1 | times: 100 | divided_by: total_reviews -%}

  <div class="pp-rev-section">
    <h2 class="pp-rev-title">Customer Reviews</h2>

    <!-- Summary -->
    <div class="pp-rev-summary">
      <div class="pp-rev-avg-col">
        <span class="pp-rev-avg-num">{{ avg_whole }}.{{ avg_dec }}</span>
        <div class="pp-rev-avg-right">
          <div class="pp-rev-avg-stars">
            {%- for i in (1..5) -%}
              <span class="pp-rev-avg-star{% if i > avg_whole %} empty{% endif %}">&#9733;</span>
            {%- endfor -%}
          </div>
          <span class="pp-rev-avg-sub">Based on {{ total_reviews }} review{% if total_reviews != 1 %}s{% endif %}</span>
        </div>
      </div>
      <div class="pp-rev-breakdown">
        <div class="pp-rev-bar-row">
          <span class="pp-rev-bar-label">5</span><span class="pp-rev-bar-star">&#9733;</span>
          <div class="pp-rev-bar-track"><div class="pp-rev-bar-fill" style="width:{{ pct_5 }}%"></div></div>
          <span class="pp-rev-bar-count">{{ count_5 }}</span>
        </div>
        <div class="pp-rev-bar-row">
          <span class="pp-rev-bar-label">4</span><span class="pp-rev-bar-star">&#9733;</span>
          <div class="pp-rev-bar-track"><div class="pp-rev-bar-fill" style="width:{{ pct_4 }}%"></div></div>
          <span class="pp-rev-bar-count">{{ count_4 }}</span>
        </div>
        <div class="pp-rev-bar-row">
          <span class="pp-rev-bar-label">3</span><span class="pp-rev-bar-star">&#9733;</span>
          <div class="pp-rev-bar-track"><div class="pp-rev-bar-fill" style="width:{{ pct_3 }}%"></div></div>
          <span class="pp-rev-bar-count">{{ count_3 }}</span>
        </div>
        <div class="pp-rev-bar-row">
          <span class="pp-rev-bar-label">2</span><span class="pp-rev-bar-star">&#9733;</span>
          <div class="pp-rev-bar-track"><div class="pp-rev-bar-fill" style="width:{{ pct_2 }}%"></div></div>
          <span class="pp-rev-bar-count">{{ count_2 }}</span>
        </div>
        <div class="pp-rev-bar-row">
          <span class="pp-rev-bar-label">1</span><span class="pp-rev-bar-star">&#9733;</span>
          <div class="pp-rev-bar-track"><div class="pp-rev-bar-fill" style="width:{{ pct_1 }}%"></div></div>
          <span class="pp-rev-bar-count">{{ count_1 }}</span>
        </div>
      </div>
    </div>

    <!-- Reviews with media -->
    {%- assign media_reviews = product_reviews | where: 'image' -%}
    {%- if media_reviews.size > 0 -%}
    <div class="pp-rev-media-wrap">
      <div class="pp-rev-media-header">
        <span class="pp-rev-media-title">Reviews with media</span>
        <div class="pp-rev-media-nav">
          <button class="pp-rev-media-btn" id="ppRevMediaPrev" type="button" aria-label="Previous">
            <svg width="14" height="14" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5"><path d="m15 18-6-6 6-6"/></svg>
          </button>
          <button class="pp-rev-media-btn" id="ppRevMediaNext" type="button" aria-label="Next">
            <svg width="14" height="14" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5"><path d="m9 18 6-6-6-6"/></svg>
          </button>
        </div>
      </div>
      <div class="pp-rev-media-strip" id="ppRevMediaStrip">
        {%- for review in product_reviews -%}
          {%- if review.image.value -%}
          <div class="pp-rev-media-thumb">
            <img src="{{ review.image.value | image_url: width: 280 }}" alt="Review photo" loading="lazy">
          </div>
          {%- endif -%}
        {%- endfor -%}
      </div>
    </div>
    {%- endif -%}

    <!-- Filters -->
    <div class="pp-rev-filters">
      <div class="pp-rev-search-wrap">
        <input type="search" class="pp-rev-search" id="ppRevSearch" placeholder="Search reviews">
        <svg class="pp-rev-search-icon" width="15" height="15" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg>
      </div>
      <button class="pp-rev-filter-btn active" data-rating="all" id="ppRevRatingFilter" type="button">Rating</button>
      <label class="pp-rev-media-toggle">
        <button type="button" class="pp-rev-toggle-switch" id="ppRevMediaToggle" aria-checked="false"><span class="pp-rev-toggle-thumb"></span></button>
        With media
      </label>
    </div>
    <div class="pp-rev-sort-row">
      Sort by: <select class="pp-rev-sort-select" id="ppRevSort"><option value="recent">Most recent</option><option value="highest">Highest rated</option><option value="lowest">Lowest rated</option></select>
    </div>

    <!-- Review list -->
    <div class="pp-rev-list" id="ppRevList">
      {%- for review in product_reviews -%}
        {%- assign rev_name = review.reviewer_name.value -%}
        {%- assign rev_parts = rev_name | split: ' ' -%}
        {%- assign rev_init = rev_parts[0] | slice: 0 | upcase -%}
        {%- if rev_parts[1] -%}{%- assign rev_init2 = rev_parts[1] | slice: 0 | upcase -%}{%- assign rev_init = rev_init | append: rev_init2 -%}{%- endif -%}
        {%- assign rev_rating = review.rating.value | plus: 0 -%}
        <div class="pp-rev-item" data-rating="{{ rev_rating }}" data-has-image="{% if review.image.value %}true{% else %}false{% endif %}" data-date="{{ review.date.value }}" data-text="{{ rev_name | downcase }} {{ review.review_title.value | downcase }} {{ review.review_text.value | downcase }}">
          <div class="pp-rev-avatar">
            {%- if review.image.value -%}
              <img src="{{ review.image.value | image_url: width: 88 }}" alt="{{ rev_name }}">
            {%- else -%}
              {{ rev_init }}
            {%- endif -%}
          </div>
          <div class="pp-rev-left">
            <span class="pp-rev-name">{{ rev_name }} <span class="pp-rev-location">{{ review.location.value }}</span></span>
            {%- if review.verified_buyer.value -%}
            <span class="pp-rev-verified"><span class="pp-rev-verified-dot"></span>Verified Buyer</span>
            {%- endif -%}
          </div>
          <div class="pp-rev-date">{{ review.date.value | date: "%m/%d/%y" }}</div>
          <div class="pp-rev-body">
            <div class="pp-rev-top">
              <div class="pp-rev-stars">
                {%- for i in (1..5) -%}<span class="pp-rev-star{% if i > rev_rating %} empty{% endif %}">&#9733;</span>{%- endfor -%}
              </div>
              <span class="pp-rev-review-title">{{ review.review_title.value }}</span>
            </div>
            <p class="pp-rev-text">{{ review.review_text.value }}</p>
            {%- if review.image.value -%}
            <div class="pp-rev-rev-image">
              <img src="{{ review.image.value | image_url: width: 160 }}" alt="Review image">
            </div>
            {%- endif -%}
            <div class="pp-rev-helpful">
              Was this review helpful?
              <button class="pp-rev-helpful-btn" type="button">
                <svg width="14" height="14" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path d="M14 9V5a3 3 0 0 0-3-3l-4 9v11h11.28a2 2 0 0 0 2-1.7l1.38-9a2 2 0 0 0-2-2.3H14z"/><path d="M7 22H4a2 2 0 0 1-2-2v-7a2 2 0 0 1 2-2h3"/></svg>
                0
              </button>
              <button class="pp-rev-helpful-btn" type="button">
                <svg width="14" height="14" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path d="M10 15v4a3 3 0 0 0 3 3l4-9V2H5.72a2 2 0 0 0-2 1.7l-1.38 9a2 2 0 0 0 2 2.3H10z"/><path d="M17 2h2.67A2.31 2.31 0 0 1 22 4v7a2.31 2.31 0 0 1-2.33 2H17"/></svg>
                0
              </button>
            </div>
          </div>
        </div>
      {%- endfor -%}
    </div>
  </div>
  {%- endif -%}
  {%- endif -%}

</div>

<!-- Price Calculator Modal -->
<style>
#pcModal { display:none; position:fixed; inset:0; z-index:9000; }
#pcModal.open { display:flex; align-items:center; justify-content:center; }
.pcm-backdrop { position:absolute; inset:0; background:rgba(0,0,0,0.5); }
.pcm-panel, .pcm-panel * { box-sizing:border-box; }
.pcm-panel { position:relative; background:#fff; border-radius:16px; padding:32px; width:calc(100% - 48px); max-width:480px; z-index:1; box-shadow:0 20px 60px rgba(0,0,0,0.2); box-sizing:border-box; overflow:hidden; max-height:calc(100vh - 48px); overflow-y:auto; }
.pcm-header { display:flex; align-items:center; justify-content:space-between; margin-bottom:24px; }
.pcm-title { font-size:20px; font-weight:800; color:#3D1F0A; }
.pcm-close { background:none; border:none; cursor:pointer; color:#6b7280; padding:4px; line-height:1; }
.pcm-close:hover { color:#3D1F0A; }
.pcm-row { display:grid; grid-template-columns:1fr 1fr; gap:16px; margin-bottom:16px; min-width:0; }
.pcm-field { display:flex; flex-direction:column; gap:6px; min-width:0; }
.pcm-label { font-size:13px; font-weight:600; color:#374151; }
.pcm-stepper { display:flex; align-items:center; border:1.5px solid #e5e7eb; border-radius:8px; overflow:hidden; min-width:0; width:100%; }
.pcm-stepper button { width:36px; height:36px; background:#f9fafb; border:none; cursor:pointer; font-size:18px; color:#374151; flex-shrink:0; }
.pcm-stepper button:hover { background:#f3f4f6; }
.pcm-stepper input { flex:1; border:none; text-align:center; font-size:14px; font-weight:600; color:#3D1F0A; outline:none; min-width:0; font-family:inherit; height:36px; }
.pcm-table { width:100%; border-collapse:collapse; margin-top:20px; font-size:14px; table-layout:fixed; }
.pcm-table th { text-align:left; padding:10px 12px; background:#f9fafb; color:#6b7280; font-weight:600; font-size:13px; border-bottom:1px solid #e5e7eb; }
.pcm-table td { padding:10px 12px; border-bottom:1px solid #f3f4f6; color:#3D1F0A; }
.pcm-table th, .pcm-table td { overflow-wrap:anywhere; }
.pcm-table tr.pcm-row-active td { background:#fff7f5; font-weight:700; color:#7C4A1E; }
.pcm-table .pcm-discount { color:#16a34a; font-weight:600; }
.pcm-loading { text-align:center; padding:24px; color:#9ca3af; font-size:14px; }
.pcm-get-quote { display:block; width:100%; margin-top:20px; padding:14px; background:#7C4A1E; color:#fff; border:none; border-radius:10px; font-size:15px; font-weight:700; cursor:pointer; font-family:inherit; }
.pcm-get-quote:hover { background:#e04a1c; }
@media (max-width: 640px) {
  .pcm-panel {
    width: calc(100% - 24px);
    padding: 20px 16px;
    max-height: calc(100vh - 24px);
    border-radius: 14px;
  }
  .pcm-row {
    grid-template-columns: 1fr;
    gap: 12px;
  }
  .pcm-header {
    margin-bottom: 18px;
  }
  .pcm-title {
    font-size: 18px;
  }
  .pcm-table {
    font-size: 13px;
  }
  .pcm-table th,
  .pcm-table td {
    padding: 9px 8px;
  }
  .pcm-stepper button {
    width: 34px;
  }
  .pcm-get-quote {
    margin-top: 16px;
    padding: 13px;
  }
}
</style>
<div id="pcModal" aria-hidden="true">
  <div class="pcm-backdrop" id="pcmBackdrop"></div>
  <div class="pcm-panel" role="dialog" aria-modal="true" aria-labelledby="pcmTitle">
    <div class="pcm-header">
      <h2 class="pcm-title" id="pcmTitle">Price Calculator</h2>
      <button class="pcm-close" id="pcmClose" aria-label="Close">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
      </button>
    </div>
    <div class="pcm-row">
      <div class="pcm-field">
        <label class="pcm-label">Width (inches)</label>
        <div class="pcm-stepper">
          <button type="button" id="pcmWMinus">−</button>
          <input type="text" id="pcmWidth" placeholder="0.00" inputmode="decimal" autocomplete="off">
          <button type="button" id="pcmWPlus">+</button>
        </div>
      </div>
      <div class="pcm-field">
        <label class="pcm-label">Height (inches)</label>
        <div class="pcm-stepper">
          <button type="button" id="pcmHMinus">−</button>
          <input type="text" id="pcmHeight" placeholder="0.00" inputmode="decimal" autocomplete="off">
          <button type="button" id="pcmHPlus">+</button>
        </div>
      </div>
    </div>
    <div class="pcm-field" style="margin-bottom:4px;">
      <label class="pcm-label">Quantity</label>
      <div class="pcm-stepper">
        <button type="button" id="pcmQtyMinus">−</button>
        <input type="text" id="pcmQty" value="100" inputmode="numeric" autocomplete="off">
        <button type="button" id="pcmQtyPlus">+</button>
      </div>
    </div>
    <table class="pcm-table">
      <thead><tr><th>Quantity</th><th>Price Each</th><th>Discount</th></tr></thead>
      <tbody id="pcmTableBody"><tr><td colspan="3" class="pcm-loading">Loading prices…</td></tr></tbody>
    </table>
    <button class="pcm-get-quote" id="pcmGetQuote">Get a Quote</button>
  </div>
</div>

<!-- Quote Request Modal -->
<div id="quoteRequestModal" aria-hidden="true">
  <div class="qrm-backdrop" id="qrmBackdrop"></div>
  <div class="qrm-panel" role="dialog" aria-modal="true" aria-labelledby="qrmTitle">
    <div class="qrm-header">
      <h2 class="qrm-title" id="qrmTitle">Submit Quote Request</h2>
      <button type="button" class="qrm-close" id="qrmClose" aria-label="Close">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
      </button>
    </div>
    <form id="quoteRequestForm" novalidate>
      <div class="qrm-body">
        <div class="qrm-field">
          <label class="qrm-label" for="qrmName">Customer Name <span class="qrm-req">*</span> <span class="qrm-field-error" id="qrmNameErr">Mandatory field!</span></label>
          <input type="text" id="qrmName" class="qrm-input" placeholder="Enter your name" required>
        </div>
        <div class="qrm-field">
          <label class="qrm-label" for="qrmPhone">Phone Number <span class="qrm-req">*</span> <span class="qrm-field-error" id="qrmPhoneErr">Mandatory field!</span></label>
          <input type="tel" id="qrmPhone" class="qrm-input" placeholder="Enter your phone number" required>
        </div>
        <div class="qrm-field">
          <label class="qrm-label" for="qrmEmail">Email <span class="qrm-req">*</span> <span class="qrm-field-error" id="qrmEmailErr">Mandatory field!</span></label>
          <input type="email" id="qrmEmail" class="qrm-input" placeholder="Enter your email" required>
        </div>
        <div class="qrm-field">
          <label class="qrm-label" for="qrmSchedule">Schedule Call <span class="qrm-opt">(optional)</span></label>
          <select id="qrmSchedule" class="qrm-input qrm-select">
            <option value="">Select a time slot</option>
            <option value="Morning (9am - 12pm)">Morning (9am - 12pm)</option>
            <option value="Afternoon (12pm - 3pm)">Afternoon (12pm - 3pm)</option>
            <option value="Late Afternoon (3pm - 6pm)">Late Afternoon (3pm - 6pm)</option>
            <option value="Evening (6pm - 8pm)">Evening (6pm - 8pm)</option>
          </select>
        </div>
        <div class="qrm-success" id="qrmSuccess">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><polyline points="20 6 9 17 4 12"/></svg>
          Your quote request has been submitted! We&#39;ll be in touch shortly.
        </div>
        <div class="qrm-err-banner" id="qrmErrBanner">Something went wrong. Please try again.</div>
      </div>
      <div class="qrm-footer">
        <button type="button" class="qrm-btn-cancel" id="qrmCancel">Cancel</button>
        <button type="submit" class="qrm-btn-submit" id="qrmSubmit">Submit Quote</button>
      </div>
    </form>
  </div>
</div>



