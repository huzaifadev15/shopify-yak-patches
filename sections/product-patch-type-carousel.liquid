  document.getElementById('cfgCheckout').onclick = function(){
    var btn = document.getElementById('cfgCheckout');
    var payload = toShopifyCartPayload();
    if (!payload) return;

    btn.disabled = true;
    btn.textContent = 'Adding to cart...';

    fetch('/cart/add.js', {
      method: 'POST',
      headers: {
        'Content-Type': 'application/json',
        'Accept': 'application/json'
      },
      body: JSON.stringify(payload)
    })
    .then(function(r) {
      return r.json().then(function(data) {
        return { ok: r.ok, status: r.status, data: data };
      });
    })
    .then(function(result) {
      if (!result.ok) {
        throw new Error((result.data && (result.data.description || result.data.message)) || 'Could not add this product to cart. Please try again.');
      }
      window.location.href = '/cart';
    })
    .catch(function(err) {
      console.error('Cart add error:', err);
      alert(err.message || 'Could not add this product to cart. Please try again.');
    })
    .finally(function() {
      btn.disabled = false;
      btn.textContent = 'Proceed to Checkout';
    });
  };

  // Add to Cart
  var VARIANT_ID = {{ product.selected_or_first_available_variant.id | default: 'null' }};

  window.fineystDoAddToCart = function doAddToCart(cartBtn, cartSpinner, cartLabel) {
    var qty = parseInt(document.getElementById('cfgQty').value, 10);
    var w   = document.getElementById('cfgWidth').value;
    var h   = document.getElementById('cfgHeight').value;
    var shape   = document.getElementById('cfgShapeLabel').textContent;
    var backing = document.getElementById('cfgBackingLabel').textContent;
    var bgColor = document.getElementById('cfgBgColor').value.trim();
    var border  = document.getElementById('cfgBorder').value.trim();
    var notes   = document.getElementById('cfgNotes').value;

    if (!validateUploadRequirement()) return;
    if (!validateQtyMinimum()) return;

    ['cfgWidth','cfgHeight','cfgBgColor','cfgBorder'].forEach(function(id){
      document.getElementById(id).classList.remove('cfg-input-err');
    });
    ['cfgWidthErr','cfgHeightErr','cfgBgColorErr','cfgBorderErr'].forEach(function(id){
      var el = document.getElementById(id); el.textContent=''; el.classList.remove('visible');
    });

    var hasError = false;
    if (!parseFloat(w) || parseFloat(w) <= 0) {
      var ew = document.getElementById('cfgWidthErr');
      ew.textContent = 'Mandatory field!'; ew.classList.add('visible');
      document.getElementById('cfgWidth').classList.add('cfg-input-err');
      hasError = true;
    }
    if (!parseFloat(h) || parseFloat(h) <= 0) {
      var eh = document.getElementById('cfgHeightErr');
      eh.textContent = 'Mandatory field!'; eh.classList.add('visible');
      document.getElementById('cfgHeight').classList.add('cfg-input-err');
      hasError = true;
    }
    if (!bgColor) {
      var e = document.getElementById('cfgBgColorErr');
      e.textContent = 'Mandatory field!'; e.classList.add('visible');
      document.getElementById('cfgBgColor').classList.add('cfg-input-err');
      hasError = true;
    }
    if (!border) {
      var e2 = document.getElementById('cfgBorderErr');
      e2.textContent = 'Mandatory field!'; e2.classList.add('visible');
      document.getElementById('cfgBorder').classList.add('cfg-input-err');
      hasError = true;
    }
    if (hasError) return;

    var backingSurcharge = backing === 'No Backing' ? 0 : 0.50;

    // Resolve unit price — prefer live DOM value (already shown to user) then recompute
    var unitPrice = 0;
    var priceEl = document.getElementById('cfgPricePerPatch');
    if (priceEl) {
      var parsed = parseFloat((priceEl.textContent || '').replace(/[^0-9.]/g, ''));
      if (isFinite(parsed) && parsed > 0) unitPrice = parsed;
    }
    if (!unitPrice) {
      var size = Math.max(parseFloat(w), parseFloat(h));
      var sizeData = (window._fineyst && window._fineyst.currentSizeData)
                     || (window._fineyst && window._fineyst.findSizeData && window._fineyst.findSizeData(size));
      if (sizeData && window._fineyst && window._fineyst.getPriceForQuantity) {
        unitPrice = window._fineyst.getPriceForQuantity(sizeData, qty);
      }
    }

    if (!unitPrice || unitPrice <= 0) {
      alert('Price could not be calculated. Please make sure dimensions are filled in and try again.');
      return;
    }

    var unitPriceWithBacking = (unitPrice + backingSurcharge).toFixed(2);
    var totalPrice = ((unitPrice + backingSurcharge) * qty).toFixed(2);

    if (cartBtn) { cartBtn.disabled = true; }
    if (cartSpinner) { cartSpinner.removeAttribute('hidden'); }
    if (cartLabel) { cartLabel.textContent = 'Adding…'; }

    var properties = {
      'Size':           w + '" × ' + h + '"',
      'Width':          w + '"',
      'Height':         h + '"',
      'Quantity':       qty + ' pcs',
      'Shape':          shape,
      'Backing':        backing,
      'Background Color': bgColor,
      'Border':         border,
      'custom_price':   unitPriceWithBacking,
      'Calculated Unit Price': '$' + unitPriceWithBacking,
      'Calculated Total':      '$' + totalPrice
    };
    if (notes) properties['Design Notes'] = notes;

    var aiUrlInput = document.getElementById('aiPropImageUrl');
    if (aiUrlInput && aiUrlInput.value) properties['Design Image URL'] = aiUrlInput.value;

    var form = document.createElement('form');
    form.method = 'post';
    form.action = '/cart/add';
    form.style.display = 'none';

    function addField(name, value) {
      var inp = document.createElement('input');
      inp.type = 'hidden';
      inp.name = name;
      inp.value = value;
      form.appendChild(inp);
    }

    addField('id', VARIANT_ID);
    addField('quantity', qty);
    Object.keys(properties).forEach(function(key) {
      addField('properties[' + key + ']', properties[key]);
    });

    document.body.appendChild(form);
    form.submit();
  }


})();

(function() {
  var sticky = document.getElementById('cfgMobileStickyActions');
  var stickySummary = document.getElementById('cfgMobileStickySummary');
  var stickyPrice = document.getElementById('cfgMobileStickyPrice');
  var stickySub = document.getElementById('cfgMobileStickySub');
  var stickyQuoteBtn = document.getElementById('cfgMobileStickyQuote');
  var stickyQuoteSpinner = document.getElementById('cfgMobileStickyQuoteSpinner');
  var stickyCheckoutBtn = document.getElementById('cfgMobileStickyCheckout');
  var stickyCheckoutSpinner = document.getElementById('cfgMobileStickyCheckoutSpinner');
  var stickyCheckoutLabel = document.getElementById('cfgMobileStickyCheckoutLabel');
  var checkoutBtn = document.getElementById('cfgCheckout');
  var quoteBtn = document.getElementById('cfgSubmitQuoteBtn');
  var cta = document.querySelector('.cfg-cta');
  var configurator = document.getElementById('ppConfigurator');
  var pricePerPatch = document.getElementById('cfgPricePerPatch');
  var priceTotal = document.getElementById('cfgPriceTotal');
  var priceSub = document.getElementById('cfgPriceSub');
  var rootWrap = document.querySelector('.pp-wrap');

  if (!sticky || !stickyQuoteBtn || !stickyCheckoutBtn || !checkoutBtn || !quoteBtn || !cta || !configurator) return;

  function isMobile() {
    return window.innerWidth <= 640;
  }

  function isConfiguratorVisible() {
    return window.getComputedStyle(configurator).display !== 'none' && !configurator.classList.contains('is-locked');
  }

  function isCtaOutOfView() {
    var rect = cta.getBoundingClientRect();
    return rect.bottom <= 0;
  }

  function syncSummary() {
    var unit = pricePerPatch ? pricePerPatch.textContent.trim() : '';
    var total = priceTotal ? priceTotal.textContent.trim() : '';
    var sub = priceSub ? priceSub.textContent.trim() : '';
    var hasSummary = unit.indexOf('$') !== -1 && total.indexOf('Total:') !== -1;

    if (hasSummary) {
      stickyPrice.innerHTML = '<strong>' + unit + '</strong> • ' + total;
      stickySub.textContent = sub;
      stickySummary.hidden = false;
      sticky.classList.add('has-summary');
    } else {
      stickyPrice.textContent = '';
      stickySub.textContent = '';
      stickySummary.hidden = true;
      sticky.classList.remove('has-summary');
    }
  }

  function syncButtonState() {
    var checkoutText = (checkoutBtn.textContent || '').trim();
    var quoteText = (quoteBtn.textContent || '').trim();
    var checkoutBusy = checkoutBtn.disabled && /creating order|loading/i.test(checkoutText);
    var quoteBusy = quoteBtn.disabled && /submitting|loading/i.test(quoteText);
    var actionsBusy = checkoutBtn.disabled || quoteBtn.disabled;

    stickyQuoteBtn.disabled = actionsBusy;
    stickyCheckoutBtn.disabled = actionsBusy;
    stickyQuoteSpinner.hidden = !quoteBusy;
    stickyCheckoutSpinner.hidden = !checkoutBusy;
    stickyCheckoutLabel.textContent = checkoutText || 'Proceed to Checkout';
  }

  function updateStickyVisibility() {
    syncSummary();
    syncButtonState();

    var shouldShow = isMobile() && isConfiguratorVisible() && isCtaOutOfView();
    sticky.classList.toggle('is-visible', shouldShow);
    sticky.setAttribute('aria-hidden', shouldShow ? 'false' : 'true');

    if (rootWrap) {
      rootWrap.classList.toggle('cfg-mobile-sticky-active', shouldShow);
    }
  }

  stickyQuoteBtn.addEventListener('click', function() {
    if (stickyQuoteBtn.disabled) return;
    quoteBtn.click();
    setTimeout(updateStickyVisibility, 50);
  });

  stickyCheckoutBtn.addEventListener('click', function() {
    if (stickyCheckoutBtn.disabled) return;
    checkoutBtn.click();
    setTimeout(updateStickyVisibility, 50);
  });


  var updateTimer = null;
  function scheduleUpdate() {
    if (updateTimer) window.cancelAnimationFrame(updateTimer);
    updateTimer = window.requestAnimationFrame(updateStickyVisibility);
  }

  window.addEventListener('scroll', scheduleUpdate, { passive: true });
  window.addEventListener('resize', scheduleUpdate);

  ['cfgWidth', 'cfgHeight', 'cfgQty', 'cfgBgColor', 'cfgBorder', 'cfgNotes'].forEach(function(id) {
    var el = document.getElementById(id);
    if (!el) return;
    el.addEventListener('input', scheduleUpdate);
    el.addEventListener('change', scheduleUpdate);
  });

  document.addEventListener('click', function(e) {
    var target = e.target;
    if (!(target instanceof Element)) return;
    if (target.closest('.cfg-opt-btn') || target.closest('.cfg-step-btn') || target.closest('#ppUploadBtn') || target.closest('#cfgRemoveBtn')) {
      setTimeout(scheduleUpdate, 50);
    }
  });

  var observer = new MutationObserver(function() {
    scheduleUpdate();
  });

  [configurator, pricePerPatch, priceTotal, priceSub, checkoutBtn, quoteBtn].forEach(function(el) {
    if (!el) return;
    observer.observe(el, {
      attributes: true,
      attributeFilter: ['style', 'class', 'disabled', 'hidden'],
      childList: true,
      subtree: true,
      characterData: true
    });
  });

  scheduleUpdate();
})();

(function(){
  // Reviews: search, filter, sort, media strip
  var revList = document.getElementById('ppRevList');
  if (!revList) return;

  var searchInput = document.getElementById('ppRevSearch');
  var mediaToggle = document.getElementById('ppRevMediaToggle');
  var sortSelect = document.getElementById('ppRevSort');
  var mediaStrip = document.getElementById('ppRevMediaStrip');
  var mediaOnly = false;
  var activeRating = 'all';

  function applyFilters() {
    var query = searchInput ? searchInput.value.toLowerCase() : '';
    var items = revList.querySelectorAll('.pp-rev-item');
    items.forEach(function(item) {
      var text = (item.getAttribute('data-text') || '').toLowerCase();
      var rating = item.getAttribute('data-rating');
      var hasImage = item.getAttribute('data-has-image') === 'true';
      var matchSearch = !query || text.includes(query);
      var matchRating = activeRating === 'all' || rating === activeRating;
      var matchMedia = !mediaOnly || hasImage;
      item.classList.toggle('hidden', !(matchSearch && matchRating && matchMedia));
    });
  }

  if (searchInput) searchInput.addEventListener('input', applyFilters);

  if (mediaToggle) {
    mediaToggle.addEventListener('click', function() {
      mediaOnly = !mediaOnly;
      mediaToggle.classList.toggle('on', mediaOnly);
      mediaToggle.setAttribute('aria-checked', mediaOnly ? 'true' : 'false');
      applyFilters();
    });
  }

  if (sortSelect) {
    sortSelect.addEventListener('change', function() {
      var items = Array.from(revList.querySelectorAll('.pp-rev-item'));
      items.sort(function(a, b) {
        if (sortSelect.value === 'highest') return parseInt(b.dataset.rating) - parseInt(a.dataset.rating);
        if (sortSelect.value === 'lowest') return parseInt(a.dataset.rating) - parseInt(b.dataset.rating);
        return (b.getAttribute('data-date') || '').localeCompare(a.getAttribute('data-date') || '');
      });
      items.forEach(function(item) { revList.appendChild(item); });
    });
  }

  // Media strip nav
  if (mediaStrip) {
    var prevBtn = document.getElementById('ppRevMediaPrev');
    var nextBtn = document.getElementById('ppRevMediaNext');
    if (prevBtn) prevBtn.addEventListener('click', function() { mediaStrip.scrollBy({ left: -300, behavior: 'smooth' }); });
    if (nextBtn) nextBtn.addEventListener('click', function() { mediaStrip.scrollBy({ left: 300, behavior: 'smooth' }); });
  }
})();

(function(){
  // Before/After slider
  var wrap = document.getElementById('ppBaWrap');
  if(!wrap) return;
  var before = wrap.querySelector('.pp-ba-before');
  var after = document.getElementById('ppBaAfter');
  var line  = document.getElementById('ppBaLine');
  var handle = document.getElementById('ppBaHandle');
  var pct = 50;

  function setPos(p){
    pct = Math.min(100, Math.max(0, p));
    before.style.clipPath = 'inset(0 ' + (100 - pct) + '% 0 0)';
    after.style.clipPath = 'inset(0 0 0 ' + pct + '%)';
    line.style.left = pct + '%';
    handle.style.left = pct + '%';
  }
  setPos(50);

  function getX(e){ return e.touches ? e.touches[0].clientX : e.clientX; }

  function onMove(e){
    var rect = wrap.getBoundingClientRect();
    setPos((getX(e) - rect.left) / rect.width * 100);
  }

  wrap.addEventListener('mousedown', function(e){
    e.preventDefault();
    document.addEventListener('mousemove', onMove);
    document.addEventListener('mouseup', function(){ document.removeEventListener('mousemove', onMove); }, { once:true });
  });
  wrap.addEventListener('touchstart', function(e){
    document.addEventListener('touchmove', onMove, { passive:true });
    document.addEventListener('touchend', function(){ document.removeEventListener('touchmove', onMove); }, { once:true });
  }, { passive:true });
})();

(function(){
  // Gallery
  var slides = document.querySelectorAll('.pp-img-slide');
  var thumbs = document.querySelectorAll('.pp-thumb');
  var cur = 0;
  if(!slides.length) return;
  function goTo(n){
    slides[cur].className = 'pp-img-slide inactive';
    thumbs[cur].classList.remove('active');
    cur = (n + slides.length) % slides.length;
    slides[cur].className = 'pp-img-slide active';
    thumbs[cur].classList.add('active');
  }
  document.getElementById('ppPrev').onclick = function(){ goTo(cur-1); };
  document.getElementById('ppNext').onclick = function(){ goTo(cur+1); };
  thumbs.forEach(function(t){ t.onclick = function(){ goTo(parseInt(t.dataset.idx)); }; });
})();

