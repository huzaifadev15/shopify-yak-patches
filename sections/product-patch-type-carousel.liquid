                    View
                  </button>
                </div>
              </div>
            </div>
          </div>
        {%- endfor -%}
      {%- else -%}
        {%- assign gallery_string = 'embroidered skull.jpeg,Embroidered skull custom patch,true,412,87|embroidered only on earth.jpeg,Only on earth embroidered patch,false,356,64|collections.jpeg,Collection of custom embroidered patches,true,498,102|snowy wolf chenille patch.jpeg,Snowy wolf chenille patch,true,441,95|rise.jpeg,Rise custom embroidered patch,false,389,71|embroidered 3.jpeg,Floral embroidered custom patch,false,318,55|embroidered patches.jpeg,Round embroidered badge patch set,true,467,93|ovc 3.jpeg,PVC odyssey adventure patch,false,342,62' -%}
        {%- assign gallery_items = gallery_string | split: '|' -%}
        {%- for item in gallery_items -%}
          {%- assign parts = item | split: ',' -%}
          <div class="pp-gcard">
            <div class="pp-gcard-inner">
              <div class="pp-gcard-img-wrap">
                <img src="{{ parts[0] | asset_url }}" alt="{{ parts[1] }}" loading="{%- if forloop.index <= 4 -%}eager{%- else -%}lazy{%- endif -%}" class="pp-gcard-img">
                {%- if parts[2] == 'true' -%}
                  <span class="pp-gcard-badge">
                    <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M11.017 2.814a1 1 0 0 1 1.966 0l1.051 5.558a2 2 0 0 0 1.594 1.594l5.558 1.051a1 1 0 0 1 0 1.966l-5.558 1.051a2 2 0 0 0-1.594 1.594l-1.051 5.558a1 1 0 0 1-1.966 0l-1.051-5.558a2 2 0 0 0-1.594-1.594l-5.558-1.051a1 1 0 0 1 0-1.966l5.558-1.051a2 2 0 0 0 1.594-1.594z"/><path d="M20 2v4"/><path d="M22 4h-4"/><circle cx="4" cy="20" r="2"/></svg>
                    Featured
                  </span>
                {%- endif -%}
                <div class="pp-gcard-overlay">
                  <div class="pp-gcard-stats">
                    <span class="pp-gcard-stat">
                      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M2.062 12.348a1 1 0 0 1 0-.696 10.75 10.75 0 0 1 19.876 0 1 1 0 0 1 0 .696 10.75 10.75 0 0 1-19.876 0"/><circle cx="12" cy="12" r="3"/></svg>
                      {{ parts[3] }}
                    </span>
                    <span class="pp-gcard-stat">
                      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M2 9.5a5.5 5.5 0 0 1 9.591-3.676.56.56 0 0 0 .818 0A5.49 5.49 0 0 1 22 9.5c0 2.29-1.5 4-3 5.5l-5.492 5.313a2 2 0 0 1-3 .019L5 15c-1.5-1.5-3-3.2-3-5.5"/></svg>
                      {{ parts[4] }}
