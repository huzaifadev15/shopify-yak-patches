    .then(function(data) {
      if (hasUsablePricingRows(data)) return { rows: data, source: 'product API' };
      return loadPricingRowsFromAsset().then(function(assetData) {
        if (hasUsablePricingRows(assetData)) return { rows: assetData, source: 'pricing-updt.json fallback' };
