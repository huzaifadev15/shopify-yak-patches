  function handleFile(file){
    if(!file) return;

    window.uploadedFiles = [];
    window.erpUploadedFile = null;
    window._uploadPending = true;
    var formData = new FormData();
    formData.append('file', file);
    var formData2 = new FormData();
    formData2.append('file', file);
    var primaryUpload = fetch('https://shopify-backend-app-omega.vercel.app/api/upload', {
      method: 'POST',
      body: formData
    })
    .catch(function(err){ console.error('Upload API error:', err); });
    var erpUpload = fetch('https://shopify-backend-app-omega.vercel.app/api/dashboardimage-upload', {
      method: 'POST',
      body: formData2
    })
    .then(function(r){ return r.json(); })
    .then(function(data){
      if(data && data.success){
        window.erpUploadedFile = data;
        window.uploadedFiles = [{
          originalName: file.name,
          fileName:     data.name,
          fileUrl:      data.fileUrl || data.url,
          fileSize:     data.size,
          fileType:     data.type
        }];
        savePatchDraft();
      }
    })
    .catch(function(err){ console.error('Dashboard upload error:', err); });
    Promise.all([primaryUpload, erpUpload]).finally(function(){ window._uploadPending = false; });

    var isImage = file.type.startsWith('image/');
    if(isImage){
      var reader = new FileReader();
      reader.onload = function(e){ showConfigurator(e.target.result); scrollToUploadSection(); savePatchDraft(); };
      reader.readAsDataURL(file);
    } else {
      // Non-image: show configurator with a placeholder icon
      cfgImg.src = '';
      cfgImg.alt = file.name;
      window.uploadedImageUrl = null;
      syncRemoveButtonVisibility();
      preUpload.style.display = 'none';
      configurator.style.display = 'block';
      document.getElementById('cfgToggles').style.display = 'none'; // No image data, hide image tools
      updatePriceDisplay();
      scrollToUploadSection();
      savePatchDraft();
    }
  }

