            <path d="M20 2v4"/><path d="M22 4h-4"/><circle cx="4" cy="20" r="2"/>
          </svg>
        </div>
        <span style="font-size:14px;font-weight:700;color:#3D1F0A;">Fineyst AI</span>
      </div>
