  // Find pricing data for specific size
  function findSizeData(sizeInches) {
    if (!pricingData || !Array.isArray(pricingData)) return null;

    var nearest = null;
    var nearestDiff = Infinity;

    pricingData.forEach(function(sizeObj) {
      var size = parseFloat(sizeObj.size);
      if (isNaN(size)) return;
      var diff = Math.abs(size - sizeInches);
      if (diff < nearestDiff) {
        nearestDiff = diff;
        nearest = sizeObj;
      }
    });

    return nearest;
  }
  
  // Get price for specific quantity from size data
  function getPriceForQuantity(sizeData, qty) {
    if (!sizeData) return 0;
    
    // Define quantity breakpoints in order
    var qtyKeys = [
      { min: 10000, key: 'qty10000' },
      { min: 5000, key: 'qty5000' },
      { min: 2500, key: 'qty2500' },
      { min: 2000, key: 'qty2000' },
      { min: 1500, key: 'qty1500' },
      { min: 1000, key: 'qty1000' },
      { min: 750, key: 'qty750' },
      { min: 700, key: 'qty700' },
      { min: 500, key: 'qty500' },
      { min: 300, key: 'qty300' },
      { min: 250, key: 'qty250' },
      { min: 200, key: 'qty200' },
      { min: 100, key: 'qty100' },
      { min: 75, key: 'qty75' },
      { min: 50, key: 'qty50' },
      { min: 25, key: 'qty25' },
      { min: 20, key: 'qty20' },
      { min: 10, key: 'qty10' },
      { min: 5, key: 'qty5' }
    ];
    
    // Cap at 1000 — quantities above 1000 use the 1000-tier price
    var effectiveQty = Math.min(qty, 1000);

    // Find the appropriate price tier
    for (var i = 0; i < qtyKeys.length; i++) {
      if (effectiveQty >= qtyKeys[i].min) {
        var price = parseFloat(sizeData[qtyKeys[i].key]);
        if (!isNaN(price) && price > 0) {
          return price;
        }
      }
    }
    
    // Fallback: use the highest-priced available tier (lowest quantity tier with a value)
    for (var j = qtyKeys.length - 1; j >= 0; j--) {
      var fbPrice = parseFloat(sizeData[qtyKeys[j].key]);
      if (!isNaN(fbPrice) && fbPrice > 0) {
        return fbPrice;
      }
    }
    return 0;
  }

