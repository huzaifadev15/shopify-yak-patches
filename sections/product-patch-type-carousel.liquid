{%- assign fallback_product = all_products['embroidered-patches'] -%}
{%- assign product_path_prefix = request.path | slice: 0, 10 -%}
{%- assign has_selected_patch_type = false -%}
{%- if product != blank and product_path_prefix == '/products/' -%}
  {%- assign has_selected_patch_type = true -%}
{%- endif -%}
{%- if product == blank -%}
  {%- assign product = fallback_product -%}
{%- endif -%}
{%- assign pp_display_title = product.title -%}
{%- assign pp_review_items = product.metafields.custom.reviews.value -%}
{%- assign pp_review_count = 143 -%}
{%- assign pp_patch_type_links = "Embroidered,/products/embroidered-patches|PVC,/products/pvc-patches|Chenille,/products/custom-chenille-patches|Leather,/products/custom-leather-name-patches|Printed,/products/printed-patches|Woven,/products/custom-woven-patches|Heart,/products/custom-heart-patches|Applique,/products/custom-applique-patches|Brand,/products/custom-brand-patches|Varsity Letter,/products/custom-varsity-letter-patches|Sports,/products/custom-sports-patches|Rubber,/products/rubber-patches|Iron On,/products/custom-iron-on-patches|Military,/products/custom-military-patches" | split: "|" -%}
{%- if pp_review_items != blank -%}
  {%- assign pp_review_count = pp_review_items.size -%}
{%- endif -%}
{%- unless has_selected_patch_type -%}
  {%- assign pp_display_title = 'Custom Patches' -%}
{%- endunless -%}
{% render 'pp-carousel-styles' %}
<script>
(function(){
  if ({{ has_selected_patch_type | json }}) return;
  var handle = new URLSearchParams(window.location.search).get('patch_type') || '';
  if (/^[a-z0-9][a-z0-9-]*$/.test(handle.trim())) document.documentElement.classList.add('pp-direct-patch-booting');
})();
</script>

<div class="pp-wrap" id="ppPriceCalc">
  <div class="pp-inner">

    <!-- Gallery -->
    <div class="pp-gallery">
      <div class="pp-main-img-box" id="ppImgBox">
        {%- if has_selected_patch_type -%}
          {%- for image in product.images -%}
            {%- assign slide_loading = 'lazy' -%}
            {%- assign slide_fetchpriority = 'auto' -%}
            {%- if forloop.first -%}
              {%- assign slide_loading = 'eager' -%}
              {%- assign slide_fetchpriority = 'high' -%}
            {%- endif -%}
            <div class="pp-img-slide {% if forloop.first %}active{% else %}inactive{% endif %}" data-idx="{{ forloop.index0 }}">
              {{ image | image_url: width: 900 | image_tag: alt: pp_display_title, loading: slide_loading, fetchpriority: slide_fetchpriority, class: 'pp-product-img' }}
            </div>
          {%- endfor -%}
        {%- else -%}
          {%- assign fallback_gallery_idx = 0 -%}
          {%- for tab in pp_patch_type_links -%}
            {%- assign tparts = tab | split: "," -%}
            {%- assign product_handle = tparts[1] | split: "/products/" | last -%}
            {%- assign linked_product = all_products[product_handle] -%}
            {%- if linked_product.featured_image != blank -%}
              {%- assign fallback_alt = linked_product.title | default: tparts[0] -%}
              <div class="pp-img-slide {% if fallback_gallery_idx == 0 %}active{% else %}inactive{% endif %}" data-idx="{{ fallback_gallery_idx }}">
                {%- if fallback_gallery_idx == 0 -%}
                  {{ linked_product.featured_image | image_url: width: 900 | image_tag: alt: fallback_alt, loading: 'eager', fetchpriority: 'high', class: 'pp-product-img' }}
                {%- else -%}
                  {{ linked_product.featured_image | image_url: width: 900 | image_tag: alt: fallback_alt, loading: 'lazy', class: 'pp-product-img' }}
                {%- endif -%}
              </div>
              {%- assign fallback_gallery_idx = fallback_gallery_idx | plus: 1 -%}
            {%- endif -%}
          {%- endfor -%}
          {%- if fallback_gallery_idx == 0 and product.featured_image != blank -%}
            <div class="pp-img-slide active" data-idx="0">
              {{ product.featured_image | image_url: width: 900 | image_tag: alt: pp_display_title, loading: 'eager', fetchpriority: 'high', class: 'pp-product-img' }}
            </div>
          {%- endif -%}
        {%- endif -%}
        <button class="pp-arrow pp-arrow-prev" id="ppPrev" aria-label="Previous">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m15 18-6-6 6-6"/></svg>
        </button>
        <button class="pp-arrow pp-arrow-next" id="ppNext" aria-label="Next">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m9 18 6-6-6-6"/></svg>
        </button>
      </div>
      <div class="pp-thumbs">
        {%- if has_selected_patch_type -%}
          {%- for image in product.images -%}
            {%- assign thumb_loading = 'lazy' -%}
            {%- if forloop.index <= 4 -%}{%- assign thumb_loading = 'eager' -%}{%- endif -%}
            <button class="pp-thumb {% if forloop.first %}active{% endif %}" data-idx="{{ forloop.index0 }}" aria-label="View image {{ forloop.index }}">
              {{ image | image_url: width: 180, height: 180, crop: 'center' | image_tag: alt: pp_display_title, loading: thumb_loading, class: 'pp-thumb-img' }}
            </button>
          {%- endfor -%}
        {%- else -%}
          {%- assign fallback_thumb_idx = 0 -%}
          {%- for tab in pp_patch_type_links -%}
            {%- assign tparts = tab | split: "," -%}
            {%- assign product_handle = tparts[1] | split: "/products/" | last -%}
            {%- assign linked_product = all_products[product_handle] -%}
            {%- if linked_product.featured_image != blank -%}
              {%- assign fallback_alt = linked_product.title | default: tparts[0] -%}
              {%- assign fallback_thumb_loading = 'lazy' -%}
              {%- if fallback_thumb_idx < 4 -%}{%- assign fallback_thumb_loading = 'eager' -%}{%- endif -%}
              <button class="pp-thumb {% if fallback_thumb_idx == 0 %}active{% endif %}" data-idx="{{ fallback_thumb_idx }}" aria-label="View {{ fallback_alt | escape }} image">
                {{ linked_product.featured_image | image_url: width: 180, height: 180, crop: 'center' | image_tag: alt: fallback_alt, loading: fallback_thumb_loading, class: 'pp-thumb-img' }}
              </button>
              {%- assign fallback_thumb_idx = fallback_thumb_idx | plus: 1 -%}
            {%- endif -%}
          {%- endfor -%}
          {%- if fallback_thumb_idx == 0 and product.featured_image != blank -%}
            <button class="pp-thumb active" data-idx="0" aria-label="View fallback image">
              {{ product.featured_image | image_url: width: 180, height: 180, crop: 'center' | image_tag: alt: pp_display_title, loading: 'eager', class: 'pp-thumb-img' }}
            </button>
          {%- endif -%}
        {%- endif -%}
      </div>
    </div>

    <!-- Details -->
    <div>
      <nav class="pp-breadcrumb" aria-label="Breadcrumb">
        <a href="/">Home</a>
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m9 18 6-6-6-6"/></svg>
        <a href="/collections/all">Patches</a>
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m9 18 6-6-6-6"/></svg>
        <span style="color:#111;font-weight:600;">{{ pp_display_title }}</span>
      </nav>

     

      {%- assign pp_title_image = nil -%}
      {%- if has_selected_patch_type and product.images.size > 0 -%}
        {%- assign pp_title_image = product.images.first -%}
      {%- elsif product.featured_image != blank -%}
        {%- assign pp_title_image = product.featured_image -%}
      {%- endif -%}
      <div class="pp-title-row">
        {%- if pp_title_image -%}
          <button type="button" class="pp-title-thumb pp-thumb active" data-idx="0" aria-label="View image 1">
            {{ pp_title_image | image_url: width: 140, height: 140, crop: 'center' | image_tag: alt: pp_display_title, loading: 'lazy', class: 'pp-thumb-img' }}
          </button>
        {%- endif -%}
        <div class="pp-title-copy">
          <h1 class="pp-title">{{ pp_display_title }}</h1>
          <div class="pp-title-mobile-info">
            <div class="pp-title-meta-row{% unless has_selected_patch_type %} pp-title-meta-row--fallback{% endunless %}">
              <div class="pp-stars">
                {%- for i in (1..5) -%}
                  <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path d="M11.525 2.295a.53.53 0 0 1 .95 0l2.31 4.679a2.123 2.123 0 0 0 1.595 1.16l5.166.756a.53.53 0 0 1 .294.904l-3.736 3.638a2.123 2.123 0 0 0-.611 1.878l.882 5.14a.53.53 0 0 1-.771.56l-4.618-2.428a2.122 2.122 0 0 0-1.973 0L6.396 21.01a.53.53 0 0 1-.77-.56l.881-5.139a2.122 2.122 0 0 0-.611-1.879L2.16 9.795a.53.53 0 0 1 .294-.906l5.165-.755a2.122 2.122 0 0 0 1.597-1.16z"/></svg>
                {%- endfor -%}
              </div>
              <span class="pp-review-count">{{ pp_review_count }} Reviews</span>
            </div>

            <div class="pp-price-row" id="ppInitialPriceRow"{% if has_selected_patch_type %} style="display:none;"{% endif %}>
              <strong id="ppInitialPrice">{% if has_selected_patch_type %}—{% else %}$2.30{% endif %}</strong> <span>{% if has_selected_patch_type %}each{% else %}upto{% endif %} at 100 pieces.</span>
            </div>
          </div>
        </div>
      </div>

      {%- if has_selected_patch_type and product.metafields.custom.product_top_description != blank -%}
        <div class="pp-desc">{{ product.metafields.custom.product_top_description | metafield_tag }}</div>
      {%- else -%}
        <div class="pp-desc pp-desc--fallback">Select a patch type below to get started.</div>
      {%- endif -%}

 <section class="pp-type-carousel" data-patch-type-carousel aria-labelledby="ppTypeCarouselTitle">
        <div class="pp-type-carousel-head">
          <div class="pp-type-carousel-title" id="ppTypeCarouselTitle"><span class="pp-type-carousel-step">1</span><span>Select Patch Type</span></div>
          {%- if has_selected_patch_type -%}<span class="pp-type-carousel-current">Current</span>{%- endif -%}
        </div>
        <button class="pp-type-arrow pp-type-arrow-prev" type="button" data-patch-type-prev aria-label="Previous patch types">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m15 18-6-6 6-6"/></svg>
        </button>
        <div class="pp-type-track" data-patch-type-track>
          {%- for tab in pp_patch_type_links -%}
            {%- assign tparts = tab | split: "," -%}
            {%- assign product_handle = tparts[1] | split: "/products/" | last -%}
            {%- assign linked_product = all_products[product_handle] -%}
            {%- assign card_title = linked_product.title | default: tparts[0] -%}
            {%- assign card_loading = 'lazy' -%}
            {%- assign card_fetchpriority = 'auto' -%}
            {%- if forloop.index <= 3 -%}
              {%- assign card_loading = 'eager' -%}
              {%- if forloop.first -%}{%- assign card_fetchpriority = 'high' -%}{%- endif -%}
            {%- endif -%}
            <a href="{{ tparts[1] }}" class="pp-type-card{% if has_selected_patch_type %}{% if request.path == tparts[1] or product.handle == product_handle %} is-active{% endif %}{% endif %}" data-patch-type-link{% if has_selected_patch_type %}{% if request.path == tparts[1] or product.handle == product_handle %} aria-current="page"{% endif %}{% endif %}>
              <span class="pp-type-card-img">
                {%- if linked_product.featured_image != blank -%}
                    {{ linked_product.featured_image | image_url: width: 420 | image_tag: alt: card_title, loading: card_loading, fetchpriority: card_fetchpriority }}
                  {%- else -%}
                  <span class="pp-type-placeholder" aria-hidden="true"></span>
                {%- endif -%}
              </span>
              <span class="pp-type-card-title">{{ card_title }}</span>
            </a>
          {%- endfor -%}
        </div>
        <button class="pp-type-arrow pp-type-arrow-next" type="button" data-patch-type-next aria-label="Next patch types">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m9 18 6-6-6-6"/></svg>
        </button>
      </section>
      
      <div class="pp-trust">
        <span class="pp-trust-item">Free Physical Proof</span>
        <span class="pp-trust-sep">|</span>
        <span class="pp-trust-item">No Art or Set Up Fees</span>
        <span class="pp-trust-sep">|</span>
        <span class="pp-trust-item">Free Shipping <span class="pp-trust-note" style="font-weight:500;color:#6b7280;">(for 100+ pieces)</span></span>
      </div>

        

      <!-- Hidden AI cart properties (underscore prefix hides them from checkout/order summary) -->
      <input type="hidden" id="aiPropProvider" name="properties[_AI Provider]" value="">
      <input type="hidden" id="aiPropModel" name="properties[_AI Model]" value="">
      <input type="hidden" id="aiPropPrompt" name="properties[_AI Prompt]" value="">
      <input type="hidden" id="aiPropRequestId" name="properties[_AI Request ID]" value="">
      <input type="hidden" id="aiPropImageUrl" name="properties[_AI Image URL]" value="">

      <!-- Upload box (pre-upload) -->
      <div id="ppPreUpload" style="display:none;" aria-hidden="true">
        <div class="pp-upload-box" id="ppUploadBox">
          <input type="file" id="ppDesignUpload" accept=".jpg,.jpeg,.png,.gif,.webp,.svg,.pdf,.ai,.eps,.psd" style="position:fixed;top:0;left:0;width:1px;height:1px;opacity:0;overflow:hidden;pointer-events:none;">
          <div id="ppUploadDefault">
            <button class="pp-upload-btn" id="ppUploadBtn">
              <svg width="18" height="18" fill="none" stroke="currentColor" viewBox="0 0 24 24"><rect x="3" y="3" width="18" height="18" rx="2" stroke-width="1.5"/><circle cx="8.5" cy="8.5" r="1.5" stroke-width="1.5"/><path d="M21 15l-5-5L5 21" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
              Upload Design to get started
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none"><path d="M12 4v12m0-12l-4 4m4-4l4 4" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/><path d="M20 16v4a2 2 0 01-2 2H6a2 2 0 01-2-2v-4" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </button>
            <p class="pp-upload-hint">or drop file here</p>
            <p class="pp-upload-sub">All file types accepted (No .DST or .EMB Files Please)</p>
          </div>
        </div>
        <!-- AI box -->
        <div class="pp-ai-box">
          <div class="pp-ai-inner">
            <div>
              <p class="pp-ai-title">Create a design with AI</p>
              <p class="pp-ai-sub">Describe your vision and let AI generate a patch design for you</p>
            </div>
            <button class="pp-ai-btn" id="openAiModal">
              Create an Image
              <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2L9.5 9.5 2 12l7.5 2.5L12 22l2.5-7.5L22 12l-7.5-2.5L12 2z"/></svg>
            </button>
          </div>
        </div>
      </div>

      <!-- Configurator (post-upload) -->
      <div id="ppConfigurator" class="pp-configurator-shell{% unless has_selected_patch_type %} is-locked{% endunless %}" aria-disabled="{% unless has_selected_patch_type %}true{% else %}false{% endunless %}">
        <div class="pp-configurator-head">
          <div class="pp-configurator-title"><span class="pp-configurator-step">2</span><span>Customization</span></div>
        </div>
        <div class="pp-configurator-lock-note">Select a patch type to continue</div>
        <div class="cfg-wrap">
          <!-- Image preview + pricing table -->
          <div class="cfg-top-grid">
            <!-- Image preview with ruler -->
            <div class="cfg-preview-col">
              <div class="cfg-ruler-wrap">
                <div class="cfg-ruler-h">
                  <div class="cfg-ruler-line"></div>
                  <div class="cfg-ruler-tick cfg-ruler-tick-l"></div>
                  <div class="cfg-ruler-tick cfg-ruler-tick-r"></div>
                  <p class="cfg-ruler-label" id="cfgWidthLabel">2.25"</p>
                </div>
                <div class="cfg-img-frame" id="cfgImgFrame" style="position:relative;">
                  <div class="cfg-remove-wrap">
                    <button id="cfgRemoveBtn" class="cfg-remove-btn" title="Remove uploaded image" style="display:none;">
                      <svg width="14" height="14" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/></svg>
                    </button>
                  </div>
                  <div class="cfg-ruler-v" id="cfgRulerV">3.00"</div>
                  <button type="button" class="cfg-img-btn" id="cfgImgBtn" aria-label="Upload a new image">
                    <img id="cfgPreviewImg" src="https://cdn.shopify.com/s/files/1/0670/4703/0883/files/placeholder-patches.webp?v=1784140622" alt="Design preview" class="cfg-preview-img">
                    <span class="cfg-upload-badge">
                      <svg width="15" height="15" viewBox="0 0 24 24" fill="none"><path d="M12 4v12m0-12l-4 4m4-4l4 4" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/><path d="M20 16v4a2 2 0 01-2 2H6a2 2 0 01-2-2v-4" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
                    </span>
                  </button>
                  <div class="cfg-zoom-lens" id="cfgZoomLens"></div>
                  <div class="cfg-zoom-result" id="cfgZoomResult"></div>
                </div>
                <div class="cfg-upload-later-block">
                  <div class="cfg-upload-later-divider" aria-hidden="true"><span>or</span></div>
                  <p class="cfg-upload-error" id="cfgUploadErr" role="alert">Image is mandatory. Upload a design or select upload image later.</p>
                  <label class="cfg-upload-later" for="ppUploadLater">
                    <input type="checkbox" id="ppUploadLater">
                    <span>Upload image later</span>
                  </label>
                </div>
              </div>
            </div>
            <!-- Pricing table -->
            <div class="cfg-price-table-wrap">
              <table class="cfg-price-table">
                <thead><tr><th>Quantity</th><th>Price</th><th>Qty Discount</th></tr></thead>
                <tbody id="cfgPriceTableBody">
                  <tr><td colspan="3" style="text-align:center;color:#9ca3af;padding:16px;font-size:13px;">Loading prices…</td></tr>
                </tbody>
              </table>
            </div>

            <div class="cfg-toggles" id="cfgToggles">
              <div class="cfg-toggle-group">
                <label class="cfg-toggle-label">
                  <span class="cfg-toggle-text">
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="6" cy="6" r="3"/><path d="M8.12 8.12 12 12"/><path d="M20 4 8.12 15.88"/><circle cx="6" cy="18" r="3"/><path d="M14.8 14.8 20 20"/></svg>
                    Crop &amp; Trim
                  </span>
                  <button type="button" role="switch" class="cfg-switch" id="cfgCropSwitch" aria-checked="false">
                    <span class="cfg-switch-thumb"></span>
                  </button>
                </label>
                <label class="cfg-toggle-label">
                  <span class="cfg-toggle-text">
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 21H8a2 2 0 0 1-1.42-.587l-3.994-3.999a2 2 0 0 1 0-2.828l10-10a2 2 0 0 1 2.829 0l5.999 6a2 2 0 0 1 0 2.828L12.834 21"/><path d="m5.082 11.09 8.828 8.828"/></svg>
                    Remove Background
                  </span>
                  <button type="button" role="switch" class="cfg-switch" id="cfgBgSwitch" aria-checked="false">
                    <span class="cfg-switch-thumb"></span>
                  </button>
                </label>
              </div>
              <button type="button" class="cfg-ai-edit-btn" id="openAiModal">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M11.017 2.814a1 1 0 0 1 1.966 0l1.051 5.558a2 2 0 0 0 1.594 1.594l5.558 1.051a1 1 0 0 1 0 1.966l-5.558 1.051a2 2 0 0 0-1.594 1.594l-1.051 5.558a1 1 0 0 1-1.966 0l-1.051-5.558a2 2 0 0 0-1.594-1.594l-5.558-1.051a1 1 0 0 1 0-1.966l5.558-1.051a2 2 0 0 0 1.594-1.594z"/><path d="M20 2v4"/><path d="M22 4h-4"/><circle cx="4" cy="20" r="2"/></svg>
                Edit with AI
              </button>
            </div>
            </div>

            <div class="cfg-size-guide-row" id="cfgSizeGuideRow">
              <span>Select Your Patch Size:</span>
              <button type="button" class="cfg-size-guide-btn" id="cfgSizeGuideBtn" aria-haspopup="dialog" aria-controls="cfgSizeGuideModal">
                <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M3 21 21 3"/><path d="M7 21h-4v-4"/><path d="M17 3h4v4"/><path d="M3 7V3h4"/><path d="M21 17v4h-4"/></svg>
                <span>Patch Size Guide</span>
              </button>
          </div>
          <!-- W / H / Qty inputs + live price -->
          <div class="cfg-dims">
            <div class="cfg-dim-group">
              <label class="cfg-dim-label">Width (inches) <span style="color:#7C4A1E;">*</span> <span class="cfg-field-err" id="cfgWidthErr"></span></label>
              <div class="cfg-stepper">
                <button type="button" class="cfg-step-btn" id="cfgWMinus">&minus;</button>
                <input type="text" id="cfgWidth" placeholder="0.00" class="cfg-step-input" inputmode="decimal" autocomplete="off" maxlength="6">
                <button type="button" class="cfg-step-btn" id="cfgWPlus">+</button>
              </div>
            </div>
            <div class="cfg-dim-group">
              <label class="cfg-dim-label">Height (inches) <span style="color:#7C4A1E;">*</span> <span class="cfg-field-err" id="cfgHeightErr"></span></label>
              <div class="cfg-stepper">
                <button type="button" class="cfg-step-btn" id="cfgHMinus">&minus;</button>
                <input type="text" id="cfgHeight" placeholder="0.00" class="cfg-step-input" inputmode="decimal" autocomplete="off" maxlength="6">
                <button type="button" class="cfg-step-btn" id="cfgHPlus">+</button>
              </div>
            </div>
            <div class="cfg-dim-group">
              <label class="cfg-dim-label" style="display:flex;justify-content:space-between;align-items:center;gap:8px;">
                <span>Qty <span class="cfg-field-err" id="cfgQtyErr"></span></span>
                <span style="color:#7C4A1E;font-size:10px;font-weight:700;">10 Piece Min.</span>
              </label>
              <div class="cfg-stepper" id="cfgQtyStepper">
                <button type="button" class="cfg-step-btn" id="cfgQMinus">&minus;</button>
