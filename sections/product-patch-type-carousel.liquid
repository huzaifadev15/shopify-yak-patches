  /* ── Crop Modal ── */
  (function() {
    var modal    = document.getElementById('cropModal');
    var img      = document.getElementById('crpmImg');
    var box      = document.getElementById('crpmBox');
    var subtitle = document.getElementById('crpmSubtitle');
    var wrap     = document.getElementById('crpmCanvasWrap');

    function openCropModal() {
      var w = parseFloat(document.getElementById('cfgWidth').value)  || 1;
      var h = parseFloat(document.getElementById('cfgHeight').value) || 1;
      subtitle.textContent = 'Adjust framing to match ' + w.toFixed(2) + '" × ' + h.toFixed(2) + '" proportions.';

      img.src = window.uploadedImageUrl;
      modal.classList.add('open');
      modal.setAttribute('aria-hidden', 'false');
      document.body.style.overflow = 'hidden';

      img.onload = function() { initCropBox(w / h); };
      if (img.complete && img.naturalWidth) initCropBox(w / h);
    }
    window.openCropModal = openCropModal;

    /* ── Initialise crop box to fill ~80% of image, locked to patch aspect ratio ── */
    function initCropBox(aspect) {
      var iw = wrap.clientWidth;
      var ih = img.clientHeight;
      var boxW = iw * 0.80;
      var boxH = boxW / aspect;
      if (boxH > ih * 0.80) { boxH = ih * 0.80; boxW = boxH * aspect; }
      var x = (iw - boxW) / 2;
      var y = (ih - boxH) / 2;
      setBox(x, y, boxW, boxH);
    }

    function setBox(x, y, w, h) {
      var iw = wrap.clientWidth;
      var ih = img.clientHeight;
      x = Math.max(0, Math.min(x, iw - w));
      y = Math.max(0, Math.min(y, ih - h));
      w = Math.max(40, Math.min(w, iw - x));
      h = Math.max(40, Math.min(h, ih - y));
      box.style.left   = x + 'px';
      box.style.top    = y + 'px';
      box.style.width  = w + 'px';
      box.style.height = h + 'px';
    }

    /* ── Drag & resize ── */
    var drag = null; // { type:'move'|dir, startX, startY, ox, oy, ow, oh }

    function onPointerDown(e) {
      e.preventDefault();
      var dir = e.target.dataset.dir;
      var cx  = e.clientX || (e.touches && e.touches[0].clientX);
      var cy  = e.clientY || (e.touches && e.touches[0].clientY);
      drag = {
        type:  dir || 'move',
        startX: cx, startY: cy,
        ox: parseInt(box.style.left),  oy: parseInt(box.style.top),
        ow: parseInt(box.style.width), oh: parseInt(box.style.height)
      };
    }

    function onPointerMove(e) {
      if (!drag) return;
      var cx  = e.clientX || (e.touches && e.touches[0].clientX);
      var cy  = e.clientY || (e.touches && e.touches[0].clientY);
      var dx  = cx - drag.startX;
      var dy  = cy - drag.startY;
      var aspect = (parseFloat(document.getElementById('cfgWidth').value)  || 1) /
                   (parseFloat(document.getElementById('cfgHeight').value) || 1);
      var x = drag.ox, y = drag.oy, w = drag.ow, h = drag.oh;
      var iw = wrap.clientWidth, ih = img.clientHeight;

      if (drag.type === 'move') {
        x = drag.ox + dx; y = drag.oy + dy;
      } else {
        var t = drag.type;
        // resize keeping aspect ratio
        if (t === 'se' || t === 's' || t === 'e') {
          w = drag.ow + dx; h = w / aspect;
        } else if (t === 'sw' || t === 'w') {
          w = drag.ow - dx; h = w / aspect; x = drag.ox + drag.ow - w;
        } else if (t === 'ne' || t === 'n') {
          w = drag.ow + dx; h = w / aspect; y = drag.oy + drag.oh - h;
        } else if (t === 'nw') {
          w = drag.ow - dx; h = w / aspect; x = drag.ox + drag.ow - w; y = drag.oy + drag.oh - h;
        }
      }
      setBox(x, y, w, h);
    }

    function onPointerUp() { drag = null; }

    box.addEventListener('mousedown',  onPointerDown);
    box.addEventListener('touchstart', onPointerDown, { passive: false });
    document.addEventListener('mousemove',  onPointerMove);
    document.addEventListener('touchmove',  onPointerMove, { passive: false });
    document.addEventListener('mouseup',  onPointerUp);
    document.addEventListener('touchend',  onPointerUp);

    /* ── Apply crop ── */
    document.getElementById('crpmApply').onclick = function() {
      var scaleX = img.naturalWidth  / img.clientWidth;
      var scaleY = img.naturalHeight / img.clientHeight;
      var bx = parseInt(box.style.left)   * scaleX;
      var by = parseInt(box.style.top)    * scaleY;
      var bw = parseInt(box.style.width)  * scaleX;
      var bh = parseInt(box.style.height) * scaleY;

      var canvas = document.createElement('canvas');
      canvas.width  = bw;
      canvas.height = bh;
      var ctx = canvas.getContext('2d');
      var source = new Image();
      source.crossOrigin = 'anonymous';
      source.onload = function() {
        ctx.drawImage(source, bx, by, bw, bh, 0, 0, bw, bh);
        var cropped = canvas.toDataURL('image/png');
        window.uploadedImageUrl = cropped;
        var cfgImg = document.getElementById('cfgPreviewImg');
        if (cfgImg) cfgImg.src = cropped;
        syncRemoveButtonVisibility();
        cropSwitch.setAttribute('aria-checked', 'true');
        closeModal();
      };
      source.onerror = function() {
        // fallback: use canvas drawn from img element
        ctx.drawImage(img, bx, by, bw, bh, 0, 0, bw, bh);
        var cropped = canvas.toDataURL('image/png');
        window.uploadedImageUrl = cropped;
        var cfgImg = document.getElementById('cfgPreviewImg');
        if (cfgImg) cfgImg.src = cropped;
        syncRemoveButtonVisibility();
        cropSwitch.setAttribute('aria-checked', 'true');
        closeModal();
      };
      source.src = window.uploadedImageUrl;
    };

    /* ── Close helpers ── */
    function closeModal() {
      modal.classList.remove('open');
      modal.setAttribute('aria-hidden', 'true');
      document.body.style.overflow = '';
    }

    function cancelCrop() {
      restoreOriginalImage();
      cropSwitch.setAttribute('aria-checked', 'false');
      closeModal();
    }
    document.getElementById('crpmClose').onclick    = cancelCrop;
    document.getElementById('crpmCancel').onclick   = cancelCrop;
    document.getElementById('crpmBackdrop').onclick = cancelCrop;
    document.addEventListener('keydown', function(e) { if (e.key === 'Escape' && modal.classList.contains('open')) cancelCrop(); });
  })();
  
  // Remove Background toggle with API call
  bgSwitch.onclick = function(){
    var checked = bgSwitch.getAttribute('aria-checked') === 'true';
    
    if (!checked && window.uploadedImageUrl) {
      // ── Serve from cache if already processed ──
      if (window.removedBgImageUrl) {
        var cfgImgEl = document.getElementById('cfgPreviewImg');
        window.uploadedImageUrl = window.removedBgImageUrl;
        if (cfgImgEl) cfgImgEl.src = window.removedBgImageUrl;
        syncRemoveButtonVisibility();
        bgSwitch.setAttribute('aria-checked', 'true');
        return;
      }

      // Turning ON - call remove background API
      bgSwitch.disabled = true;
      var originalText = bgSwitch.parentElement.querySelector('.cfg-toggle-text').innerHTML;
      bgSwitch.parentElement.querySelector('.cfg-toggle-text').innerHTML = '<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg>Processing...';

      // Convert data URL to blob and upload if needed
      if (window.uploadedImageUrl.startsWith('data:')) {
        fetch(window.uploadedImageUrl)
          .then(function(res) { return res.blob(); })
          .then(function(blob) {
            var formData = new FormData();
            formData.append('file', blob, 'uploaded-image.png');
            return fetch('https://shopify-backend-app-omega.vercel.app/api/upload', {
              method: 'POST',
              body: formData
            });
          })
          .then(function(r) { return r.json(); })
          .then(function(uploadData) {
            if (uploadData.url) {
              return fetch('https://shopify-backend-app-omega.vercel.app/api/ai/edit', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ action: 'remove_background', imageUrl: uploadData.url })
              });
            } else {
              throw new Error('Failed to upload image');
            }
          })
          .then(function(r) { return r.json(); })
          .then(function(data) {
            var reqId = data.requestId || data.generation_id || data.id;
            if (reqId) {
              pollRemoveBgStatus(reqId, 0, Date.now(), bgSwitch, originalText);
            } else {
              bgSwitch.disabled = false;
              bgSwitch.parentElement.querySelector('.cfg-toggle-text').innerHTML = originalText;
            }
          })
          .catch(function(err) {
            console.error('Remove background error:', err);
            bgSwitch.disabled = false;
            bgSwitch.parentElement.querySelector('.cfg-toggle-text').innerHTML = originalText;
          });
      } else {
        // Use URL directly
        fetch('https://shopify-backend-app-omega.vercel.app/api/ai/edit', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ action: 'remove_background', imageUrl: window.uploadedImageUrl })
        })
        .then(function(r) { return r.json(); })
        .then(function(data) {
          var reqId = data.requestId || data.generation_id || data.id;
          if (reqId) {
            pollRemoveBgStatus(reqId, 0, Date.now(), bgSwitch, originalText);
          } else {
            bgSwitch.disabled = false;
            bgSwitch.parentElement.querySelector('.cfg-toggle-text').innerHTML = originalText;
          }
        })
        .catch(function(err) {
          console.error('Remove background error:', err);
          bgSwitch.disabled = false;
          bgSwitch.parentElement.querySelector('.cfg-toggle-text').innerHTML = originalText;
        });
      }
    } else {
      // Toggle off — restore original image
      restoreOriginalImage();
      bgSwitch.setAttribute('aria-checked', 'false');
    }
  };
  
  function pollRemoveBgStatus(requestId, attempt, startTime, switchEl, originalText) {
    var elapsed = Date.now() - startTime;
    if (elapsed > 90000) {
      switchEl.disabled = false;
      switchEl.parentElement.querySelector('.cfg-toggle-text').innerHTML = originalText;
      return;
    }
    
    fetch('https://shopify-backend-app-omega.vercel.app/api/ai/edit/' + requestId)
      .then(function(r) { return r.json(); })
      .then(function(data) {
        if (data.status === 'completed') {
          var imageUrl = null;
          if (data.images && data.images.length > 0 && data.images[0].url) imageUrl = data.images[0].url;
          else if (data.image && data.image.url) imageUrl = data.image.url;
          else if (data.output && typeof data.output === 'string') imageUrl = data.output;
          else if (data.output && data.output.images && data.output.images.length > 0 && data.output.images[0].url) imageUrl = data.output.images[0].url;
          
          if (imageUrl) {
            fetch(imageUrl)
              .then(function(r) { return r.blob(); })
              .then(function(blob) {
                var reader = new FileReader();
                reader.onload = function(e) {
                  cfgImg.src = e.target.result;
                  syncRemoveButtonVisibility();
                  window.uploadedImageUrl  = e.target.result;
                  syncRemoveButtonVisibility();
                  window.removedBgImageUrl = e.target.result; // cache for re-use
                  switchEl.setAttribute('aria-checked', 'true');
                  switchEl.disabled = false;
                  switchEl.parentElement.querySelector('.cfg-toggle-text').innerHTML = originalText;
                };
                reader.readAsDataURL(blob);
              })
              .catch(function() {
                switchEl.disabled = false;
                switchEl.parentElement.querySelector('.cfg-toggle-text').innerHTML = originalText;
              });
          } else {
            switchEl.disabled = false;
            switchEl.parentElement.querySelector('.cfg-toggle-text').innerHTML = originalText;
          }
        } else if (data.status === 'failed') {
          switchEl.disabled = false;
          switchEl.parentElement.querySelector('.cfg-toggle-text').innerHTML = originalText;
        } else {
          setTimeout(function() { pollRemoveBgStatus(requestId, attempt + 1, startTime, switchEl, originalText); }, 2500);
        }
      })
      .catch(function() {
        setTimeout(function() { pollRemoveBgStatus(requestId, attempt + 1, startTime, switchEl, originalText); }, 2500);
      });
  }

