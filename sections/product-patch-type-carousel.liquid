  // Render pricing table from API data
  function renderPricingTableFromAPI(sizeData, qty) {
    if (!sizeData) return false;
    
    var tbody = document.getElementById('cfgPriceTableBody');
    var html = '';
    
    // Define tier structure for display with their actual API keys
    var tiers = [
      { min: 10, max: 24, label: '10-24 pcs', qtyKey: 'qty10' },
      { min: 25, max: 49, label: '25-49', qtyKey: 'qty25' },
      { min: 50, max: 99, label: '50-99', qtyKey: 'qty50' },
      { min: 100, max: 199, label: '100-199', qtyKey: 'qty100' },
      { min: 200, max: 499, label: '200-499', qtyKey: 'qty250' },
      { min: 500, max: 999, label: '500-999', qtyKey: 'qty500' },
      { min: 1000, max: null, label: '1000+', qtyKey: 'qty1000' }
    ];
    
    var basePrice = getPriceForQuantity(sizeData, 10);
    if (!basePrice || basePrice === 0) return false;
    
    tiers.forEach(function(tier) {
      // Get the actual price for this tier using the quantity-based lookup
      var price = getPriceForQuantity(sizeData, tier.min);
      
      var discountPercent = Math.round(((basePrice - price) / basePrice) * 100);
      var active = qty >= tier.min && (tier.max === null || qty <= tier.max);
      
      html += '<tr' + (active ? ' class="cfg-row-active"' : '') + ' data-cfg-tier-qty="' + tier.min + '" tabindex="0" role="button">' +
        '<td>' + tier.label + '</td>' +
        '<td>$' + price.toFixed(2) + ' ea</td>' +
        '<td class="cfg-discount">' + (discountPercent > 0 ? discountPercent + '% off' : '') + '</td>' +
        '</tr>';
    });
    
    tbody.innerHTML = html;
    return true;
  }



