{% comment %} Why Buy From Us Section {% endcomment %}
<section class="why-section">
  <div class="why-container">

    <!-- Header -->
    <div class="why-header">
      <h2 class="why-title">Why Buy From Yak Patches?</h2>
      <p class="why-subtitle">We're committed to providing the highest quality custom patches with exceptional service at competitive prices.</p>
    </div>

    <!-- Feature rows -->
    <div class="why-rows">

      {%- assign features = "COMPETITIVE PRICES,dollar,Affordable Custom Patches Without Sacrificing Quality,We believe high-quality custom patches should be accessible to everyone. Our competitive pricing ensures you get premium patches without breaking the bank.,No setup or art fees|Bulk order discounts available|Free digital proofs and revisions|Price match guarantee|SIMPLE & HASSLE-FREE DESIGN PROCESS,lightbulb,Your Vision Our Expertise,Our streamlined design process makes creating custom patches easy and efficient. From concept to final product we handle everything with expertise.,Easy online submission|Quick turnaround times|Expert design assistance|Satisfaction guaranteed|ENDLESS CUSTOMIZATION OPTIONS,palette,Create Unique Custom Patches for Any Purpose,From colors and materials to shapes and sizes we offer unlimited customization options to bring your vision to life.,Multiple patch types (embroidered PVC woven)|Custom shapes and sizes available|Various backing options (iron-on velcro adhesive)|Vibrant long-lasting colors" | split: "|" -%}

      {%- comment -%} Build structured data manually for 3 features {%- endcomment -%}

      {%- assign feature_data = "COMPETITIVE PRICES||dollar||Affordable Custom Patches Without Sacrificing Quality||We believe high-quality custom patches should be accessible to everyone. Our competitive pricing ensures you get premium patches without breaking the bank.||No setup or art fees||Bulk order discounts available||Free digital proofs and revisions||Price match guarantee~~SIMPLE & HASSLE-FREE DESIGN PROCESS||lightbulb||Your Vision, Our Expertise||Our streamlined design process makes creating custom patches easy and efficient. From concept to final product, we handle everything with expertise.||Easy online submission||Quick turnaround times||Expert design assistance||Satisfaction guaranteed~~ENDLESS CUSTOMIZATION OPTIONS||palette||Create Unique Custom Patches for Any Purpose||From colors and materials to shapes and sizes, we offer unlimited customization options to bring your vision to life.||Multiple patch types (embroidered, PVC, woven)||Custom shapes and sizes available||Various backing options (iron-on, velcro, adhesive)||Vibrant, long-lasting colors" | split: "~~" -%}

      {%- for feature in feature_data -%}
        {%- assign f = feature | split: "||" -%}
        {%- assign title = f[0] -%}
        {%- assign icon = f[1] -%}
        {%- assign tagline = f[2] -%}
        {%- assign desc = f[3] -%}
        {%- assign b1 = f[4] -%}
        {%- assign b2 = f[5] -%}
        {%- assign b3 = f[6] -%}
        {%- assign b4 = f[7] -%}

        <div class="why-card">
          <!-- Icon -->
          <div class="why-icon">
            {%- if icon == 'dollar' -%}
              <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="12" x2="12" y1="2" y2="22"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg>
            {%- elsif icon == 'lightbulb' -%}
              <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M15 14c.2-1 .7-1.7 1.5-2.5 1-.9 1.5-2.2 1.5-3.5A6 6 0 0 0 6 8c0 1 .2 2.2 1.5 3.5.7.7 1.3 1.5 1.5 2.5"/><path d="M9 18h6"/><path d="M10 22h4"/></svg>
            {%- elsif icon == 'palette' -%}
              <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 22a1 1 0 0 1 0-20 10 9 0 0 1 10 9 5 5 0 0 1-5 5h-2.25a1.75 1.75 0 0 0-1.4 2.8l.3.4a1.75 1.75 0 0 1-1.4 2.8z"/><circle cx="13.5" cy="6.5" r=".5" fill="currentColor"/><circle cx="17.5" cy="10.5" r=".5" fill="currentColor"/><circle cx="6.5" cy="12.5" r=".5" fill="currentColor"/><circle cx="8.5" cy="7.5" r=".5" fill="currentColor"/></svg>
            {%- endif -%}
          </div>
          <!-- Content -->
          <div class="why-card-body">
            <p class="why-card-title">{{ title }}</p>
            <p class="why-card-tagline">{{ tagline }}</p>
            <p class="why-card-desc">{{ desc }}</p>
            <div class="why-bullets">
              <div class="why-bullet"><span class="why-dot"></span><span>{{ b1 }}</span></div>
              <div class="why-bullet"><span class="why-dot"></span><span>{{ b2 }}</span></div>
              <div class="why-bullet"><span class="why-dot"></span><span>{{ b3 }}</span></div>
              <div class="why-bullet"><span class="why-dot"></span><span>{{ b4 }}</span></div>
            </div>
          </div>
        </div>

      {%- endfor -%}
    </div>

    <!-- CTA Banner -->
    <div class="why-cta-wrap">
      <div class="why-cta-banner">
        <p class="why-cta-title">READY TO GET STARTED?</p>
        <p class="why-cta-sub">Contact us today for a free quote and consultation on your custom patch project.</p>
        <a href="/collections" class="why-cta-btn">Get Started</a>
      </div>
    </div>

  </div>
</section>

{% schema %}
{
  "name": "Why Buy From Us",
  "settings": [],
  "presets": [{ "name": "Why Buy From Us" }]
}
{% endschema %}

