{% comment %} Bulk Orders Section {% endcomment %}
<style>
  .bulk-orders-section {
    position: relative;
    background-image:
      linear-gradient(rgba(0, 0, 0, 0.35), rgba(0, 0, 0, 0.35)),
      url('{{ "patch-manufacturing-machine.webp" | asset_url }}');
    background-size: cover;
    background-position: center;
    background-repeat: no-repeat;
  }

  @media (max-width: 767px) {
    .bulk-orders-section {
      background-image:
        linear-gradient(rgba(0, 0, 0, 0.35), rgba(0, 0, 0, 0.35)),
        url('{{ "fleet-mobile.webp" | asset_url }}');
    }
  }
</style>

<section class="bulk-orders-section" style="{% if section.settings.bg_image != blank %}background-image: linear-gradient(rgba(0, 0, 0, 0.35), rgba(0, 0, 0, 0.35)), url('{{ section.settings.bg_image | img_url: 'master' }}'); background-size: cover; background-position: center; background-repeat: no-repeat;{% elsif section.settings.bg_color != blank %}background-color: {{ section.settings.bg_color }};{% endif %}">
  <div class="bulk-container">
    <div class="bulk-content">
      
      <!-- Badge -->
      <div class="bulk-badge">
        <p><span class="bulk-badge-highlight">Free</span> Design &amp; <span class="bulk-badge-highlight">Unlimited</span> Revisions</p>
      </div>

      <!-- Heading -->
      <h2 class="bulk-heading">{{ section.settings.heading | default: 'Custom Patches â€” Small Batch &amp; Bulk Orders, Any Quantity' }}</h2>

      <!-- Description -->
      <p class="bulk-desc">{{ section.settings.description | default: 'Our massive production capacity allows us to handle orders of any size with industry-leading turnaround times. From small custom batches to large volume orders, our state-of-the-art embroidery machines deliver consistent, high-quality results every time.' }}</p>

      <!-- Trust indicator -->
      <div class="bulk-trust">
        <div class="bulk-trust-badge">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21.801 10A10 10 0 1 1 17 3.335"/><path d="m9 11 3 3L22 4"/></svg>
          <span>5,000+ Trusted Customers</span>
        </div>
      </div>

      <!-- CTA -->
      <a href="{{ section.settings.cta_url | default: '/collections' }}" class="bulk-cta">
        {{ section.settings.cta_text | default: 'Get Started' }}
      </a>

    </div>
  </div>
</section>

{% schema %}
{
  "name": "Bulk Orders",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "Custom Patches â€” Small Batch & Bulk Orders, Any Quantity" },
    { "type": "textarea", "id": "description", "label": "Description" },
    { "type": "text", "id": "cta_text", "label": "Button Text", "default": "Get Started" },
    { "type": "url", "id": "cta_url", "label": "Button URL" },
    { "type": "color", "id": "bg_color", "label": "Background Color" },
    { "type": "image_picker", "id": "bg_image", "label": "Background Image" }
  ],
  "presets": [{ "name": "Bulk Orders" }]
}
{% endschema %}

