<section class="scroll-reviews-section" aria-labelledby="reviews-scroll-heading">
  <header class="scroll-reviews-header">
    <h2 id="reviews-scroll-heading" class="scroll-reviews-title">Custom Patches Reviews â€” Verified Feedback from Real Customers</h2>
    <p class="scroll-reviews-sub">Verified Feedback from Authentic Customers</p>
  </header>

  <!-- Row 1: scroll left -->
  <div class="scroll-row-wrap" aria-label="Customer reviews scrolling left">
    <div class="scroll-row scroll-left">
      {%- for item in row1 -%}
        {%- assign parts = item | split: "," -%}
        <article class="scroll-card" role="button" tabindex="0" aria-label="Review by {{ parts[0] }}">
          <header class="scroll-card-header">
            <div class="scroll-stars">{{ star_svg }}{{ star_svg }}{{ star_svg }}{{ star_svg }}{{ star_svg }}</div>
            <p class="scroll-name">{{ parts[0] }}</p>
            <div class="scroll-verified">
              <img src="{{ 'meta-verified.webp' | asset_url }}" alt="Meta Verified" width="20" height="20" loading="lazy">
              <span>Verified buyer</span>
            </div>
          </header>
          <p class="scroll-text">"{{ parts[1] }}"</p>
        </article>
      {%- endfor -%}
      {%- comment -%}Duplicate for seamless loop{%- endcomment -%}
      {%- for item in row1 -%}
        {%- assign parts = item | split: "," -%}
        <article class="scroll-card" aria-hidden="true" tabindex="-1">
          <header class="scroll-card-header">
            <div class="scroll-stars">{{ star_svg }}{{ star_svg }}{{ star_svg }}{{ star_svg }}{{ star_svg }}</div>
            <p class="scroll-name">{{ parts[0] }}</p>
            <div class="scroll-verified">
              <img src="{{ 'meta-verified.webp' | asset_url }}" alt="" width="20" height="20" loading="lazy">
              <span>Verified buyer</span>
            </div>
          </header>
          <p class="scroll-text">"{{ parts[1] }}"</p>
        </article>
      {%- endfor -%}
    </div>
  </div>

  <!-- Row 2: scroll right -->
  <div class="scroll-row-wrap" aria-label="Customer reviews scrolling right">
    <div class="scroll-row scroll-right">
      {%- for item in row2 -%}
        {%- assign parts = item | split: "," -%}
