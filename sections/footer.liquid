<style>
  /* ===== FOOTER ===== */
  .ft { background: #3D1F0A; padding: 48px 16px 0; font-family: "Averta", "Segoe UI", Arial, sans-serif; }
  .ft *, .ft *::before, .ft *::after { box-sizing: border-box; }
  .ft a { text-decoration: none; }
  .ft-inner { max-width: 1440px; margin: 0 auto; padding: 0 16px; }

  /* Top grid */
  .ft-grid { display: grid; grid-template-columns: 1fr; gap: 32px; margin-bottom: 48px; }
  @media (min-width: 640px) { .ft-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (min-width: 900px) { .ft-grid { grid-template-columns: 2fr 1fr 1fr 1fr 1fr; } }

  /* Brand col */
  .ft-brand { display: flex; flex-direction: column; align-items: center; gap: 24px; }
  @media (min-width: 900px) { .ft-brand { align-items: flex-start; padding-right: 24px; } }

  .ft-logo-wrap { display: flex; flex-direction: column; align-items: center; }
  @media (min-width: 900px) { .ft-logo-wrap { align-items: flex-start; } }
  .ft-logo { height: 48px; width: 200px; object-fit: contain; display: block; margin-bottom: 12px; transition: opacity 0.2s; }
  .ft-logo:hover { opacity: 0.8; }
  .ft-tagline { color: #d1d5db; font-size: 14px; font-weight: 600; text-align: center; }
  @media (min-width: 900px) { .ft-tagline { text-align: left; } }

  /* Contact info */
  .ft-contact { display: flex; flex-direction: column; gap: 14px; width: 100%; align-items: center; }
  @media (min-width: 900px) { .ft-contact { align-items: flex-start; } }
  .ft-contact-row { display: flex; align-items: flex-start; gap: 10px; }
  .ft-contact-icon { color: #7C4A1E; flex-shrink: 0; margin-top: 2px; }
  .ft-contact-row a, .ft-contact-row span { color: #d1d5db; font-size: 14px; font-weight: 600; line-height: 1.5; transition: color 0.2s; }
  .ft-contact-row a:hover { color: #fff; }

  .ft-hours { margin-top: 8px; text-align: center; display: flex; flex-direction: column; gap: 12px; }
  @media (min-width: 900px) { .ft-hours { text-align: left; } }
  .ft-hours-label { color: #fff; font-weight: 600; font-size: 14px; margin-bottom: 3px; }
  .ft-hours p { color: #d1d5db; font-size: 14px; font-weight: 600; margin: 0; }

  /* Link columns */
  .ft-col { }
  .ft-col-btn { display: flex; justify-content: space-between; align-items: center; width: 100%; background: none; border: none; border-bottom: 1px solid #374151; padding-bottom: 10px; margin-bottom: 0; cursor: pointer; color: #7C4A1E; font-family: "Averta", "Segoe UI", Arial, sans-serif; font-weight: 700; font-size: 16px; text-align: left; }
  @media (min-width: 900px) { .ft-col-btn { border-bottom: none; padding-bottom: 0; margin-bottom: 16px; cursor: default; pointer-events: none; } }
  .ft-col-chevron { flex-shrink: 0; transition: transform 0.25s; color: #7C4A1E; }
  .ft-col-chevron.open { transform: rotate(180deg); }
  @media (min-width: 900px) { .ft-col-chevron { display: none; } }

  .ft-col-links { list-style: none; margin: 0; padding: 0; display: flex; flex-direction: column; gap: 10px; overflow: hidden; max-height: 0; transition: max-height 0.3s ease, padding 0.3s ease; }
  .ft-col-links.open { max-height: 400px; padding-top: 12px; }
  @media (min-width: 900px) { .ft-col-links { max-height: none !important; padding-top: 0 !important; } }
  .ft-col-links a { color: #d1d5db; font-size: 14px; font-weight: 600; transition: color 0.2s; }
  .ft-col-links a:hover { color: #fff; }
  .ft-col-links .ft-view-all { color: #fff; font-weight: 500; }
  .ft-col-links .ft-view-all:hover { color: #7C4A1E; }

  /* Middle row: social + newsletter */
  .ft-mid { display: flex; flex-direction: column; align-items: center; gap: 32px; border-top: 1px solid #2A1008; padding: 32px 0; }
  @media (min-width: 900px) { .ft-mid { flex-direction: row; justify-content: space-between; align-items: center; } }

  /* Social */
  .ft-social { display: flex; flex-direction: column; align-items: center; gap: 16px; }
  @media (min-width: 900px) { .ft-social { flex-direction: row; align-items: center; margin-top:40px; } }
  .ft-follow-label { color: #d1d5db; font-size: 13px; font-weight: 600; letter-spacing: 0.05em; }
  .ft-social-links { display: flex; gap: 12px; }
  .ft-social-link { display: flex; align-items: center; justify-content: center; width: 40px; height: 40px; border-radius: 50%; border: 2px solid rgba(124,74,30,0.5); background: transparent; color: #7C4A1E; transition: border-color 0.3s, background 0.3s; }
  .ft-social-link:hover { border-color: #7C4A1E; background: rgba(124,74,30,0.1); }
  .ft-social-link svg { width: 20px; height: 20px; display: block; flex-shrink: 0; }
  .ft-social-link .ft-social-icon--stroke { fill: none; stroke: currentColor; }
  .ft-social-link .ft-social-icon--fill { fill: currentColor; stroke: none; }

  /* Newsletter */
  .ft-newsletter { max-width: 380px; width: 100%; text-align: center; padding: 0 8px; }
  .ft-nl-title { color: #fff; font-weight: 600; font-size: 15px; margin-bottom: 6px; }
  .ft-nl-sub { color: #d1d5db; font-size: 13px; margin-bottom: 14px; }
  .ft-nl-form { display: flex; }
  .ft-nl-input { flex: 1; background: #2A1008; border: 1px solid #374151; border-right: none; border-radius: 6px 0 0 6px; padding: 10px 16px; color: #fff; font-size: 14px; font-family: "Averta", "Segoe UI", Arial, sans-serif; outline: none; transition: border-color 0.2s; }
  .ft-nl-input:focus { border-color: #7C4A1E; }
  .ft-nl-input::placeholder { color: #6b7280; }
  .ft-nl-btn { background: #7C4A1E; color: #fff; border: none; border-radius: 0 6px 6px 0; padding: 10px 18px; font-size: 14px; font-weight: 600; font-family: "Averta", "Segoe UI", Arial, sans-serif; cursor: pointer; transition: background 0.2s; white-space: nowrap; }
  .ft-nl-btn:hover { background: #6B3A18; }
  .ft-nl-btn:disabled { cursor: wait; opacity: 0.72; }
  .ft-nl-status { min-height: 18px; margin: 8px 0 0; color: #d1d5db; font-size: 12px; line-height: 1.4; }
  .ft-nl-status.success { color: #86efac; }
  .ft-nl-status.error { color: #fca5a5; }
  .trustpilot-widget { width: auto; max-width: 220px; }
  @media (max-width: 899px) { .trustpilot-widget { margin-top: 0 !important; } }

  /* Bottom bar */
  .ft-bottom { border-top: 1px solid #2A1008; padding: 24px 0 32px; }
  .ft-bottom-inner { display: flex; flex-direction: column; align-items: center; gap: 20px; }
  @media (min-width: 900px) { .ft-bottom-inner { flex-direction: row; justify-content: space-between; align-items: center; } }

  .ft-copy { color: #9ca3af; font-size: 14px; text-align: center; }
  @media (min-width: 900px) { .ft-copy { text-align: left; width: 33%; } }
  .ft-copy-mobile { color: #9ca3af; font-size: 13px; text-align: center; margin-top: 16px; }
  @media (min-width: 900px) { .ft-copy-mobile { display: none; } }
  .ft-copy-desktop { display: none; }
  @media (min-width: 900px) { .ft-copy-desktop { display: block; } }

  .ft-country { display: flex; flex-direction: column; align-items: center; gap: 6px; }
  @media (min-width: 900px) { .ft-country { width: 33%; } }
  .ft-country-label { color: #9ca3af; font-size: 12px; }
  .ft-country-btn { display: inline-flex; align-items: center; gap: 8px; border: 1px solid #d1d5db; border-radius: 6px; background: #fff; color: #111; padding: 8px 16px; font-size: 14px; font-weight: 500; font-family: "Averta", "Segoe UI", Arial, sans-serif; cursor: pointer; transition: background 0.2s; }
  .ft-country-btn:hover { background: #f3f4f6; }

  .ft-payments { text-align: center; }
  @media (min-width: 900px) { .ft-payments { text-align: right; width: 33%; } }
  .ft-payments-label { color: #9ca3af; font-size: 12px; margin-bottom: 8px; }
