{% assign resolved_case_handle = case_handle | default: page.handle %}

{% assign accent_color = '#C4956A' %}
{% assign accent_soft = 'rgba(124, 74, 30, 0.1)' %}
{% assign button_hover = '#6B3A18' %}
{% assign side_logo = '' %}
{% assign meta_1_label = '' %}
{% assign meta_1_value = '' %}
{% assign meta_2_label = '' %}
{% assign meta_2_value = '' %}
{% assign meta_3_label = '' %}
{% assign meta_3_value = '' %}
{% assign cta_title = '' %}
{% assign cta_button_text = '' %}
{% assign hero_title = '' %}
{% assign hero_accent = '' %}
{% assign hero_client = '' %}
{% assign hero_problem = '' %}
{% assign need_copy = '' %}
{% assign response_intro = '' %}
{% assign response_image = '' %}
{% assign response_image_alt = '' %}
{% assign response_items = '' %}
{% assign outcome_items = '' %}
{% assign outcome_image = '' %}
{% assign outcome_image_alt = '' %}
{% assign quote_text = '' %}
{% assign extra_title = '' %}
{% assign extra_intro = '' %}
{% assign extra_items = '' %}
{% assign extra_outro = '' %}
{% assign extra_cta_text = '' %}

{% case resolved_case_handle %}
  {% when 'case-study-cuero-street' %}
    {% assign side_logo = 'cuero-street.webp' %}
    {% assign meta_1_label = 'VERSION USED' %}
    {% assign meta_1_value = 'Custom embroidered patches' %}
    {% assign meta_2_label = 'TIME TO DEPLOYMENT' %}
    {% assign meta_2_value = '10 days' %}
    {% assign meta_3_label = 'HOURS SAVED' %}
    {% assign meta_3_value = 'Sold out in under 48 hours' %}
    {% assign cta_title = 'Ready to make your brand stand out?' %}
    {% assign cta_button_text = 'Get Started' %}
    {% assign hero_title = 'CUERO STREET' %}
    {% assign hero_accent = 'When Your Brand Message Has to Be Worn' %}
    {% assign hero_client = 'Client: CUERO STREET - Black-owned Streetwear Brand' %}
    {% assign hero_problem = 'Problem: "We can&apos;t launch looking like everyone else."' %}
    {% assign need_copy = 'CUERO STREET wasn&apos;t just selling clothes. They were launching a movement - one rooted in Black resilience, street legacy, and modern rebellion. They didn&apos;t want screen prints or generic patches.<br><br>They needed statement pieces. The kind of detail that stops someone in the street and makes them ask, "Where&apos;d you get that?"' %}
    {% assign response_intro = 'We didn&apos;t sell them patches. We helped build a uniform for street culture:' %}
    {% assign response_image = 'cuero-street-case-study2.webp' %}
    {% assign response_image_alt = 'Cuero Street Patch Details' %}
    {% assign response_items = 'Embroidered "CUERO STREET" logos in gothic black applique|A lion paw patch symbolizing legacy and strength|Metallic thread "Key &amp; Crown" patch - royalty from the street, for the street|Designed to feel luxury, not mass-made|Everything was produced, proofed, and shipped in 10 days, ahead of their drop.' %}
    {% assign outcome_items = 'Their jackets sold out in under 48 hours|Over 300 customers posted "CUERO STREET" patch fits online|The brand was featured in 2 streetwear blogs - within a week|They came back for 3x more patches the next month' %}
    {% assign outcome_image = 'cuero-street-case-study.webp' %}
    {% assign outcome_image_alt = 'Cuero Street Custom Patches' %}
    {% assign quote_text = '&quot;The patches made the collection. Everyone kept asking who did them.&quot;' %}
  {% when 'case-study-steel-wolves' %}
    {% assign side_logo = 'steel-wolves.webp' %}
    {% assign meta_1_label = 'VERSION USED' %}
    {% assign meta_1_value = 'Weatherproof embroidered patches' %}
    {% assign meta_2_label = 'DEPLOYMENT' %}
    {% assign meta_2_value = 'Multi-chapter rollout' %}
    {% assign meta_3_label = 'REACH' %}
    {% assign meta_3_value = '35 chapters nationwide' %}
    {% assign cta_title = 'Ready to create your story?' %}
    {% assign cta_button_text = 'Get a Quote' %}
    {% assign hero_title = 'Steel Wolves MC' %}
    {% assign hero_accent = 'For Those Who Wear Their Brotherhood on Their Back' %}
    {% assign hero_client = 'Client: Steel Wolves Motorcycle Club' %}
    {% assign hero_problem = 'Problem: "No one can get our design right. And we ride hard. We need these to last."' %}
    {% assign need_copy = 'Steel Wolves had one non-negotiable: their back patches mean everything. They represent decades of loyalty, pride, and unity. But most local patch makers couldn&apos;t handle the complexity of their design - or make something that could survive Texas heat, cold, and hundreds of miles on the road.<br><br>They needed more than just a vendor. They needed someone who understood the culture.' %}
    {% assign response_intro = 'We delivered patches worthy of the road:' %}
    {% assign response_image = 'steel-wolves-case-study.webp' %}
    {% assign response_image_alt = 'Steel Wolves MC Custom Patches' %}
    {% assign response_items = 'Oversized, high-resolution wolf emblem - embroidered with weatherproof thread|Reinforced edges for abrasion resistance on leather|Matching name bars with Velcro and sew-on versions|Tested in tough outdoor conditions before shipping' %}
    {% assign outcome_items = 'Rolled out across 35 chapters nationwide|Referred to 2 other MCs within weeks|Their President called it "the best patch work they&apos;ve ever had"|Added us to their official preferred vendor list' %}
    {% assign quote_text = '&quot;No one else could pull this off. We wear our patches with pride - and now with confidence.&quot;' %}
    {% assign extra_title = 'Common Success Factors' %}
    {% assign extra_intro = 'They started with a need:' %}
    {% assign extra_items = 'Make us stand out|Make it last|Make it feel like us' %}
    {% assign extra_outro = 'That&apos;s what Yak Patches does - we build identity into every stitch.' %}
    {% assign extra_cta_text = 'Ready to create your story?' %}
  {% when 'case-study-techgear' %}
    {% assign side_logo = 'tech-gear.webp' %}
    {% assign meta_1_label = 'VERSION USED' %}
    {% assign meta_1_value = 'Woven logo patches' %}
    {% assign meta_2_label = 'TIME TO DEPLOYMENT' %}
    {% assign meta_2_value = 'Early delivery' %}
    {% assign meta_3_label = 'RESULTS' %}
    {% assign meta_3_value = '98% attendee adoption' %}
    {% assign cta_title = 'Ready for your next corporate event?' %}
    {% assign cta_button_text = 'Get Started' %}
    {% assign hero_title = 'TechGear Solutions' %}
    {% assign hero_accent = 'Turning a Corporate Event into a Brand Experience' %}
    {% assign hero_client = 'Client: TechGear Solutions - B2B SaaS Product Launch' %}
    {% assign hero_problem = 'Problem: "Our event can&apos;t feel like just another booth giveaway."' %}
    {% assign need_copy = 'TechGear was hosting a tech summit. They didn&apos;t want water bottles or stress balls.<br><br>They wanted memorability &mdash; something subtle, sleek, and wearable that would still carry their brand weeks after the event.<br><br>They tried swag vendors &mdash; most were slow, off-brand, or overpromised.' %}
    {% assign response_intro = 'We proposed a clean, corporate patch set:' %}
    {% assign response_items = 'Woven logo patches in minimalist matte finish|Velcro backing for bags, jackets, and caps|Premium packaging, ready to drop into swag kits|Delivered early, with high-res proofing and brand-safe color matching' %}
    {% assign outcome_items = '98% of attendees took home branded patches|Event hashtag got 500+ LinkedIn posts|Patches showed up on backpacks at 3 follow-up events|TechGear&apos;s CMO approved an ongoing patch line for company gifts' %}
    {% assign quote_text = '&quot;This was next-level branding. Everyone asked who our vendor was.&quot;' %}
{% endcase %}

{% assign response_list = response_items | split: '|' %}
{% assign outcome_list = outcome_items | split: '|' %}
{% assign extra_list = extra_items | split: '|' %}

<style>
  .case-study-page {
    background: #ffffff;
    color: #111827;
  }

  .case-study-page .case-study-shell {
    max-width: 1280px;
    margin: 0 auto;
    padding: 138px 16px 64px;
  }

  .case-study-page .case-study-breadcrumb {
    margin: 8px 0 24px;
    font-size: 14px;
    line-height: 1.6;
    color: #6b7280;
  }

  .case-study-page .case-study-breadcrumb a {
    color: #6b7280;
    transition: color 0.2s ease;
  }

  .case-study-page .case-study-breadcrumb a:hover {
    color: {{ accent_color }};
  }

  .case-study-page .case-study-breadcrumb-sep {
    display: inline-block;
    margin: 0 8px;
    color: #9ca3af;
  }

  .case-study-page .case-study-layout {
    display: grid;
    grid-template-columns: minmax(250px, 290px) minmax(0, 1fr);
    gap: 32px;
    align-items: start;
  }

  .case-study-page .case-study-back {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    width: 100%;
    padding: 16px 18px;
    background: #0f1629;
    color: #ffffff;
    border-radius: 16px 16px 0 0;
    font-size: 15px;
    font-weight: 600;
    transition: opacity 0.2s ease, transform 0.2s ease;
  }

  .case-study-page .case-study-back:hover {
    opacity: 0.92;
    transform: translateX(-4px);
  }

  .case-study-page .case-study-aside-card {
    position: sticky;
    top: 100px;
    border: 1px solid #e5e7eb;
    border-top: 0;
    border-radius: 0 0 16px 16px;
    background: #ffffff;
    box-shadow: 0 10px 30px rgba(15, 23, 42, 0.08);
    padding: 24px;
  }

  .case-study-page .case-study-logo {
    display: flex;
    justify-content: center;
    margin-bottom: 24px;
  }

  .case-study-page .case-study-logo img {
    width: 120px;
    max-width: 100%;
    height: auto;
    object-fit: contain;
  }

  .case-study-page .case-study-metrics {
    display: grid;
    gap: 20px;
    margin-bottom: 28px;
  }

  .case-study-page .case-study-metric-label {
    margin: 0 0 4px;
    color: #6b7280;
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .case-study-page .case-study-metric-value {
    margin: 0;
    color: #111827;
    font-size: 16px;
    line-height: 1.5;
    font-weight: 600;
  }

  .case-study-page .case-study-cta {
    padding: 20px;
    border: 1px solid #e5e7eb;
    border-radius: 16px;
    background: {{ accent_soft }};
  }

  .case-study-page .case-study-cta p {
    margin: 0 0 14px;
    color: #111827;
    line-height: 1.6;
    font-weight: 600;
  }

  .case-study-page .case-study-cta-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    min-height: 48px;
    padding: 12px 22px;
    border-radius: 9999px;
    background: {{ accent_color }};
    color: #ffffff;
    font-size: 15px;
    font-weight: 600;
    transition: background-color 0.2s ease, transform 0.2s ease;
  }

  .case-study-page .case-study-cta-btn:hover {
    background: {{ button_hover }};
    transform: translateY(-1px);
  }

  .case-study-page .case-study-main {
    margin-top: 6px;
    text-align: left;
  }

  .case-study-page .case-study-hero {
    margin-bottom: 28px;
    padding: 28px;
    border: 1px solid #e5e7eb;
    border-radius: 24px;
    background: linear-gradient(90deg, #0f1629 0%, #3D1F0A 100%);
    color: #ffffff;
  }

  .case-study-page .case-study-hero h1 {
    margin: 0 0 16px;
    font-size: clamp(1.5rem, 3.6vw, 2.5rem);
    line-height: 1.12;
    font-weight: 700;
  }

  .case-study-page .case-study-hero h1 span {
    color: {{ accent_color }};
  }

  .case-study-page .case-study-hero h2 {
    margin: 0;
    color: #d1d5db;
    font-size: clamp(1rem, 2vw, 1.3rem);
    line-height: 1.5;
    font-weight: 500;
  }

  .case-study-page .case-study-hero p {
    margin: 16px 0 0;
    color: #9ca3af;
    font-size: clamp(0.95rem, 1.7vw, 1.1rem);
    line-height: 1.6;
  }

  .case-study-page .case-study-block {
    margin-bottom: 28px;
    padding: 28px;
    border: 1px solid #e5e7eb;
    border-radius: 24px;
    background: #f9fafb;
  }

  .case-study-page .case-study-head {
    display: flex;
    align-items: center;
    gap: 16px;
    margin-bottom: 18px;
  }

  .case-study-page .case-study-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 48px;
    height: 48px;
    flex: 0 0 48px;
    border-radius: 9999px;
    background: linear-gradient(90deg, {{ accent_color }} 0%, {{ accent_color }} 100%);
    color: #ffffff;
  }

  .case-study-page .case-study-icon svg {
    width: 24px;
    height: 24px;
  }

  .case-study-page .case-study-head h2 {
    margin: 0;
    color: #111827;
    font-size: clamp(1rem, 2vw, 1.5rem);
    line-height: 1.2;
    font-weight: 700;
  }

  .case-study-page .case-study-copy,
  .case-study-page .case-study-intro,
  .case-study-page .case-study-extra-copy,
  .case-study-page .case-study-extra-copy a {
    color: #374151;
    font-size: 16px;
    line-height: 1.8;
  }

  .case-study-page .case-study-intro {
    margin: 0 0 16px;
  }

  .case-study-page .case-study-split {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(300px, 1fr);
    gap: 24px;
    align-items: start;
  }

  .case-study-page .case-study-list {
    display: grid;
    gap: 14px;
    margin: 16px 0 0;
    padding: 0;
    list-style: none;
  }

  .case-study-page .case-study-list li {
    position: relative;
    padding-left: 20px;
    color: #374151;
    font-size: 16px;
    line-height: 1.7;
  }

  .case-study-page .case-study-list li::before {
    content: '';
    position: absolute;
    top: 11px;
    left: 0;
    width: 8px;
    height: 8px;
    border-radius: 9999px;
    background: {{ accent_color }};
  }

  .case-study-page .case-study-visual {
    position: relative;
    overflow: hidden;
    border: 1px solid #e5e7eb;
    border-radius: 18px;
    box-shadow: 0 18px 40px rgba(15, 23, 42, 0.12);
    background: #ffffff;
  }

  .case-study-page .case-study-visual img {
    width: 100%;
    height: 100%;
    display: block;
    object-fit: cover;
  }

  .case-study-page .case-study-visual.case-study-visual-4x3 {
    aspect-ratio: 4 / 3;
  }

  .case-study-page .case-study-visual.case-study-visual-16x9 {
    aspect-ratio: 16 / 9;
  }

  .case-study-page .case-study-quote {
    margin-bottom: 28px;
    padding: 24px 28px;
    border-left: 4px solid {{ accent_color }};
    border-radius: 0 18px 18px 0;
    background: linear-gradient(90deg, {{ accent_soft }} 0%, rgba(255, 255, 255, 0.95) 100%);
  }

  .case-study-page .case-study-quote p {
    margin: 0;
    color: #111827;
    font-size: clamp(1rem, 1.8vw, 1.15rem);
    line-height: 1.7;
    font-weight: 600;
  }

  .case-study-page .case-study-extra {
    margin-bottom: 0;
  }

  .case-study-page .case-study-extra-list li::before {
    background: #22c55e;
  }

  .case-study-page .case-study-extra-cta {
    margin-top: 16px;
  }

  .case-study-page .case-study-extra-cta a {
    color: {{ accent_color }};
    font-weight: 700;
  }

  @media (max-width: 1023px) {
    .case-study-page .case-study-layout,
    .case-study-page .case-study-split {
      grid-template-columns: 1fr;
    }

    .case-study-page .case-study-aside-card {
      position: static;
    }
  }

  @media (max-width: 767px) {
    .case-study-page .case-study-shell {
      padding-top: 128px;
      padding-bottom: 48px;
    }

    .case-study-page .case-study-breadcrumb {
      margin-top: 0;
      margin-bottom: 20px;
      font-size: 13px;
    }

    .case-study-page .case-study-back,
    .case-study-page .case-study-main {
      text-align: left;
    }

    .case-study-page .case-study-aside-card,
    .case-study-page .case-study-hero,
    .case-study-page .case-study-block,
    .case-study-page .case-study-quote {
      padding: 22px 20px;
    }

    .case-study-page .case-study-head {
      align-items: flex-start;
    }
  }
</style>

<div class="case-study-page">
  <div class="case-study-shell">
    <nav class="case-study-breadcrumb" aria-label="Breadcrumb">
      <a href="/">Home</a>
      <span class="case-study-breadcrumb-sep">/</span>
      <a href="/#case-studies-heading">Case Studies</a>
      <span class="case-study-breadcrumb-sep">/</span>
      <span>{{ hero_title }}</span>
    </nav>

    <div class="case-study-layout">
      <aside class="case-study-aside">
        <a class="case-study-back" href="/#case-studies-heading" aria-label="Back to Case Studies">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="m15 18-6-6 6-6"></path></svg>
          <span>Back to Case Studies</span>
        </a>
        <div class="case-study-aside-card">
          {% if side_logo != blank %}
            <div class="case-study-logo">
              <img src="{{ side_logo | asset_url }}" alt="{{ hero_title }} logo" loading="lazy">
            </div>
          {% endif %}

          <div class="case-study-metrics">
            <div>
              <p class="case-study-metric-label">{{ meta_1_label }}</p>
              <p class="case-study-metric-value">{{ meta_1_value }}</p>
            </div>
            <div>
              <p class="case-study-metric-label">{{ meta_2_label }}</p>
              <p class="case-study-metric-value">{{ meta_2_value }}</p>
            </div>
            <div>
              <p class="case-study-metric-label">{{ meta_3_label }}</p>
              <p class="case-study-metric-value">{{ meta_3_value }}</p>
            </div>
          </div>

          <div class="case-study-cta">
            <p>{{ cta_title }}</p>
            <a class="case-study-cta-btn" href="/collections">{{ cta_button_text }}</a>
          </div>
        </div>
      </aside>

      <div class="case-study-main">
        <section class="case-study-hero">
          <h1>{{ hero_title }} - <span>{{ hero_accent }}</span></h1>
          <h2>{{ hero_client }}</h2>
          <p>{{ hero_problem }}</p>
        </section>

        <section class="case-study-block">
          <div class="case-study-head">
            <span class="case-study-icon" aria-hidden="true">
              <svg fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M12.395 2.553a1 1 0 0 0-1.45-.385c-.345.23-.614.558-.822.88-.214.33-.403.713-.57 1.116-.334.804-.614 1.768-.84 2.734a31.365 31.365 0 0 0-.613 3.58 2.64 2.64 0 0 1-.945-1.067c-.328-.68-.398-1.534-.398-2.654A1 1 0 0 0 5.05 6.05 6.981 6.981 0 0 0 3 11a7 7 0 1 0 11.95-4.95c-.592-.591-.98-.985-1.348-1.467-.363-.476-.724-1.063-1.207-2.03zM12.12 15.12A3 3 0 0 1 7 13s.879.5 2.5.5c0-1 .5-4 1.25-4.5.5 1 .786 1.293 1.371 1.879A2.99 2.99 0 0 1 13 13a2.99 2.99 0 0 1-.879 2.121z" clip-rule="evenodd"></path></svg>
            </span>
            <h2>The Real Need</h2>
          </div>
          <div class="case-study-copy">{{ need_copy }}</div>
        </section>

        <section class="case-study-block">
          <div class="case-study-head">
            <span class="case-study-icon" aria-hidden="true">
              <svg fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 1 0 0-16 8 8 0 0 0 0 16zm3.707-8.293-3-3a1 1 0 0 0-1.414 1.414L10.586 9.5 9.293 10.793a1 1 0 1 0 1.414 1.414l3-3a1 1 0 0 0 0-1.414z" clip-rule="evenodd"></path></svg>
            </span>
            <h2>Our Response</h2>
          </div>
          {% if response_image != blank %}
            <div class="case-study-split">
              <div>
                <p class="case-study-intro">{{ response_intro }}</p>
                <ul class="case-study-list">
                  {% for item in response_list %}
                    <li>{{ item }}</li>
                  {% endfor %}
                </ul>
              </div>
              <div class="case-study-visual {% if resolved_case_handle == 'case-study-steel-wolves' %}case-study-visual-16x9{% else %}case-study-visual-4x3{% endif %}">
                <img src="{{ response_image | asset_url }}" alt="{{ response_image_alt }}" loading="lazy">
              </div>
            </div>
          {% else %}
            <p class="case-study-intro">{{ response_intro }}</p>
            <ul class="case-study-list">
              {% for item in response_list %}
                <li>{{ item }}</li>
              {% endfor %}
            </ul>
          {% endif %}
        </section>

        <section class="case-study-block">
          <div class="case-study-head">
            <span class="case-study-icon" aria-hidden="true">
              <svg fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 0 0 .95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 0 0-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 0 0-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 0 0-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 0 0 .951-.69l1.07-3.292z"></path></svg>
            </span>
            <h2>The Outcome</h2>
          </div>
          {% if outcome_image != blank %}
            <div class="case-study-split">
              <div>
                <ul class="case-study-list">
                  {% for item in outcome_list %}
                    <li>{{ item }}</li>
                  {% endfor %}
                </ul>
              </div>
              <div class="case-study-visual case-study-visual-4x3">
                <img src="{{ outcome_image | asset_url }}" alt="{{ outcome_image_alt }}" loading="lazy">
              </div>
            </div>
          {% else %}
            <ul class="case-study-list">
              {% for item in outcome_list %}
                <li>{{ item }}</li>
              {% endfor %}
            </ul>
          {% endif %}
        </section>

        <section class="case-study-quote">
          <p>{{ quote_text }}</p>
        </section>

        {% if extra_title != blank %}
          <section class="case-study-block case-study-extra">
            <div class="case-study-head">
              <span class="case-study-icon" aria-hidden="true">
