<style>
  .sitemap-page {
    background: #fff;
    color: #111827;
    padding: 152px 24px 64px;
  }
  .sitemap-shell {
    max-width: 1216px;
    margin: 0 auto;
  }
  .sitemap-header {
    max-width: 720px;
    margin: 0 auto 48px;
    text-align: center;
  }
  .sitemap-header h1 {
    margin: 0 0 14px;
    color: #111827;
    font-size: clamp(34px, 5vw, 48px);
    line-height: 1.1;
    font-weight: 800;
  }
  .sitemap-header p {
    margin: 0;
    color: #5f6978;
    font-size: 17px;
    line-height: 1.65;
    font-weight: 500;
  }
  .sitemap-sections {
    display: grid;
    gap: 48px;
  }
  .sitemap-section.is-empty {
    display: none;
  }
  .sitemap-section-head {
    margin-bottom: 16px;
  }
  .sitemap-section-head h2 {
    margin: 0 0 6px;
    color: #111827;
    font-size: 26px;
    line-height: 1.25;
    font-weight: 800;
  }
  .sitemap-section-head p {
    margin: 0;
    color: #6b7280;
    font-size: 14px;
    font-weight: 600;
  }
  .sitemap-grid {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 16px;
  }
  .sitemap-card {
    display: block;
    min-height: 74px;
    padding: 16px;
    border: 1px solid #e1e5eb;
    border-radius: 8px;
    background: #fff;
    color: inherit;
    text-decoration: none;
    transition: border-color 0.2s ease, box-shadow 0.2s ease, transform 0.2s ease;
  }
  .sitemap-card:hover {
    border-color: #7C4A1E;
    box-shadow: 0 12px 28px rgba(20, 24, 54, 0.1);
    transform: translateY(-2px);
  }
  .sitemap-card h3 {
    margin: 0 0 7px;
    color: #061226;
    font-size: 14px;
    line-height: 1.35;
    font-weight: 800;
  }
  .sitemap-card p {
    margin: 0;
    color: #647084;
    font-size: 12px;
    line-height: 1.4;
    font-weight: 700;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }
  .sitemap-status {
    padding: 18px;
    border: 1px solid #e1e5eb;
    border-radius: 8px;
    color: #647084;
    font-size: 14px;
    font-weight: 700;
  }
  .sitemap-help {
    margin-top: 48px;
    padding: 28px 24px;
    border-radius: 10px;
    background: #f8fafc;
    text-align: center;
  }
  .sitemap-help h3 {
    margin: 0 0 8px;
    color: #111827;
    font-size: 20px;
    font-weight: 800;
  }
  .sitemap-help p {
    margin: 0 0 18px;
    color: #5f6978;
  }
  .sitemap-help a {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 46px;
    padding: 12px 24px;
    border-radius: 999px;
    background: #7C4A1E;
    color: #fff;
    text-decoration: none;
    font-weight: 800;
    transition: background 0.2s ease;
  }
  .sitemap-help a:hover {
    background: #e64a19;
  }
  .sitemap-noscript {
    display: grid;
    gap: 28px;
    margin-top: 12px;
  }
  .sitemap-noscript-note {
    padding: 16px 18px;
    border: 1px solid #e1e5eb;
    border-radius: 10px;
    background: #f8fafc;
    color: #5f6978;
    font-size: 14px;
    font-weight: 600;
    line-height: 1.6;
  }
  .sitemap-noscript-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 18px;
  }
  .sitemap-noscript-card {
    padding: 18px;
    border: 1px solid #e1e5eb;
    border-radius: 10px;
    background: #fff;
  }
  .sitemap-noscript-card h3 {
    margin: 0 0 10px;
    color: #111827;
    font-size: 18px;
    line-height: 1.25;
    font-weight: 800;
  }
  .sitemap-noscript-card ul {
    margin: 0;
    padding-left: 18px;
  }
  .sitemap-noscript-list {
    margin: 0;
    padding-left: 18px;
  }
  .sitemap-noscript-list--products {
    columns: 2;
    column-gap: 28px;
  }
  .sitemap-noscript-card li {
    margin-bottom: 8px;
    color: #5f6978;
    font-size: 14px;
    line-height: 1.5;
    font-weight: 600;
  }
  .sitemap-noscript-card a {
    color: #111827;
    text-decoration: none;
  }
  .sitemap-noscript-card a:hover {
    color: #7C4A1E;
    text-decoration: underline;
  }
  @media (max-width: 1024px) {
    .sitemap-grid {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }
  }
  @media (max-width: 760px) {
    .sitemap-page {
      padding: 124px 16px 48px;
    }
    .sitemap-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 12px;
    }
    .sitemap-card {
      padding: 14px;
    }
  }
  @media (max-width: 520px) {
    .sitemap-grid {
      grid-template-columns: 1fr;
    }
    .sitemap-noscript-grid {
      grid-template-columns: 1fr;
    }
  }
</style>

<main class="sitemap-page" data-sitemap-page>
  <div class="sitemap-shell">
    <header class="sitemap-header">
      <h1>Site Map</h1>
      <p>Find all the pages and resources available on our website. Navigate easily to any section you need.</p>
    </header>

    <noscript>
      <style>
        .sitemap-sections:not(.sitemap-sections--noscript),
        .sitemap-help {
          display: none;
        }
        .sitemap-sections--noscript {
          display: grid;
        }
      </style>
      <div class="sitemap-sections sitemap-sections--noscript">
        <section class="sitemap-section">
          <div class="sitemap-section-head">
            <h2>Pages</h2>
          </div>
          {% render 'sitemap-pages-noscript' %}
        </section>

        <section class="sitemap-section">
          <div class="sitemap-section-head">
            <h2>Products</h2>
          </div>
          {% render 'sitemap-products-noscript' %}
        </section>

        <section class="sitemap-section">
          <div class="sitemap-section-head">
            <h2>Collections</h2>
          </div>
          {% render 'sitemap-collections-noscript' %}
        </section>

        <section class="sitemap-section">
          <div class="sitemap-section-head">
            <h2>Blogs</h2>
          </div>
          {% render 'sitemap-blogs-noscript' %}
        </section>
      </div>
    </noscript>

    <div class="sitemap-sections">
      <section class="sitemap-section" data-sitemap-section="pages">
        <div class="sitemap-section-head">
          <h2>Pages</h2>
          <p data-sitemap-count>Loading items</p>
        </div>
        <div class="sitemap-grid" data-sitemap-grid></div>
        <div class="sitemap-status" data-sitemap-status>Loading pages...</div>
      </section>

      <section class="sitemap-section" data-sitemap-section="products">
        <div class="sitemap-section-head">
          <h2>Products</h2>
          <p data-sitemap-count>Loading items</p>
        </div>
        <div class="sitemap-grid" data-sitemap-grid></div>
        <div class="sitemap-status" data-sitemap-status>Loading products...</div>
      </section>

      <section class="sitemap-section" data-sitemap-section="collections">
        <div class="sitemap-section-head">
          <h2>Collections</h2>
          <p data-sitemap-count>Loading items</p>
        </div>
        <div class="sitemap-grid" data-sitemap-grid></div>
        <div class="sitemap-status" data-sitemap-status>Loading collections...</div>
      </section>

      <section class="sitemap-section" data-sitemap-section="blogs">
        <div class="sitemap-section-head">
          <h2>Blogs</h2>
          <p data-sitemap-count>Loading items</p>
        </div>
        <div class="sitemap-grid" data-sitemap-grid></div>
        <div class="sitemap-status" data-sitemap-status>Loading blogs...</div>
      </section>
    </div>

    <section class="sitemap-help">
      <h3>Need Help?</h3>
      <p>Can't find what you're looking for? Our team is here to help.</p>
      <a href="/pages/contact-us">Contact Us</a>
    </section>
  </div>
</main>

<script>
  (function () {
    var root = document.querySelector('[data-sitemap-page]');
    if (!root || !window.DOMParser || !window.fetch) return;

    var siteOrigin = window.location.origin;
    var sitemapSources = [
      {
        key: 'pages',
        url: '/sitemap_pages_1.xml?from=123172651107&to=128501907555',
        include: function (path) { return path.indexOf('/pages/') === 0; }
      },
      {
        key: 'products',
        url: '/sitemap_products_1.xml?from=8001738440803&to=8029252485219',
        include: function (path) { return path.indexOf('/products/') === 0 || path.indexOf('/patches/') === 0; },
        normalize: function (path) { return path.replace(/^\/patches\//, '/products/'); }
      },
      {
        key: 'collections',
        url: '/sitemap_collections_1.xml?from=297962897507&to=297963978851',
        include: function (path) { return path.indexOf('/collections/') === 0; }
      },
      {
        key: 'blogs',
        url: '/sitemap_blogs_1.xml',
        include: function (path) { return path.indexOf('/blogs/') === 0; }
      }
    ];

    var titleOverrides = {
      '/': 'Home',
      '/pages/about-us': 'About Us',
      '/pages/author': 'Author',
      '/pages/contact': 'Contact',
      '/pages/contact-us': 'Contact Us',
      '/pages/faqs': 'FAQs',
      '/pages/charts': 'Size & Color Charts',
      '/pages/privacy-policy': 'Privacy Policy',
      '/pages/refund-returns-policy': 'Refund & Returns Policy',
      '/pages/shipping-policy': 'Shipping Policy',
      '/pages/terms-and-conditions': 'Terms and Conditions',
      '/pages/case-study-cuero-street': 'Cuero Street',
      '/pages/case-study-steel-wolves': 'Steel Wolves MC',
      '/pages/case-study-techgear': 'TechGear Solutions',
      '/blogs/news': 'Blogs'
    };

    function pathFromUrl(url) {
      try {
        return new URL(url, siteOrigin).pathname.replace(/\/$/, '') || '/';
      } catch (error) {
        return '';
      }
    }

    function titleFromPath(path) {
      if (titleOverrides[path]) return titleOverrides[path];
      var segment = (path.split('/').filter(Boolean).pop() || path).replace(/[-_]+/g, ' ');
      return segment.replace(/\b\w/g, function (letter) { return letter.toUpperCase(); });
    }

    function getImageTitle(urlNode) {
      var imageTitle = urlNode.getElementsByTagName('image:title')[0];
      return imageTitle && imageTitle.textContent ? imageTitle.textContent.trim() : '';
    }

    function uniqueItems(items) {
      var seen = {};
      return items.filter(function (item) {
        if (seen[item.path]) return false;
        seen[item.path] = true;
        return true;
      });
    }

    function renderSection(source, items) {
      var section = root.querySelector('[data-sitemap-section="' + source.key + '"]');
      if (!section) return;

      var grid = section.querySelector('[data-sitemap-grid]');
      var count = section.querySelector('[data-sitemap-count]');
      var status = section.querySelector('[data-sitemap-status]');

      if (!items.length) {
        section.classList.add('is-empty');
        return;
      }

      section.classList.remove('is-empty');
      count.textContent = items.length + (items.length === 1 ? ' item' : ' items');
      status.style.display = 'none';
      grid.innerHTML = items.map(function (item) {
        return (
          '<a class="sitemap-card" href="' + item.path + '">' +
            '<h3>' + escapeHtml(item.title) + '</h3>' +
            '<p>' + escapeHtml(item.path) + '</p>' +
          '</a>'
        );
      }).join('');
    }

    function renderError(source) {
      var section = root.querySelector('[data-sitemap-section="' + source.key + '"]');
      if (!section) return;
      var count = section.querySelector('[data-sitemap-count]');
      var status = section.querySelector('[data-sitemap-status]');
      count.textContent = '0 items';
      status.textContent = 'Unable to load this sitemap section.';
    }

    function escapeHtml(value) {
      return String(value)
        .replace(/&/g, '&amp;')
        .replace(/</g, '&lt;')
        .replace(/>/g, '&gt;')
        .replace(/"/g, '&quot;')
        .replace(/'/g, '&#039;');
    }

    sitemapSources.forEach(function (source) {
      fetch(source.url)
        .then(function (response) {
          if (!response.ok) throw new Error('Sitemap request failed');
          return response.text();
        })
        .then(function (xmlText) {
          var doc = new DOMParser().parseFromString(xmlText, 'application/xml');
          var urlNodes = Array.prototype.slice.call(doc.getElementsByTagName('url'));
          var items = urlNodes.map(function (urlNode) {
            var loc = urlNode.getElementsByTagName('loc')[0];
            var path = loc ? pathFromUrl(loc.textContent) : '';
            if (source.normalize) path = source.normalize(path);
            return {
              path: path,
              title: getImageTitle(urlNode) || titleFromPath(path)
            };
          }).filter(function (item) {
            return item.path && item.path !== '/' && source.include(item.path);
          });

          renderSection(source, uniqueItems(items));
        })
        .catch(function () {
          renderError(source);
        });
    });
  })();
</script>

