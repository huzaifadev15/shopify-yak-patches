<script>
  (function () {
    var root = document.querySelector('[data-faq-page]');
    if (!root) return;

    var searchInput = root.querySelector('[data-faq-search]');
    var categoryButtons = Array.prototype.slice.call(root.querySelectorAll('.faq-category-btn[data-faq-category]'));
    var sections = Array.prototype.slice.call(root.querySelectorAll('[data-faq-section]'));
    var items = Array.prototype.slice.call(root.querySelectorAll('[data-faq-item]'));
    var emptyState = root.querySelector('[data-faq-empty]');
    var resultsHeading = root.querySelector('[data-faq-results-heading]');
    var backTop = root.querySelector('[data-faq-back-top]');
    var activeCategory = 'all';

    function normalize(value) {
      return (value || '').toLowerCase().trim();
    }

    function setActiveCategory(category, shouldScroll) {
      activeCategory = category;
      categoryButtons.forEach(function (button) {
        button.classList.toggle('is-active', button.getAttribute('data-faq-category') === category);
      });
      filterItems();

      if (shouldScroll && category !== 'all') {
        var target = root.querySelector('[data-faq-section="' + category + '"]');
        if (target) target.scrollIntoView({ behavior: 'smooth', block: 'start' });
      }
      if (shouldScroll && category === 'all') {
        window.scrollTo({ top: 0, behavior: 'smooth' });
      }
    }

    function filterItems() {
      var query = normalize(searchInput.value);
      var visibleCount = 0;

      items.forEach(function (item) {
        var matchesCategory = activeCategory === 'all' || item.getAttribute('data-faq-category') === activeCategory;
        var haystack = normalize(item.getAttribute('data-faq-question') + ' ' + item.getAttribute('data-faq-answer'));
        var matchesSearch = !query || haystack.indexOf(query) !== -1;
        var isVisible = matchesCategory && matchesSearch;

        item.classList.toggle('is-hidden', !isVisible);
        if (isVisible) visibleCount += 1;
      });

      sections.forEach(function (section) {
        var sectionHasVisibleItem = !!section.querySelector('[data-faq-item]:not(.is-hidden)');
        section.classList.toggle('is-hidden', !sectionHasVisibleItem);
      });

      if (emptyState) emptyState.classList.toggle('is-visible', visibleCount === 0);
      if (resultsHeading) resultsHeading.style.display = query ? 'block' : 'none';
    }

    categoryButtons.forEach(function (button) {
      button.addEventListener('click', function () {
        setActiveCategory(button.getAttribute('data-faq-category'), true);
      });
    });

    searchInput.addEventListener('input', filterItems);

    window.addEventListener('scroll', function () {
      if (backTop) backTop.classList.toggle('is-visible', window.scrollY > 300);
    });

    if (backTop) {
      backTop.addEventListener('click', function () {
        window.scrollTo({ top: 0, behavior: 'smooth' });
      });
    }
  })();
</script>

