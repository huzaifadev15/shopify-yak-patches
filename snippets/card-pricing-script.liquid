<script>
  (function() {
    if (window.FineystCardPricingLoaded) return;
    window.FineystCardPricingLoaded = true;

    var priceUrl = '{{ "pricing-updt.json" | asset_url }}';
    var pricingApiUrl = 'https://shopify-backend-app-omega.vercel.app/api/pricing/by-page-title';
    var defaultPricingTitle = 'Embroidered Patches';
    var moneyFormatter = new Intl.NumberFormat('en-US', {
      style: 'currency',
      currency: 'USD',
      minimumFractionDigits: 2,
      maximumFractionDigits: 2
    });

    function normalize(value) {
      return String(value || '')
        .toLowerCase()
        .replace(/&/g, 'and')
        .replace(/\bcustom\b/g, '')
        .replace(/\bpatches\b/g, 'patch')
        .replace(/[^a-z0-9]+/g, ' ')
        .trim();
    }

    function getCandidateTitles(el) {
      return String(el.dataset.cardPriceTitles || '')
        .split('|||')
        .map(function(title) { return title.trim(); })
        .filter(Boolean);
    }

    function parseSize(value) {
      var match = String(value || '').match(/[\d.]+/);
      return match ? parseFloat(match[0]) : 0;
    }

    function getTenPieceEntryPrice(rows, titles) {
      var normalizedTitles = titles.map(normalize).filter(Boolean);
      var exactMatch = null;
      var fallbackMatch = null;
      var fallbackSize = Infinity;

      rows.forEach(function(row) {
        var rowName = normalize(row.name);
        var size = parseSize(row.size);
        var hasFlatTargetTier = Number(row.quantity) === 10 && row.price != null;
        var hasMatrixTargetTier = row.qty10 != null;
        var hasTargetTier = hasFlatTargetTier || hasMatrixTargetTier;
        if (!hasTargetTier || !size) return;

        var titleMatch = !rowName || normalizedTitles.some(function(title) {
          return rowName === title || rowName.indexOf(title) !== -1 || title.indexOf(rowName) !== -1;
        });

        if (!titleMatch) return;

        var price = parseFloat(hasMatrixTargetTier ? row.qty10 : row.price);
        if (isNaN(price) || price <= 0) return;

        if (size === 1) {
          exactMatch = price;
          return;
        }

        if (size < fallbackSize) {
          fallbackSize = size;
          fallbackMatch = price;
        }
      });

      return exactMatch || fallbackMatch;
    }

    function getRowsFromApi(title) {
      return fetch(pricingApiUrl + '?title=' + encodeURIComponent(title))
        .then(function(response) { return response.ok ? response.json() : []; })
        .then(function(rows) { return Array.isArray(rows) ? rows : []; })
        .catch(function() { return []; });
    }

    function getRowsFromAsset() {
      return fetch(priceUrl)
        .then(function(response) { return response.ok ? response.json() : []; })
        .then(function(rows) { return Array.isArray(rows) ? rows : []; })
        .catch(function() { return []; });
    }

    function setPrice(el, price) {
      if (price) {
        el.textContent = 'As low as ' + moneyFormatter.format(price) + ' ea';
        return;
      }

      el.textContent = el.dataset.cardPriceFallback || 'Custom quote available';
    }

    function applyPrices(assetRows) {
      document.querySelectorAll('[data-card-price-titles]').forEach(function(el) {
        var titles = getCandidateTitles(el);
        if (!titles.length) {
          setPrice(el, null);
          return;
        }

        var apiTitles = titles.slice(0, 4);
        var apiRequests = apiTitles.map(getRowsFromApi);
        Promise.all(apiRequests).then(function(results) {
          var apiRows = [];
          results.forEach(function(rows) { apiRows = apiRows.concat(rows); });
          var apiPrice = getTenPieceEntryPrice(apiRows, titles);
          var assetPrice = getTenPieceEntryPrice(assetRows, titles);

          if (apiPrice || assetPrice || normalize(titles[0]) === normalize(defaultPricingTitle)) {
            setPrice(el, apiPrice || assetPrice);
            return;
          }

          getRowsFromApi(defaultPricingTitle).then(function(defaultRows) {
            setPrice(el, apiPrice || getTenPieceEntryPrice(defaultRows, [defaultPricingTitle]) || assetPrice);
          });
        });
      });
    }

    getRowsFromAsset().then(applyPrices);
  })();
</script>

