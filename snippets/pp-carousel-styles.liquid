  .pp-type-carousel-title { font-size: 15px; gap: 8px; }
  .pp-type-carousel-step { width: 22px; height: 22px; font-size: 12px; }
  .pp-type-carousel-current { padding: 3px 8px; font-size: 10px; }
  .pp-type-track {
    display: grid !important;
    grid-template-columns: repeat(2, minmax(0, 1fr)) !important;
    gap: 10px !important;
    padding: 2px 2px !important;
    /* show ~3 rows (6 cards) then scroll vertically for the rest */
    max-height: calc(112vw + 50px) !important;
    overflow-x: hidden !important;
    overflow-y: auto !important;
    scroll-behavior: auto !important;
    -webkit-overflow-scrolling: touch;
    overscroll-behavior: contain;
    scrollbar-width: thin;
  }
  .pp-type-track::-webkit-scrollbar { display: block; width: 4px; }
  .pp-type-track::-webkit-scrollbar-thumb { background: #ffd0b5; border-radius: 4px; }
