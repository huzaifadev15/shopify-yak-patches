.pp-title { font-size: clamp(26px, 3.2vw, 44px); font-weight: 700; color: #1C0800; margin-bottom: 0px; line-height: 1.2; }
.pp-type-carousel { position: relative; border: 2px solid #ff5b14; border-radius: 8px; padding: 14px 10px 16px; margin: 0 0 18px; background: #fff; box-shadow: 0 10px 28px rgba(20,26,50,0.12); overflow: hidden; }
.pp-type-carousel-head { display:flex; align-items:center; justify-content:space-between; gap:10px; margin-bottom:12px; }
.pp-type-carousel-title { display:flex; align-items:center; gap:8px; color:#ff5b14; font-size:16px; font-weight:800; line-height:1.2; }
.pp-type-carousel-step { width:22px; height:22px; border-radius:9999px; background:#ff5b14; color:#fff; display:inline-flex; align-items:center; justify-content:center; font-size:12px; font-weight:800; box-shadow:0 4px 12px rgba(255,91,20,0.25); }
.pp-type-carousel-current { border-radius:9999px; background:#fff1e7; color:#c2410c; padding:3px 8px; font-size:10px; font-weight:800; }
.pp-type-track { display:flex; gap:10px; overflow-x:auto; scroll-behavior:smooth; scrollbar-width:none; padding:2px 2px 2px; }
.pp-type-track::-webkit-scrollbar { display:none; }
.pp-type-card { flex:0 0 180px; text-decoration:none; color:#1C0800; text-align:center; font-weight:800; font-size:13px; outline:none; transition:opacity .18s ease; }
.pp-type-card-img { width:100%; aspect-ratio:4/3; border:1px solid #dde2ea; border-radius:10px; background:#f8fafc; display:flex; align-items:center; justify-content:center; overflow:hidden; transition:border-color .18s, box-shadow .18s, transform .18s, filter .18s; max-height: 190px; }
.pp-type-card-img img { width:100%; height:100%; object-fit:contain; padding:8px; display:block; }
.pp-type-card-title { display:block; margin-top:8px; white-space:normal; line-height:1.2; }
@media (hover: hover) and (pointer: fine) {
  .pp-type-card:hover .pp-type-card-img { border-color:#ff5b14; box-shadow:0 0 0 2px rgba(255,91,20,0.14); transform:translateY(-1px); }
}
.pp-type-card:focus-visible .pp-type-card-img,
.pp-type-card.is-active .pp-type-card-img { border-color:#ff5b14; box-shadow:0 0 0 2px rgba(255,91,20,0.14); transform:translateY(-1px); }
.pp-type-card.is-active .pp-type-card-title { color:#ff5b14; }
.pp-type-carousel.has-active .pp-type-card:not(.is-active) { opacity:.55; }
.pp-type-carousel.has-active .pp-type-card:not(.is-active) .pp-type-card-img { filter:grayscale(.35) saturate(.8); }
.pp-type-carousel.has-active .pp-type-card:not(.is-active):hover { opacity:1; }
.pp-type-carousel.has-active .pp-type-card:not(.is-active):hover .pp-type-card-img { filter:none; }
.pp-type-carousel.has-active .pp-type-card.is-active .pp-type-card-img { border-color:#ff5b14; box-shadow:0 0 0 2px rgba(255,91,20,0.22), 0 12px 28px rgba(255,91,20,0.16); }
.pp-type-placeholder { width:72px; height:72px; border-radius:50%; border:8px solid #120400; opacity:.18; }
.pp-type-arrow { position:absolute; top:50%; transform:translateY(-10%); width:34px; height:34px; border:none; border-radius:50%; background:#fff; color:#1C0800; display:flex; align-items:center; justify-content:center; box-shadow:0 6px 18px rgba(20,26,50,.18); cursor:pointer; z-index:3; }
.pp-type-arrow:hover { color:#ff5b14; }
.pp-type-arrow-prev { left:10px; }
.pp-type-arrow-next { right:10px; }
.pp-type-loading { pointer-events:none; opacity:.62; }
@media (max-width: 768px) { .pp-title { font-size: clamp(32px, 8vw, 34px); font-weight: 700; line-height: 1.1; } }
@media (max-width: 768px) {
