  <div class="gallery-lightbox" data-gallery-lightbox hidden aria-hidden="true">
    <div class="gallery-lightbox-backdrop" data-gallery-close></div>
    <div class="gallery-lightbox-shell" role="dialog" aria-modal="true" aria-label="Customer patch gallery viewer">
      <button class="gallery-lightbox-close" type="button" aria-label="Close gallery viewer" data-gallery-close>
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M18 6 6 18"></path><path d="m6 6 12 12"></path></svg>
      </button>
      <button class="gallery-lightbox-nav gallery-lightbox-nav--prev" type="button" aria-label="Previous image" data-gallery-prev>
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m15 18-6-6 6-6"></path></svg>
      </button>
      <button class="gallery-lightbox-nav gallery-lightbox-nav--next" type="button" aria-label="Next image" data-gallery-next>
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m9 18 6-6-6-6"></path></svg>
      </button>

      <div class="gallery-lightbox-layout">
        <div class="gallery-lightbox-media">
          <img src="" alt="" data-gallery-lightbox-image>
        </div>
        <div class="gallery-lightbox-info">
          <span class="gallery-lightbox-kicker">Customer Gallery</span>
          <h3 class="gallery-lightbox-title" data-gallery-lightbox-title></h3>
          <p class="gallery-lightbox-description">Premium custom patch work from our customer gallery, showcasing vibrant thread, clean edges, and detailed craftsmanship.</p>
          <div class="gallery-lightbox-count" data-gallery-lightbox-count></div>
          <div class="gallery-lightbox-actions">
            <a href="" class="gallery-btn gallery-btn-primary" target="_blank" rel="noopener noreferrer" data-gallery-lightbox-open-original>Open Full Size</a>
          </div>
          <div class="gallery-lightbox-thumb-row" data-gallery-thumb-row></div>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
  (() => {
    const lightbox = document.querySelector('[data-gallery-lightbox]');
    if (!lightbox) return;

    const items = Array.from(document.querySelectorAll('[data-gallery-open]')).map((item) => ({
      src: item.getAttribute('data-gallery-src'),
      alt: item.getAttribute('data-gallery-alt'),
      title: item.getAttribute('data-gallery-title')
    }));

    const imageEl = lightbox.querySelector('[data-gallery-lightbox-image]');
    const titleEl = lightbox.querySelector('[data-gallery-lightbox-title]');
    const countEl = lightbox.querySelector('[data-gallery-lightbox-count]');
    const originalEl = lightbox.querySelector('[data-gallery-lightbox-open-original]');
    const thumbRow = lightbox.querySelector('[data-gallery-thumb-row]');
    const closeButtons = lightbox.querySelectorAll('[data-gallery-close]');
    const prevButton = lightbox.querySelector('[data-gallery-prev]');
    const nextButton = lightbox.querySelector('[data-gallery-next]');

    let currentIndex = 0;

    function renderThumbs() {
      if (!thumbRow) return;
      thumbRow.innerHTML = items.slice(0, 4).map((item, index) => {
        const actualIndex = (currentIndex + index) % items.length;
        const thumb = items[actualIndex];
        return '<button class="gallery-lightbox-thumb' + (actualIndex === currentIndex ? ' is-active' : '') + '" type="button" data-gallery-thumb-index="' + actualIndex + '" aria-label="View ' + thumb.title + '"><img src="' + thumb.src + '" alt="' + thumb.alt + '"></button>';
      }).join('');

      thumbRow.querySelectorAll('[data-gallery-thumb-index]').forEach((button) => {
        button.addEventListener('click', () => render(Number(button.getAttribute('data-gallery-thumb-index'))));
      });
    }

    function render(index) {
      const item = items[index];
      if (!item) return;

      currentIndex = index;
      imageEl.src = item.src;
      imageEl.alt = item.alt;
      titleEl.textContent = item.title;
      countEl.textContent = 'Image ' + (index + 1) + ' of ' + items.length;
      originalEl.href = item.src;
      renderThumbs();
    }

    function open(index) {
      render(index);
      lightbox.hidden = false;
      lightbox.setAttribute('aria-hidden', 'false');
      document.body.classList.add('gallery-lightbox-open');
    }

    function close() {
      lightbox.hidden = true;
      lightbox.setAttribute('aria-hidden', 'true');
      document.body.classList.remove('gallery-lightbox-open');
    }

    function navigate(step) {
      const next = (currentIndex + step + items.length) % items.length;
      render(next);
    }

    document.querySelectorAll('[data-gallery-open]').forEach((trigger, index) => {
      trigger.addEventListener('click', (event) => {
        event.preventDefault();
        open(index);
      });
    });

    closeButtons.forEach((button) => {
      button.addEventListener('click', close);
    });

    if (prevButton) {
      prevButton.addEventListener('click', () => navigate(-1));
    }

    if (nextButton) {
      nextButton.addEventListener('click', () => navigate(1));
    }

    document.addEventListener('keydown', (event) => {
      if (lightbox.hidden) return;
      if (event.key === 'Escape') close();
      if (event.key === 'ArrowLeft') navigate(-1);
      if (event.key === 'ArrowRight') navigate(1);
    });
  })();
</script>

