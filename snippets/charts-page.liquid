<style>
  .charts-page {
    min-height: 100vh;
    background: #f8fafc;
    color: #2A1008;
  }

  .charts-page .charts-shell {
    width: 100%;
    max-width: 1280px;
    margin: 0 auto;
    padding: 140px 16px 80px;
  }

  .charts-page .charts-breadcrumb {
    margin-bottom: 24px;
    color: #64748b;
    font-size: 14px;
    font-weight: 600;
  }

  .charts-page .charts-breadcrumb a {
    color: inherit;
  }

  .charts-page .charts-breadcrumb a:hover {
    color: {{ primary_color }};
  }

  .charts-page .charts-mobile-toggle-wrap {
    display: none;
  }

  .charts-page .charts-layout {
    display: grid;
    grid-template-columns: 280px minmax(0, 1fr);
    gap: 28px;
    align-items: start;
  }

  .charts-page .charts-sidebar-column {
    position: relative;
    min-width: 0;
  }

  .charts-page .charts-sidebar {
    align-self: start;
    height: fit-content;
    position: sticky;
    top: 132px;
    max-height: calc(100vh - 156px);
    border: 1px solid rgba(10, 36, 99, 0.1);
    border-radius: 24px;
    background: #fff;
    box-shadow: 0 16px 40px rgba(15, 23, 42, 0.08);
    overflow-y: auto;
    overflow-x: hidden;
  }

  .charts-page .charts-sidebar.is-sticky-fixed {
    position: fixed;
    top: 132px;
    left: var(--charts-sidebar-left, 16px);
    width: var(--charts-sidebar-width, 280px);
    z-index: 30;
  }

  .charts-page .charts-sidebar.is-sticky-bottom {
    position: absolute;
    top: auto;
    bottom: 0;
    left: 0;
    width: 100%;
  }

  .charts-page .charts-sidebar-head {
    padding: 20px 22px 14px;
    background: linear-gradient(135deg, {{ dark_color }}, #142a78);
    color: #fff;
  }

  .charts-page .charts-sidebar-head h2 {
    margin: 0 0 6px;
    font-size: 1.2rem;
    font-weight: 800;
  }

  .charts-page .charts-sidebar-head p {
    margin: 0;
    color: rgba(255, 255, 255, 0.82);
    font-size: 0.9rem;
    line-height: 1.6;
  }

  .charts-page .charts-sidebar-nav {
    padding: 12px;
  }

  .charts-page .charts-sidebar-link {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
    padding: 12px 14px;
    border-radius: 16px;
    color: #334155;
    font-size: 0.96rem;
    font-weight: 700;
    transition: background 0.2s ease, color 0.2s ease, transform 0.2s ease;
  }

  .charts-page .charts-sidebar-link:hover,
  .charts-page .charts-sidebar-link.is-active {
    background: rgba(124, 74, 30, 0.08);
    color: {{ primary_color }};
    transform: translateX(2px);
  }

  .charts-page .charts-sidebar-link-index {
    font-size: 0.8rem;
    color: #94a3b8;
  }

  .charts-page .charts-content {
    display: flex;
    flex-direction: column;
    gap: 28px;
    min-width: 0;
  }

  .charts-page .charts-card {
    border: 1px solid rgba(10, 36, 99, 0.1);
    border-radius: 24px;
    background: #fff;
    box-shadow: 0 16px 40px rgba(15, 23, 42, 0.08);
    overflow: hidden;
    scroll-margin-top: 138px;
  }

  .charts-page .charts-card-inner {
    padding: 28px;
    min-width: 0;
  }

  .charts-page .charts-hero-title {
    margin: 0 0 12px;
    color: {{ dark_color }};
    font-size: clamp(2rem, 4vw, 3rem);
    line-height: 1.1;
    font-weight: 800;
  }

  .charts-page .charts-hero-text,
  .charts-page .charts-section-intro {
    margin: 0;
    color: #64748b;
    font-size: 1rem;
    line-height: 1.8;
    font-weight: 500;
  }

  .charts-page .charts-list {
    margin: 20px 0 0;
    padding-left: 22px;
    color: #334155;
    list-style: disc;
  }

  .charts-page .charts-list li + li {
    margin-top: 10px;
  }

  .charts-page .charts-list h3 {
    margin: 0;
    font-size: 1rem;
    line-height: 1.6;
    font-weight: 700;
    overflow-wrap: anywhere;
  }

  .charts-page .charts-section-head {
    margin-bottom: 22px;
  }

  .charts-page .charts-section-head h2 {
    margin: 0 0 10px;
    color: {{ dark_color }};
    font-size: clamp(1.5rem, 3vw, 2.25rem);
    line-height: 1.2;
    font-weight: 800;
  }

  .charts-page .charts-search {
    width: 100%;
    min-height: 52px;
    margin-bottom: 22px;
    border: 1px solid #d1d5db;
    border-radius: 9999px;
    background: #fff;
    padding: 0 18px;
    color: #111827;
    font-size: 0.96rem;
    outline: none;
    transition: border-color 0.2s ease, box-shadow 0.2s ease;
  }

  .charts-page .charts-search:focus {
    border-color: {{ primary_color }};
    box-shadow: 0 0 0 3px rgba(124, 74, 30, 0.15);
  }

  .charts-page .charts-table-wrap {
    overflow-x: auto;
    min-width: 0;
    -webkit-overflow-scrolling: touch;
  }

  .charts-page .charts-table {
    width: 100%;
    min-width: 640px;
    border-collapse: collapse;
  }

  .charts-page .charts-table thead tr {
    background: linear-gradient(135deg, {{ primary_color }}, #7C4A1E);
    color: #fff;
  }

  .charts-page .charts-table th,
  .charts-page .charts-table td {
    padding: 14px 16px;
    text-align: left;
    border-bottom: 1px solid #e5e7eb;
    font-size: 0.92rem;
  }

  .charts-page .charts-table th {
    font-weight: 700;
    letter-spacing: 0.02em;
    text-transform: uppercase;
  }

  .charts-page .charts-table td {
    color: #334155;
    font-weight: 500;
