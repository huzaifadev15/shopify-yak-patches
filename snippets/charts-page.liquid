                <div class="charts-swatch-card" data-chart-item data-search-text="{{ parts[0] }} {{ parts[1] }} {{ parts[2] }}">
                  <div class="charts-swatch-color" style="background-color: {{ parts[2] }};{% if parts[2] == '#FFFFFF' %}border:1px solid #e5e7eb;{% endif %}"></div>
                  <div class="charts-swatch-body">
                    <p class="charts-swatch-title">{{ parts[0] }}</p>
                    <p class="charts-swatch-meta">{{ parts[1] }}</p>
                    <p class="charts-swatch-meta">{{ parts[2] }}</p>
                  </div>
                </div>
              {%- endfor -%}
            </div>
            <div class="charts-empty" data-chart-empty="pantone">No Pantone colors found matching your search criteria.</div>
            <div class="charts-note">
              <h3>Pantone Color Information</h3>
