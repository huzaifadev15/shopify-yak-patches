            <a class="charts-sidebar-link" href="#charts-thread" data-charts-nav><span>Thread Chart</span><span class="charts-sidebar-link-index">05</span></a>
            <a class="charts-sidebar-link" href="#charts-woven" data-charts-nav><span>Woven Swatches</span><span class="charts-sidebar-link-index">06</span></a>
