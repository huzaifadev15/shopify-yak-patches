<script>
  (() => {
    const root = document.currentScript && document.currentScript.previousElementSibling;
    if (!root || !root.matches('[data-charts-page]')) return;

    const desktopBreakpoint = 900;
    const stickyTop = 132;
    const stickyBottomGap = 24;
    const layout = root.querySelector('.charts-layout');
    const sidebar = root.querySelector('[data-charts-sidebar]');
    const sidebarColumn = root.querySelector('[data-charts-sidebar-column]');
    const content = root.querySelector('.charts-content');
    const toggle = root.querySelector('[data-charts-toggle]');
    const backdrop = root.querySelector('[data-charts-backdrop]');
    const navLinks = Array.from(root.querySelectorAll('[data-charts-nav]'));
    const sections = Array.from(root.querySelectorAll('[data-charts-section]'));

    const resetDesktopSticky = () => {
      if (!sidebar || !sidebarColumn) return;
      sidebar.classList.remove('is-sticky-fixed', 'is-sticky-bottom');
      sidebar.style.removeProperty('--charts-sidebar-left');
      sidebar.style.removeProperty('--charts-sidebar-width');
      sidebarColumn.style.removeProperty('min-height');
    };

    const updateDesktopSticky = () => {
      if (!sidebar || !sidebarColumn || !content || !layout) return;
      if (window.innerWidth <= desktopBreakpoint) {
        resetDesktopSticky();
        return;
      }

      const columnRect = sidebarColumn.getBoundingClientRect();
      const layoutRect = layout.getBoundingClientRect();
      const contentHeight = content.offsetHeight;
      const sidebarHeight = sidebar.offsetHeight;
      const maxHeight = Math.max(contentHeight, sidebarHeight);

      sidebarColumn.style.minHeight = maxHeight + 'px';
      sidebar.style.setProperty('--charts-sidebar-left', Math.round(columnRect.left) + 'px');
      sidebar.style.setProperty('--charts-sidebar-width', Math.round(columnRect.width) + 'px');

      const sidebarStart = window.scrollY + layoutRect.top;
      const sidebarEnd = sidebarStart + maxHeight;
      const fixedStop = sidebarEnd - stickyTop - stickyBottomGap - sidebarHeight;
      const scrollY = window.scrollY;

      sidebar.classList.remove('is-sticky-fixed', 'is-sticky-bottom');

      if (scrollY <= sidebarStart - stickyTop) {
        return;
      }

      if (scrollY >= fixedStop) {
        sidebar.classList.add('is-sticky-bottom');
        return;
      }

      sidebar.classList.add('is-sticky-fixed');
    };

    const closeSidebar = () => {
      if (!sidebar || window.innerWidth > desktopBreakpoint) return;
      sidebar.classList.remove('is-open');
      backdrop && backdrop.classList.remove('is-open');
    };

    const openSidebar = () => {
      if (!sidebar || window.innerWidth > desktopBreakpoint) return;
      sidebar.classList.add('is-open');
      backdrop && backdrop.classList.add('is-open');
    };

    if (toggle) {
      toggle.addEventListener('click', () => {
        if (sidebar && sidebar.classList.contains('is-open')) {
          closeSidebar();
        } else {
          openSidebar();
        }
      });
    }

    if (backdrop) {
      backdrop.addEventListener('click', closeSidebar);
    }

    navLinks.forEach((link) => {
      link.addEventListener('click', closeSidebar);
    });

    const setActiveLink = () => {
      if (!sections.length) return;
      let activeId = sections[0].id;
      const offset = 180;

      sections.forEach((section) => {
        const rect = section.getBoundingClientRect();
        if (rect.top - offset <= 0) {
          activeId = section.id;
        }
      });

      navLinks.forEach((link) => {
        const isActive = link.getAttribute('href') === '#' + activeId;
        link.classList.toggle('is-active', isActive);
      });
    };

    setActiveLink();
    window.addEventListener('scroll', setActiveLink, { passive: true });
    updateDesktopSticky();
    window.addEventListener('scroll', updateDesktopSticky, { passive: true });
    window.addEventListener('resize', updateDesktopSticky);
    window.addEventListener('load', updateDesktopSticky);

    const searchInputs = root.querySelectorAll('[data-chart-search]');
    searchInputs.forEach((input) => {
      input.addEventListener('input', () => {
        const key = input.getAttribute('data-chart-search');
        const target = root.querySelector('[data-chart-target="' + key + '"]');
        const empty = root.querySelector('[data-chart-empty="' + key + '"]');
        if (!target) return;

        const query = input.value.trim().toLowerCase();
        const items = target.querySelectorAll('[data-chart-item]');
        let visibleCount = 0;

        items.forEach((item) => {
          const haystack = (item.getAttribute('data-search-text') || '').toLowerCase();
          const matches = !query || haystack.indexOf(query) !== -1;
          item.style.display = matches ? '' : 'none';
          if (matches) visibleCount += 1;
        });

        if (empty) {
          empty.classList.toggle('is-visible', visibleCount === 0);
        }
      });
    });
  })();
</script>

