                    <th>Swatch</th>
                    <th>Thread Type</th>
                  </tr>
                </thead>
                <tbody>
                  {%- for row in thread_rows_raw -%}
                    {%- assign parts = row | split: '|^|' -%}
                    <tr data-chart-item data-search-text="{{ parts[0] }} {{ parts[2] }}">
                      <td data-label="Thread Code">{{ parts[0] }}</td>
                      <td data-label="Swatch">
                        <div style="width:100%;min-width:110px;height:28px;border-radius:8px;border:1px solid #e5e7eb;background-color: {{ parts[1] }};"></div>
