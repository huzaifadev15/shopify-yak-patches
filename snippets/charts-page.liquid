      <main class="charts-content">
        <section class="charts-card" id="charts-overview" data-charts-section>
          <div class="charts-card-inner">
            <h1 class="charts-hero-title">Reference Charts</h1>
            <p class="charts-hero-text">
              Welcome to our reference charts section. Please select a chart from the sidebar to view detailed information
              about our patch sizes, colors, materials, and more.
            </p>
            <ul class="charts-list">
              <li><h3>Size Chart - Dimensions and measurements for all patch types</h3></li>
              <li><h3>Color Chart - Pantone color matching options</h3></li>
              <li><h3>Cloth Color Swatches - Fabric options and colors</h3></li>
              <li><h3>Thread Color Chart - Embroidery thread options</h3></li>
              <li><h3>Woven Thread Swatches - Woven patch thread options</h3></li>
            </ul>
          </div>
        </section>

        <section class="charts-card" id="charts-size" data-charts-section>
          <div class="charts-card-inner">
            <div class="charts-section-head">
              <h2>Size Chart</h2>
              <p class="charts-section-intro">Find the right patch size for jackets, caps, uniforms, bags, and branding applications. All measurements are shown in inches.</p>
            </div>
            <input class="charts-search" type="search" placeholder="Search by size..." data-chart-search="size">
            <div class="charts-table-wrap" data-chart-target="size">
              <table class="charts-table charts-table--mobile-cards">
                <thead>
                  <tr>
                    <th>Size</th>
                    <th>Width</th>
                    <th>Height</th>
                    <th>Category</th>
                  </tr>
                </thead>
                <tbody>
                  {%- for row in size_chart_rows_raw -%}
                    {%- assign parts = row | split: '|^|' -%}
                    <tr data-chart-item data-search-text="{{ parts[0] }} {{ parts[1] }} {{ parts[2] }} {{ parts[3] }}">
                      <td data-label="Size">{{ parts[0] }}</td>
                      <td data-label="Width">{{ parts[1] }}</td>
                      <td data-label="Height">{{ parts[2] }}</td>
                      <td data-label="Category">
                        <span class="charts-chip {% if parts[3] == 'Small' %}charts-chip--small{% elsif parts[3] == 'Medium' %}charts-chip--medium{% elsif parts[3] == 'Large' %}charts-chip--large{% elsif parts[3] == 'Extra Large' %}charts-chip--xlarge{% else %}charts-chip--rectangle{% endif %}">
                          {{ parts[3] }}
                        </span>
                      </td>
                    </tr>
                  {%- endfor -%}
