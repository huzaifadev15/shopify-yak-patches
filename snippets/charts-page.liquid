              {%- for row in cloth_rows_raw -%}
                {%- assign parts = row | split: '|^|' -%}
                <div class="charts-swatch-card" data-chart-item data-search-text="{{ parts[0] }} {{ parts[2] }}">
                  <div class="charts-swatch-color" style="background-color: {{ parts[1] }};{% if parts[1] == '#FFFFFF' or parts[1] == '#ffffff' %}border:1px solid #e5e7eb;{% endif %}"></div>
                  <div class="charts-swatch-body">
                    <p class="charts-swatch-title">{{ parts[0] }}</p>
                    <p class="charts-swatch-meta">{{ parts[2] }}</p>
                  </div>
                </div>
              {%- endfor -%}
            </div>
            <div class="charts-empty" data-chart-empty="cloth">No cloth colors found matching your search criteria.</div>
            <div class="charts-note">
              <h3>Cloth Material Information</h3>
              <ul>
                <li>Colors may appear slightly different on screen versus actual fabric.</li>
                <li>All cloth materials are colorfast and resistant to fading.</li>
                <li>Custom cloth colors are available upon request.</li>
                <li>Our fabrics are durable and designed for long-lasting patches.</li>
                <li>For exact color matching, please provide the specific cloth code.</li>
              </ul>
            </div>
          </div>
        </section>

        <section class="charts-card" id="charts-thread" data-charts-section>
          <div class="charts-card-inner">
            <div class="charts-section-head">
              <h2>Thread Color Chart</h2>
              <p class="charts-section-intro">Compare standard embroidery threads, Madeira rayon options, metallic finishes, and neon shades for standout patch work.</p>
            </div>
            <input class="charts-search" type="search" placeholder="Search thread colors by ID number..." data-chart-search="thread">
